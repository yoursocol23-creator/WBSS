                    break
                end
            end
            
            task.wait(0.05)
        end
        
        StopWalking()
    end
end

function UI:StartStatusUpdater()
    if self.statusUpdaterThread then
        task.cancel(self.statusUpdaterThread)
        self.statusUpdaterThread = nil
    end
    
    self.statusUpdaterThread = task.spawn(function()
        -- Start alive check system
        AliveCheck:Start()
        
        -- Constant walkspeed enforcer
        task.spawn(function()
            while self.isRunning do
                local character = game.Players.LocalPlayer.Character
                if character then
                    local humanoid = character:FindFirstChild("Humanoid")
                    if humanoid and humanoid.Address then
                        if not self.starActive then
                            pcall(function()
                                memory_write("float", humanoid.Address + (OFFSETS.WalkSpeed or 0x1D4), self.walkSpeed or 50)
                                memory_write("float", humanoid.Address + (OFFSETS.WalkSpeedCheck or 0x3C0), self.walkSpeed or 50)
                            end)
                        end
                    end
                end
                task.wait(0.1)
            end
        end)
        
        while self.isRunning do
            if self.autoFarmEnabled then
                local success = pcall(function()
                    local player = game.Players.LocalPlayer
                    local character = player.Character
                    
                    if character then
                        local coreStats = player:FindFirstChild("CoreStats")
                        if coreStats then
                            local pollen = coreStats:FindFirstChild("Pollen")
                            local capacity = coreStats:FindFirstChild("Capacity")
                            local honey = coreStats:FindFirstChild("Honey")
                            
                            if pollen and capacity then
                                local pollenValue = math.floor(pollen.Value)
                                local capacityValue = math.floor(capacity.Value)
                                local percentage = math.floor((pollenValue / capacityValue) * 100)
                                
                                local newStatus = string.format("Farming | %d%% (%d/%d)", percentage, pollenValue, capacityValue)
                                
                                if self.status ~= newStatus then
                                    self.status = newStatus
                                end
                            end
                            
                            if honey then
                                self.playerHoney = honey.Value
                            end
                        end
                    end
                    
                    self.uptime = AliveCheck:GetUptime()
                end)
                
                if not success then
                    warn("Status updater error (non-fatal)")
                end
            end
            
            task.wait(1)
        end
        
        AliveCheck:Stop()
        self.statusUpdaterThread = nil
    end)
end

function UI:StartCoconutESP()
    print("=== STARTING COCONUT ESP ===")

    if coconutESPThread then
        task.cancel(coconutESPThread)
        coconutESPThread = nil
    end

    for _, espData in pairs(coconutESP) do
        pcall(function()
            if espData.rect then espData.rect:Remove() end
            if espData.text then espData.text:Remove() end
        end)
    end
    coconutESP = {}

    if not coconutESPEnabled then
        print("Coconut ESP disabled, returning")
        return
    end

    coconutESPThread = task.spawn(function()
        print("âœ“ Coconut ESP thread started")
        while coconutESPEnabled do
            local P = game.Workspace:FindFirstChild("Particles")
            local character = game.Players.LocalPlayer.Character
            local hrp = character and character:FindFirstChild("HumanoidRootPart")

            -- Remove ESP for despawned disks
            for key, espData in pairs(coconutESP) do
                if not espData.disk or not espData.disk.Parent then
                    pcall(function()
                        if espData.rect then espData.rect:Remove() end
                        if espData.text then espData.text:Remove() end
                    end)
                    coconutESP[key] = nil
                end
            end

            -- Add ESP for new disks
            if P then
                for _, c in pairs(P:GetChildren()) do
                    if c.Name == "WarningDisk" and c.Parent and c.Size.X >= 20 then
                        local key = tostring(c)
                        if not coconutESP[key] then  -- NEW DISK!
                            local rect = Drawing.new("Square")
                            rect.Filled = false
                            rect.Color = Color3.fromRGB(255, 150, 0)
                            rect.Size = Vector2.new(60, 30)
                            rect.Thickness = 2
                            rect.Visible = false
                            rect.Transparency = 1

                            local text = Drawing.new("Text")
                            text.Color = Color3.fromRGB(255, 150, 0)
                            text.Size = 14
                            text.Center = true
                            text.Outline = true
                            text.Visible = false
                            text.Transparency = 1

                            coconutESP[key] = {disk = c, rect = rect, text = text}
                            print("[ESP] Added ESP for new coconut")
                        end
                    end
                end
            end

            -- Update positions
            for key, espData in pairs(coconutESP) do
                if espData.disk and espData.disk.Parent then
                    local pos, onScreen = WorldToScreen(espData.disk.Position)
                    if pos and onScreen then
                        espData.rect.Position = Vector2.new(pos.X - 30, pos.Y - 15)
                        espData.rect.Visible = true
                        local dist = 0
                        if hrp and espData.disk and espData.disk.Parent then
                            local dx = hrp.Position.X - espData.disk.Position.X
                            local dy = hrp.Position.Y - espData.disk.Position.Y
                            local dz = hrp.Position.Z - espData.disk.Position.Z
                            dist = math.floor(Vector3.new(dx, dy, dz).Magnitude)
                        end
                        espData.text.Text = "COCONUT\n" .. dist .. "s"
                        espData.text.Position = Vector2.new(pos.X, pos.Y - 25)
                        espData.text.Visible = true
                    else
                        espData.rect.Visible = false
                        espData.text.Visible = false
                    end
                end
            end

            task.wait(0.03)
        end
        print("Coconut ESP loop ended")
    end)
end

