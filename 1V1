function UI:BuildAIUIContext()
    local function compactString(value, maxLength)
        local text = tostring(value or "")
        maxLength = tonumber(maxLength) or 160
        if #text > maxLength then
            return text:sub(1, maxLength - 3) .. "..."
        end
        return text
    end

    local function compactValue(value, depth)
        depth = tonumber(depth) or 0
        local valueType = type(value)

        if value == nil then
            return nil
        elseif valueType == "boolean" or valueType == "number" then
            return value
        elseif valueType == "string" then
            return compactString(value, 180)
        elseif valueType == "function" or valueType == "thread" then
            return nil
        elseif depth >= 2 then
            return compactString(value, 120)
        elseif valueType == "table" then
            local out = {}
            local count = 0
            local isArray = #value > 0

            if isArray then
                for index, item in ipairs(value) do
                    if index > 40 then
                        table.insert(out, "...")
                        break
                    end
                    out[index] = compactValue(item, depth + 1)
                end
            else
                for key, item in pairs(value) do
                    count = count + 1
                    if count > 40 then
                        out._truncated = true
                        break
                    end

                    local compacted = compactValue(item, depth + 1)
                    if compacted ~= nil then
                        out[compactString(key, 80)] = compacted
                    end
                end
            end

            return out
        end

        local okVector, x, y, z = pcall(function()
            return value.X, value.Y, value.Z
        end)
        if okVector and x ~= nil and y ~= nil and z ~= nil then
            return {
                x = math.floor((tonumber(x) or 0) * 100) / 100,
                y = math.floor((tonumber(y) or 0) * 100) / 100,
                z = math.floor((tonumber(z) or 0) * 100) / 100,
            }
        end

        local okColor, r, g, b = pcall(function()
            return value.R, value.G, value.B
        end)
        if okColor and r ~= nil and g ~= nil and b ~= nil then
            return {
                r = math.floor((tonumber(r) or 0) * 255),
                g = math.floor((tonumber(g) or 0) * 255),
                b = math.floor((tonumber(b) or 0) * 255),
            }
        end

        return compactString(value, 120)
    end

    local function getTabName(tabIndex)
        local tab = self.tabs and self.tabs[tabIndex]
        return compactString(tab and (tab.name or tab.Name or tab.label or tab.Label) or ("Tab " .. tostring(tabIndex)), 80)
    end

    local function getOptions(control)
        local rawOptions = control and (control.options or control.Values or control.values)
        if type(rawOptions) == "function" then
            local ok, resolved = pcall(rawOptions, self)
            rawOptions = ok and resolved or {}
        end

        if type(rawOptions) ~= "table" then
            return nil, 0
        end

        local options = {}
        local count = 0
        for _, option in ipairs(rawOptions) do
            count = count + 1
            if #options < 60 then
                table.insert(options, compactString(self:FormatDropdownListValue(control, option), 100))
            end
        end

        return options, count
    end

    local tabs = {}
    for tabIndex, tab in ipairs(self.tabs or {}) do
        tabs[tabIndex] = compactString(tab.name or tab.Name or tab.label or tab.Label or ("Tab " .. tostring(tabIndex)), 80)
    end

    local controls = {}
    for tabIndex, tabControls in ipairs(self.controls or {}) do
        local tabName = getTabName(tabIndex)
        for _, control in ipairs(tabControls or {}) do
            if self:IsControlVisible(control) then
                local controlType = self:GetControlType(control)
                local groupName = control.group or control.groupbox or control.Group or control.Groupbox or tabName
                local side = control.side or control.column or control.Side or control.Column or 1
                if side == "right" or side == "Right" or side == 2 then
                    side = 2
                else
                    side = 1
                end

                local value = self:GetControlRawValue(control, nil)
                if controlType == "dropdown_multi" then
                    value = control.selected or control.Selected or value or {}
                end

                local item = {
                    tabIndex = tabIndex,
                    tabName = tabName,
                    tab = tabName,
                    group = compactString(groupName, 90),
                    side = side,
                    id = compactString(self:GetControlId(control), 100),
                    label = compactString(self:GetControlLabel(control), 120),
                    type = compactString(controlType, 40),
                    value = compactValue(value, 0),
                }

                if self:IsControlDisabled(control) then
                    item.disabled = true
                end

                if control.bssKey then
                    item.bssKey = compactString(control.bssKey, 100)
                end

                if controlType == "dropdown_single" or controlType == "dropdown_multi" then
                    local options, optionCount = getOptions(control)
                    item.options = options or {}
                    item.optionCount = optionCount or 0
                end

                table.insert(controls, item)
            end
        end
    end

    local activeGatherOptions = {}
    for _, key in ipairs({
        "collectTokens",
        "useSprinkler",
        "farmPuppyBall",
        "autoGrindBlooms",
        "farmUnderBalloons",
        "farmUnderClouds",
        "farmFlames",
        "farmBubbles",
        "convertBalloon",
        "farmTargetPractice",
        "farmSprouts",
        "farmFaceBalloons",
        "catchCoconuts",
        "catchStars",
    }) do
        if self[key] == true then
            table.insert(activeGatherOptions, key)
        end
    end

    local combatToggles = {}
    for _, key in ipairs({
        "killCoconutCrab",
        "trainSnail",
        "killKingBeetle",
        "killViciousBee",
        "killCommandoChick",
        "killWindy",
        "killTunnelBear",
        "killMondo",
        "lootMondo",
        "timeToKillEnabled",
    }) do
        combatToggles[key] = self[key] == true
    end

    local selectedTab = tonumber(self.selectedTab) or 1
    return {
        title = compactString(self.title or "ObsidianPort", 80),
        selectedTab = selectedTab,
        selectedTabName = getTabName(selectedTab),
        tabs = tabs,
        controls = controls,
        runtime = {
            status = compactString(self.status or "Ready", 120),
            selectedField = compactString(self.selectedOption or self.selectedField or "", 120),
            selectedCombatTarget = compactString(self.selectedCombatTarget or "", 120),
            autoFarmEnabled = self.autoFarmEnabled == true,
            autoFarmRunning = self.autoFarmRunning == true,
            activeGatherOptions = activeGatherOptions,
            combatToggles = combatToggles,
            processingTween = self.processingTween == true,
            tweenMethod = compactString(self.tweenMethod or "", 60),
            tweenSpeed = tonumber(self.tweenSpeed) or 0,
            tweenQueueLength = #(self.tweenQueue or {}),
            currentTweenTarget = compactValue(self.currentTweenTarget, 0),
            aiTabIndex = self.aiTabIndex,
            matchaMindTabIndex = self.aiTabIndex,
            settingsTabIndex = self.settingsTabIndex,
        },
    }
end

