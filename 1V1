end

function UI:HasActiveInteraction()
    return self.draggingResize == true
        or self.draggingWindow == true
        or self.draggingSlider == true
        or self.draggingScroll == true
        or self.draggingAIChatScroll == true
        or self.searchFocused == true
        or self.activeTextInput ~= nil
        or self.activeDropdownSearch ~= nil
        or self.activeKeybind ~= nil
        or self.expandedDropdown ~= nil
        or self.expandedColorPicker ~= nil
end

function UI:PollFrameInputChanged()
    local mousePos = self:GetMouseLocation()
    local mouseDown = self:IsMousePressed()
    local mouseX = math.floor((mousePos.X or 0) + 0.5)
    local mouseY = math.floor((mousePos.Y or 0) + 0.5)
    local changed = self.lastFrameMouseX ~= mouseX
        or self.lastFrameMouseY ~= mouseY
        or self.lastFrameMouseDown ~= mouseDown

    self.lastFrameMouseX = mouseX
    self.lastFrameMouseY = mouseY
    self.lastFrameMouseDown = mouseDown

    return changed, mousePos, mouseDown
end

function UI:GetActiveControls()
    local tabControls = self.controls[self.selectedTab] or {}

    if not self.searching then
        return tabControls
    end

    local filtered = {}

    for _, control in ipairs(tabControls) do
        if self:ControlMatchesSearch(control) then
            table.insert(filtered, control)
        end
    end

    return filtered
end

