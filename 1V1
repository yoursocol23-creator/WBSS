function UI:SafeTweenPosition(part, targetPosition, speed, isCancelled)
    if not part or typeof(targetPosition) ~= "Vector3" then
        return false
    end

    local startPosition = part.Position
    local distance = (targetPosition - startPosition).Magnitude
    if distance < 1 then
        part.Position = targetPosition
        return true
    end

    local duration = math.max(distance / math.max(speed or self:GetTweenSpeed(), 0.01), 0.1)
    local tweenStart = os.clock()
    local stepInterval = 0.03
    local lastVelocityHold = 0
    local velocityHoldInterval = 0.05

    while true do
        if type(isCancelled) == "function" then
            local ok, cancelled = pcall(isCancelled)
            if ok and cancelled then
                return false
            end
        end

        local elapsed = os.clock() - tweenStart
        local alpha = math.clamp(elapsed / duration, 0, 1)
        local newPosition = startPosition:Lerp(targetPosition, alpha)

        if elapsed - lastVelocityHold >= velocityHoldInterval then
            lastVelocityHold = elapsed
            self:ZeroPartPhysics(part)
        end
        part.Position = newPosition

        if alpha >= 1 then
            self:ZeroPartPhysics(part)
            part.Position = targetPosition
            return true
        end

        task.wait(stepInterval)
    end
end

function UI:SafeTweenStage(parts, speed, isCancelled)
    if type(parts) ~= "table" or #parts <= 0 then
        return false
    end

    local entries = {}
    local maxDistance = 0

    for _, entry in ipairs(parts) do
        if entry and entry.part and typeof(entry.target) == "Vector3" then
            local startPosition = entry.part.Position
            local distance = (entry.target - startPosition).Magnitude
            entries[#entries + 1] = {
                part = entry.part,
                start = startPosition,
                target = entry.target,
            }
            if distance > maxDistance then
                maxDistance = distance
            end
        end
    end

    if #entries <= 0 then
        return false
    end

    local duration = math.max(maxDistance / math.max(speed or self:GetTweenSpeed(), 0.01), 0.1)
    local tweenStart = os.clock()
    local stepInterval = 0.03
    local lastVelocityHold = 0
    local velocityHoldInterval = 0.05

    while true do
        if type(isCancelled) == "function" then
            local ok, cancelled = pcall(isCancelled)
            if ok and cancelled then
                return false
            end
        end

        local elapsed = os.clock() - tweenStart
        local alpha = math.clamp(elapsed / duration, 0, 1)

        local shouldZeroPhysics = (elapsed - lastVelocityHold) >= velocityHoldInterval
        if shouldZeroPhysics then
            lastVelocityHold = elapsed
        end

        for _, entry in ipairs(entries) do
            if entry.part and entry.part.Parent then
                if shouldZeroPhysics then
                    self:ZeroPartPhysics(entry.part)
                end
                entry.part.Position = entry.start:Lerp(entry.target, alpha)
            end
        end

        if alpha >= 1 then
            for _, entry in ipairs(entries) do
                if entry.part and entry.part.Parent then
                    self:ZeroPartPhysics(entry.part)
                    entry.part.Position = entry.target
                end
            end
            return true
        end

        task.wait(stepInterval)
    end
end

function UI:GetContentBounds()
    local renderX, renderY = self:GetRenderWindowPosition()

    local headerH = 48
    local gap = 12

    local x = renderX + self.window.sidebarWidth + 14
    local y = renderY + headerH + gap + self:GetAnimatedWindowYOffset()

    local width = self.window.width - self.window.sidebarWidth - 28
    local height = self.window.height - headerH - gap - 18

    return x, y, width, height
end

function UI:GetScrollbarMetrics()
    local x, y, width, height = self:GetContentBounds()
    local scrollbarX = x + width - 10
    local scrollbarY = y + 8
    local scrollbarW = 4
    local scrollbarH = height - 16
    local thumbH = 0
    local thumbY = scrollbarY

    if self.scroll.max > 0 then
        thumbH = math.max(34, math.floor(scrollbarH * (height / (height + self.scroll.max))))
        local available = math.max(1, scrollbarH - thumbH)
        thumbY = scrollbarY + math.floor((self.scroll.offset / self.scroll.max) * available)
    end

    return scrollbarX, scrollbarY, scrollbarW, scrollbarH, thumbY, thumbH
end

function UI:GetScrollbarGutter()
    return 22
end

function UI:UpdateScrollLimit()
    local previousMax = self.scroll.max
    local previousOffset = self.scroll.offset
    local _, _, width, viewportHeight = self:GetContentBounds()
    local usableWidth = math.max(1, width - self:GetScrollbarGutter())
    local gap = 6
    local columnW = math.max(1, math.floor((usableWidth - gap - 4) * 0.5))
    local innerW = math.max(1, columnW - 14)
    local columns = self:BuildObsidianGroups()
    local contentHeight = 0

    for side = 1, 2 do
        local columnHeight = 4
        for _, group in ipairs(columns[side]) do
            columnHeight = columnHeight + self:GetGroupHeight(group, innerW) + 6
        end
        if columnHeight > contentHeight then
            contentHeight = columnHeight
        end
    end

    self.scroll.max = math.max(0, contentHeight - viewportHeight + 12)
    self.scroll.offset = math.clamp(self.scroll.offset, 0, self.scroll.max)
    return previousMax ~= self.scroll.max or previousOffset ~= self.scroll.offset
end

