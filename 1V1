function UI:CheckKingBeetle()
    local monsters = game.Workspace:FindFirstChild("Monsters")
    if not monsters then return false end
    
    local kingBeetle = monsters:FindFirstChild("King Beetle (Lvl 7)")
    return kingBeetle ~= nil
end

function UI:KillKingBeetle()
    print("=== KING BEETLE AUTO-FARM ===")
    
    local player = game.Players.LocalPlayer
    local character = player.Character
    
    if not character then
        print("ERROR: No character for King Beetle")
        return false
    end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        print("ERROR: No HRP for King Beetle")
        return false
    end
    
    local previousStatus = self.status
    
    self.pausedForTimedAction = true
    StopWalking()
    self:ClearTweenQueue()
    task.wait(0.5)
    
    self.status = "Checking King Beetle"
    self.needsRedraw = true
    
    local checkPos = Vector3.new(218, 4, 140)
    
    self:QueueTween(hrp, checkPos, true)
    
    local maxWaitTime = 60
    local startWait = os.clock()
    
    self:WaitForTween(60, function() return self.autoFarmEnabled end)
    
    print("Arrived at check location, checking for King Beetle...")
    task.wait(1)
    
    if not self:CheckKingBeetle() then
        print("King Beetle not spawned, returning to farming")
        self.lastKingBeetleTime = os.clock()
        if self.autoFarmEnabled and self.selectedOption and self.selectedOption ~= "Select Field..." then
            print("Returning to " .. self.selectedOption)
            self.status = "Returning to " .. self.selectedOption
            self.needsRedraw = true
            
            local flowerZones = GetFlowerZonesFolder()
            if flowerZones then
                local targetZone = GetFlowerZone(self.selectedOption)
                if targetZone then
                    character = player.Character
                    if character then
                        hrp = character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local fieldPos = Vector3.new(targetZone.Position.X, targetZone.Position.Y + 10, targetZone.Position.Z)
                            self:QueueTween(hrp, fieldPos, true)
                            
                            local startWait = os.clock()
                            self:WaitForTween(60, function() return self.autoFarmEnabled end)
                            
                            print("Returned to field")
                        end
                    end
                end
            end
        end
        
        self.pausedForTimedAction = false
        self.status = previousStatus
        self.needsRedraw = true
        return false
    end
    
    print("King Beetle spawned! Starting fight sequence...")
    self.status = "Fighting King Beetle"
    self.needsRedraw = true
    
    local waypoint1 = Vector3.new(108, 4, 169)
    print("Walking to waypoint 1...")
    self:QueueTween(hrp, waypoint1, true)
    
    startWait = os.clock()
    self:WaitForTween(60, function() return self.autoFarmEnabled end)
    
    task.wait(0.5)
    
    local waypoint2 = Vector3.new(109, 4, 253)
    print("Walking to waypoint 2...")
    self:QueueTween(hrp, waypoint2, true)
    
    startWait = os.clock()
    self:WaitForTween(60, function() return self.autoFarmEnabled end)
    
    print("Waiting at waypoint 2, checking for King Beetle...")
    task.wait(1)
    
    local checkStartTime = os.clock()
    while self.autoFarmEnabled and self:CheckKingBeetle() do
        if os.clock() - checkStartTime > 300 then
            print("King Beetle timeout (5 minutes)")
            break
        end
        task.wait(0.5)
    end
    
    if self.autoFarmEnabled then
        print("King Beetle defeated!")
        
        local collectPos = Vector3.new(182, 4, 180)
        print("Walking to collection point...")
        self:QueueTween(hrp, collectPos, true)
        
        startWait = os.clock()
        self:WaitForTween(60, function() return self.autoFarmEnabled end)
        task.wait(0.5)
        
        print("Collecting tokens for 15 seconds...")
        self.status = "Collecting King Beetle Tokens"
        self.needsRedraw = true
        
        local collectStartTime = os.clock()
        local recentTokens = {}
        
        while self.autoFarmEnabled and (os.clock() - collectStartTime) < 15 do
            local collectibles = game.Workspace:FindFirstChild("Collectibles")
            if collectibles then
                character = player.Character
                if character then
                    hrp = character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local hrpPos = hrp.Position
                        local closestToken = nil
                        local closestDistance = math.huge
                        
                        for _, token in pairs(collectibles:GetChildren()) do
                            if token.Name == "C" and token:IsA("BasePart") and token.Parent then
                                if token.Transparency >= 0.2 then
                                    continue
                                end
                                local tokenPos = token.Position
                                if tokenPos then
                                    local isRecent = false
                                    for _, recentPos in ipairs(recentTokens) do
                                        local tdx = math.abs(tokenPos.X - recentPos.X)
                                        local tdy = math.abs(tokenPos.Y - recentPos.Y)
                                        local tdz = math.abs(tokenPos.Z - recentPos.Z)
                                        if tdx < 3 and tdy < 3 and tdz < 3 then
                                            isRecent = true
                                            break
                                        end
                                    end
                                    
                                    if not isRecent then
                                        local tdy = math.abs(hrpPos.Y - tokenPos.Y)
                                        if tdy <= 10 then
                                            local tdx = hrpPos.X - tokenPos.X
                                            local tdz = hrpPos.Z - tokenPos.Z
                                            local distSquared = tdx * tdx + tdz * tdz
                                            
                                            if distSquared < 2500 and distSquared < closestDistance then
                                                closestDistance = distSquared
                                                closestToken = tokenPos
                                            end
                                        end
                                    end
                                end
                            end
                        end
                        
                        if closestToken then
                            WalkTo(closestToken)
                            
                            local startTime = os.clock()
                            while IsWalking() and self.autoFarmEnabled do
                                if os.clock() - startTime > 3 then
                                    StopWalking()
                                    break
                                end
                                
                                hrp = character:FindFirstChild("HumanoidRootPart")
                                if hrp then
                                    local currentPos = hrp.Position
                                    local cdx = currentPos.X - closestToken.X
                                    local cdz = currentPos.Z - closestToken.Z
                                    local distSquared = cdx * cdx + cdz * cdz
                                    
                                    if distSquared < 25 then
                                        StopWalking()
                                        break
                                    end
                                end
                                
                                task.wait(0.05)
                            end
                            
                            StopWalking()
                            
                            table.insert(recentTokens, closestToken)
                            if #recentTokens > 10 then
                                table.remove(recentTokens, 1)
                            end
                        else
                            if #recentTokens > 0 then
                                recentTokens = {}
                            end
                        end
                    end
                end
            end
            
            task.wait(0.05)
        end
        
        StopWalking()
        print("Token collection complete!")
        print("Next King Beetle in 24 hours")
    end
    
    if self.autoFarmEnabled and self.selectedOption and self.selectedOption ~= "Select Field..." then
        print("Returning to " .. self.selectedOption)
        self.status = "Returning to " .. self.selectedOption
        self.needsRedraw = true
        
        local flowerZones = GetFlowerZonesFolder()
        if flowerZones then
            local targetZone = GetFlowerZone(self.selectedOption)
            if targetZone then
                character = player.Character
                if character then
                    hrp = character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local fieldPos = Vector3.new(targetZone.Position.X, targetZone.Position.Y + 10, targetZone.Position.Z)
                        self:QueueTween(hrp, fieldPos, true)
                        
                        local startWait = os.clock()
                        self:WaitForTween(60, function() return self.autoFarmEnabled end)
                        
                        print("Returned to field")
                    end
                end
            end
        end
    end
    
    self.pausedForTimedAction = false
    self.status = previousStatus
    self.needsRedraw = true
    self:SaveCooldowns()
    return true
end

function UI:FightCommandoChick()
    local player = game.Players.LocalPlayer
    local character = player.Character
    
    if not character then
        return false
    end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        return false
    end
    
    local previousStatus = self.status
    local previousField = self.selectedOption
    
    self.pausedForTimedAction = true
    StopWalking()
    self:ClearTweenQueue()
    task.wait(0.5)
    
    self.status = "Going to Commando Chick"
    self.needsRedraw = true
    
    local commandoPos = self.commandoChickConfig.spawnPoint
    
    self:QueueTween(hrp, commandoPos, true)
    
    local maxWaitTime = 60
    local startWait = os.clock()
    
    self:WaitForTween(60, function() return self.autoFarmEnabled end)
    
    task.wait(3)
    
    if not self:CheckForCommandoChick() then
        if self.autoFarmEnabled and previousField and previousField ~= "Select Field..." then
            self.status = "Returning to " .. self.selectedOption
            self.needsRedraw = true
            
            local flowerZones = GetFlowerZonesFolder()
            if flowerZones then
                local targetZone = GetFlowerZone(previousField)
                if targetZone then
                    character = player.Character
                    if character then
                        hrp = character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local fieldPos = Vector3.new(targetZone.Position.X, targetZone.Position.Y + 10, targetZone.Position.Z)
                            self:QueueTween(hrp, fieldPos, true)
                            
                            local startWait = os.clock()
                            self:WaitForTween(60, function() return self.autoFarmEnabled end)
                        end
                    end
                end
            end
        end
        
        self.pausedForTimedAction = false
        self.status = previousStatus
        self.needsRedraw = true
        
        return false
    end
    
    self.status = "Fighting Commando Chick"
    self.needsRedraw = true
    
    while self.autoFarmEnabled and self.killCommandoChick and self:CheckForCommandoChick() do
        character = player.Character
        if not character then break end
        
        hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then break end
        
        local hrpPos = hrp.Position
        
        local chickenData = self:GetCommandoChickPosition()
        
        if not chickenData then
            task.wait(0.3)
            continue
        end
        
        local currentDistance = chickenData.distance
        local chickenPos = chickenData.position
        local chickenVel = chickenData.velocity
        
        local predictedPos = Vector3.new(
            chickenPos.X + (chickenVel.X * self.commandoChickConfig.predictionTime),
            chickenPos.Y,
            chickenPos.Z + (chickenVel.Z * self.commandoChickConfig.predictionTime)
        )
        
        local pdx = hrpPos.X - predictedPos.X
        local pdz = hrpPos.Z - predictedPos.Z
        local predictedDistance = Vector3.new(pdx, 0, pdz).Magnitude
        
        local currentDanger = math.max(0, self.commandoChickConfig.minDistance - currentDistance)
        local predictedDanger = math.max(0, self.commandoChickConfig.minDistance - predictedDistance)
        local totalDanger = currentDanger + predictedDanger * 2
        
        local targetPos = nil
        local action = ""
        
        if totalDanger > 0 then
            action = "ðŸš¨ESCAPE"
            
            local escapeX = hrpPos.X + (hrpPos.X - predictedPos.X) * 3
            local escapeZ = hrpPos.Z + (hrpPos.Z - predictedPos.Z) * 3
            
            escapeX = escapeX + (hrpPos.X - chickenPos.X) * 1.5
            escapeZ = escapeZ + (hrpPos.Z - chickenPos.Z) * 1.5
            
            targetPos = Vector3.new(escapeX, 47, escapeZ)
            
        elseif currentDistance < self.commandoChickConfig.idealDistance or 
               predictedDistance < self.commandoChickConfig.idealDistance then
            
            action = "RETREAT"
            
            local awayX = hrpPos.X + (hrpPos.X - predictedPos.X) * 1.5
            local awayZ = hrpPos.Z + (hrpPos.Z - predictedPos.Z) * 1.5
            targetPos = Vector3.new(awayX, 47, awayZ)
            
        elseif currentDistance > self.commandoChickConfig.maxDistance and
               predictedDistance > self.commandoChickConfig.maxDistance then
            
            action = "APPROACH"
            
            local towardsX = hrpPos.X + (predictedPos.X - hrpPos.X) * 0.4
            local towardsZ = hrpPos.Z + (predictedPos.Z - hrpPos.Z) * 0.4
            targetPos = Vector3.new(towardsX, 47, towardsZ)
            
        else
            action = "STRAFE"
            
            local toPredictedX = predictedPos.X - hrpPos.X
            local toPredictedZ = predictedPos.Z - hrpPos.Z
            
            local perpX = -toPredictedZ
            local perpZ = toPredictedX
            
            local perpLen = Vector3.new(perpX, 0, perpZ).Magnitude
            if perpLen > 0.1 then
                perpX = perpX / perpLen * 25
                perpZ = perpZ / perpLen * 25
            else
                local angle = math.atan2(hrpPos.Z - chickenPos.Z, hrpPos.X - chickenPos.X) + math.rad(45)
                perpX = math.cos(angle) * 30 - (chickenPos.X - hrpPos.X)
                perpZ = math.sin(angle) * 30 - (chickenPos.Z - hrpPos.Z)
            end
            
            targetPos = Vector3.new(hrpPos.X + perpX, 47, hrpPos.Z + perpZ)
        end
        
        targetPos = self:ClampPositionToBoundary(targetPos)
        
        if action ~= "ðŸš¨ESCAPE" and action ~= "RETREAT" then
            local collectibles = game.Workspace:FindFirstChild("Collectibles")
            if collectibles then
                for _, token in pairs(collectibles:GetChildren()) do
                    if token.Name == "C" and token:IsA("BasePart") and token.Parent then
                        if token.Transparency < 0.2 then
                            local tokenPos = token.Position
                            
                            local tdx = tokenPos.X - targetPos.X
                            local tdz = tokenPos.Z - targetPos.Z
                            local tokenDistToPath = Vector3.new(tdx, 0, tdz).Magnitude
                            
                            if tokenDistToPath < 12 then
                                local dxFromChicken = tokenPos.X - predictedPos.X
                                local dzFromChicken = tokenPos.Z - predictedPos.Z
                                local tokenDistFromChicken = Vector3.new(dxFromChicken, 0, dzFromChicken).Magnitude
                                
                                if tokenDistFromChicken > 20 then
                                    targetPos = Vector3.new(
                                        targetPos.X + (tokenPos.X - targetPos.X) * 0.6,
                                        47,
                                        targetPos.Z + (tokenPos.Z - targetPos.Z) * 0.6
                                    )
                                    action = action .. "+TOKEN"
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
        
        self.status = action
        self.needsRedraw = true
        
        WalkTo(targetPos)
        
        local moveStart = os.clock()
        while IsWalking() and os.clock() - moveStart < self.commandoChickConfig.moveInterval do
            task.wait(0.05)
        end
        
        StopWalking()
        task.wait(0.05)
    end
     
    if self.autoFarmEnabled and previousField and previousField ~= "Select Field..." then
        self.status = "Returning to " .. self.selectedOption
        self.needsRedraw = true
        
        local flowerZones = GetFlowerZonesFolder()
        if flowerZones then
            local targetZone = GetFlowerZone(previousField)
            if targetZone then
                character = player.Character
                if character then
                    hrp = character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local fieldPos = Vector3.new(targetZone.Position.X, targetZone.Position.Y + 10, targetZone.Position.Z)
                        self:QueueTween(hrp, fieldPos, true)
                        
                        local startWait = os.clock()
                        self:WaitForTween(60, function() return self.autoFarmEnabled end)
                    end
                end
            end
        end
    end
    
    self.pausedForTimedAction = false
    self.status = previousStatus
    self.needsRedraw = true
    self:SaveCooldowns()
    return true
end


function UI:StartPathNodeESP()
    print("=== STARTING PATH NODE ESP ===")
    
    if espUpdateThread then
        task.cancel(espUpdateThread)
        espUpdateThread = nil
    end
    
    -- Clear old ESP
    for _, espData in pairs(pathNodeESP) do
        pcall(function()
            if espData.rect then espData.rect:Remove() end
            if espData.text then espData.text:Remove() end
            if espData.line then
                for _, line in pairs(espData.line) do
                    line:Remove()
                end
            end
        end)
    end
    pathNodeESP = {}
    
    if not pathNodeESPEnabled then
        print("ESP disabled, returning")
        return
    end
    
    -- Create ESP for each path node
    local nodeCount = 0
    for nodeName, nodePos in pairs(self.pathNodes) do
        nodeCount = nodeCount + 1
        
        local rect = Drawing.new("Square")
        rect.Filled = false
        rect.Color = Color3.fromRGB(0, 255, 100)
        rect.Size = Vector2.new(60, 30)
        rect.Thickness = 2
        rect.Visible = true
        rect.Transparency = 1
        
        local text = Drawing.new("Text")
        text.Color = Color3.fromRGB(0, 255, 100)
        text.Size = 14
        text.Center = true
        text.Outline = true
        text.Visible = true
        text.Transparency = 1
        
        pathNodeESP[nodeName] = {
            position = nodePos,
            rect = rect,
            text = text,
            connections = self.pathConnections[nodeName] or {},
            line = {}
        }
    end
    
    print("âœ“ Created ESP for " .. nodeCount .. " nodes")
    
    -- ESP update loop
    espUpdateThread = task.spawn(function()
        print("âœ“ ESP update thread started")
        local loopCount = 0
        
        while pathNodeESPEnabled do
            loopCount = loopCount + 1
            
            if loopCount % 60 == 0 then
                print("ESP loop running... (" .. loopCount .. " frames)")
            end
            
            local player = game.Players.LocalPlayer
            local character = player.Character
            
            if character then
                local hrp = character:FindFirstChild("HumanoidRootPart")
                
                for nodeName, espData in pairs(pathNodeESP) do
                    local nodePos = espData.position
                    local pos, onScreen = WorldToScreen(nodePos)
                    
                    if pos and onScreen then
                        -- Rectangle
                        espData.rect.Position = Vector2.new(pos.X - 30, pos.Y - 15)
                        espData.rect.Visible = true
                        
                        -- Distance text
                        if hrp then
                            local dx = hrp.Position.X - nodePos.X
                            local dy = hrp.Position.Y - nodePos.Y
                            local dz = hrp.Position.Z - nodePos.Z
                            local distance = Vector3.new(dx, dy, dz).Magnitude
                            
                            espData.text.Text = nodeName .. "\n" .. math.floor(distance) .. "s"
                        else
                            espData.text.Text = nodeName
                        end
                        
                        espData.text.Position = Vector2.new(pos.X, pos.Y - 25)
                        espData.text.Visible = true
                    else
                        espData.rect.Visible = false
                        espData.text.Visible = false
                    end
                end
                
                 -- Draw connection lines
                for nodeName, espData in pairs(pathNodeESP) do
                    if espData.connections then
                        for _, connectedNodeName in ipairs(espData.connections) do
                            local connectedESP = pathNodeESP[connectedNodeName]
                            if connectedESP then
                                local pos1, onScreen1 = WorldToScreen(espData.position)
                                local pos2, onScreen2 = WorldToScreen(connectedESP.position)
                                
                                local lineKey = nodeName .. "->" .. connectedNodeName
                                
                                -- Only show line if BOTH endpoints are on screen
                                if pos1 and pos2 and onScreen1 and onScreen2 then
                                    if not espData.line[lineKey] then
                                        local line = Drawing.new("Line")
                                        line.Color = Color3.fromRGB(255, 200, 0)
                                        line.Thickness = 1
                                        line.Transparency = 0.5
                                        espData.line[lineKey] = line
                                    end
                                    
                                    local line = espData.line[lineKey]
                                    line.From = Vector2.new(pos1.X, pos1.Y)
                                    line.To = Vector2.new(pos2.X, pos2.Y)
                                    line.Visible = true
                                else
                                    -- Hide line if either endpoint is off-screen
                                    if espData.line[lineKey] then
                                        espData.line[lineKey].Visible = false
                                    end
                                end
                            end
                        end
                    end
                end
            end
            
            task.wait(0.03)
        end
        
        print("ESP loop ended")
    end)
end

function UI:StopPathNodeESP()
    print("=== STOPPING PATH NODE ESP ===")
    pathNodeESPEnabled = false
    
    if espUpdateThread then
        task.cancel(espUpdateThread)
        espUpdateThread = nil
    end
    
    for _, espData in pairs(pathNodeESP) do
        pcall(function()
            if espData.rect then espData.rect:Remove() end
            if espData.text then espData.text:Remove() end
            if espData.line then
                for _, line in pairs(espData.line) do
                    line:Remove()
                end
            end
        end)
    end
    pathNodeESP = {}
    print("âœ“ ESP cleared")
end

function UI:SaveCooldowns()
    local cooldowns = {}
    local currentClock = os.clock()
    local currentTime = os.time()
    
    for key, config in pairs(self.dispenserConfig) do
        local timerKey = "last" .. key:gsub("^%l", string.upper) .. "Time"
        if self[timerKey] then
            local secondsAgo = currentClock - self[timerKey]
            cooldowns[timerKey] = currentTime - secondsAgo
        end
    end
    
    if self.lastTunnelBearTime then
        local secondsAgo = currentClock - self.lastTunnelBearTime
        cooldowns.lastTunnelBearTime = currentTime - secondsAgo
    end
    if self.lastKingBeetleTime then
        local secondsAgo = currentClock - self.lastKingBeetleTime
        cooldowns.lastKingBeetleTime = currentTime - secondsAgo
    end
    if self.lastCommandoChickTime then
        local secondsAgo = currentClock - self.lastCommandoChickTime
        cooldowns.lastCommandoChickTime = currentTime - secondsAgo
    end
    
    local HttpService = game:GetService("HttpService")
    if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end
    
    local success, err = pcall(function()
        writefile(CONFIG_FOLDER .. "/cooldowns.json", HttpService:JSONEncode(cooldowns))
    end)
    
    if success then print("Cooldowns saved") else warn("Save failed: " .. tostring(err)) end
end

function UI:LoadCooldowns()
    local cooldownPath = CONFIG_FOLDER .. "/cooldowns.json"
    if not isfile(cooldownPath) then return false end
    
    local HttpService = game:GetService("HttpService")
    local success, cooldowns = pcall(function()
        return HttpService:JSONDecode(readfile(cooldownPath))
    end)
    
    if not success or not cooldowns then return false end
    
    local currentClock = os.clock()
    local currentWallTime = os.time()
    local loadedCount = 0
    
    for key, wallTimeValue in pairs(cooldowns) do
        if type(wallTimeValue) == "number" then
            -- Convert wall time back to os.clock equivalent
            local secondsAgo = currentWallTime - wallTimeValue
            self[key] = currentClock - secondsAgo
            loadedCount = loadedCount + 1
        end
    end
    return true
end


