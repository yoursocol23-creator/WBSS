spawn(function()
    local lastHomeRedraw = 0
    while UI.isRunning do
        if UI.uiVisible then
            UI:HandleInput()
            local anyLerping = false
            for i = 1, #UI.tabs do
                local target = (i == UI.activeTab) and 1 or 0
                local current = UI.tabLerpProgress[i] or target
                if math.abs(current - target) > 0.5 then
                    anyLerping = true
                    break
                end
            end
            if UI.activeTab == 1 and os.clock() - lastHomeRedraw >= 0.3 then
                UI.needsRedraw = true
                lastHomeRedraw = os.clock()
            end
            if UI.needsRedraw or anyLerping then
                UI:Render()
            end
        end
        wait(0.03)
    end
    UI:Clear()
    print("Complete")
end)
