function UI:GetSliderDisplay(control)
    local rawValue = self:GetControlRawValue(control, 0)
    local value = tonumber(rawValue) or 0
    local formatter = control.formatDisplay or control.FormatDisplayValue

    if type(formatter) == "function" then
        -- Preferred modern style: function(value, control)
        local ok, formatted = pcall(formatter, value, control)
        if ok and formatted ~= nil then
            local shown = tostring(formatted)
            if shown:sub(1, 6) ~= "table:" then
                return shown
            end
        end

        -- Backward compatibility for old style: function(control, value)
        ok, formatted = pcall(formatter, control, value)
        if ok and formatted ~= nil then
            local shown = tostring(formatted)
            if shown:sub(1, 6) ~= "table:" then
                return shown
            end
        end
    end

    local prefix = tostring(control.prefix or control.Prefix or "")
    local suffix = tostring(control.suffix or control.Suffix or "")
    local maxValue = tonumber(control.max or control.Max or 0) or 0

    if control.compact or control.Compact then
        return string.format("%s: %s", self:GetControlLabel(control), tostring(value))
    end

    if control.hideMax or control.HideMax then
        return prefix .. tostring(value) .. suffix
    end

    return prefix .. tostring(value) .. suffix .. "/" .. prefix .. tostring(maxValue) .. suffix
end

