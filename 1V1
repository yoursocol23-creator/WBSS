function UI:FindAllTargetsInField()
    local player = game.Players.LocalPlayer
    local character = player.Character
    if not character then return {} end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return {} end
    
    local targets = {}
    local hrpPos = hrp.Position
    
    local flowerZones = GetFlowerZonesFolder()
    if not flowerZones or not self.selectedOption then return {} end
    
    local targetZone = GetFlowerZone(self.selectedOption)
    if not targetZone then return {} end
    
    local fieldPos = targetZone.Position
    local fieldSize = targetZone.Size
    
    if self.autoGrindBlooms then
        local happenings = game.Workspace:FindFirstChild("Happenings")
        if happenings then
            local poppablePlants = happenings:FindFirstChild("PoppablePlants")
            if poppablePlants then
                for _, child in pairs(poppablePlants:GetChildren()) do
                    if child:IsA("Model") and child.Name == "Bloom" then
                        local stem = child:FindFirstChild("Stem")
                        if stem and stem:IsA("BasePart") then
                            local stemPos = stem.Position
                            local dx = math.abs(stemPos.X - fieldPos.X)
                            local dz = math.abs(stemPos.Z - fieldPos.Z)
                            local dy = math.abs(stemPos.Y - fieldPos.Y)
                            
                            local withinX = dx <= fieldSize.X / 2
                            local withinZ = dz <= fieldSize.Z / 2
                            local withinY = dy <= 50
                            
                            if withinX and withinZ and withinY then
                                local distance = (hrpPos - stemPos).Magnitude
                                table.insert(targets, {
                                    type = "bloom",
                                    position = stemPos,
                                    object = stem,
                                    distance = distance
                                })
                            end
                        end
                    end
                end
            end
        end
    end
    
    if self.collectTokens then
        local collectibles = game.Workspace:FindFirstChild("Collectibles")
        if collectibles then
            for _, token in pairs(collectibles:GetChildren()) do
                if token.Name == "C" and token:IsA("BasePart") then
                    if token.Transparency >= 0.2 then
                        continue
                    end
                    local tokenPos = token.Position
                    local distance = (hrpPos - tokenPos).Magnitude
                    
                    table.insert(targets, {
                        type = "token",
                        position = tokenPos,
                        object = token,
                        distance = distance
                    })
                end
            end
        end
    end
    
    if self.farmUnderBalloons then
        local balloon = self:FindBalloonInField()
        if balloon then
            local balloonPos = balloon.Position
            local distance = (hrpPos - balloonPos).Magnitude
            
            table.insert(targets, {
                type = "balloon",
                position = balloonPos,
                object = balloon,
                distance = distance
            })
        end
    end
    
    if self.farmUnderClouds then
        local cloud = self:FindCloudInField()
        if cloud then
            local cloudPos = cloud.Position
            local distance = (hrpPos - cloudPos).Magnitude
            
            table.insert(targets, {
                type = "cloud",
                position = cloudPos,
                object = cloud,
                distance = distance
            })
        end
    end
    
    if self.farmBubbles then
        local bubbles = self:CheckForBubblesInField()
        if bubbles and #bubbles > 0 and #bubbles <= 1 then
            for _, bubble in ipairs(bubbles) do
                local bubblePos = bubble.Position
                local distance = (hrpPos - bubblePos).Magnitude
                
                table.insert(targets, {
                    type = "bubble",
                    position = bubblePos,
                    object = bubble,
                    distance = distance
                })
            end
        end
    end
    
    -- 6. FLAMES
    if self.farmFlames then
        local flames = self:CheckForFlamesInField()
        if flames and #flames > 0 then
            for _, flame in ipairs(flames) do
                local flamePos = flame.Position
                local distance = (hrpPos - flamePos).Magnitude
                
                table.insert(targets, {
                    type = "flame",
                    position = flamePos,
                    object = flame,
                    distance = distance
                })
            end
        end
    end
    
    table.sort(targets, function(a, b) return a.distance < b.distance end)
    
    return targets
end

function UI:CleanTargetPracticeHandledSpots()
    local spots = self.targetPracticeHandledSpots
    if type(spots) ~= "table" then
        spots = {}
        self.targetPracticeHandledSpots = spots
    end

    local now = os.clock()
    local ttl = tonumber(self.targetPracticeHandledTTL) or 5
    for i = #spots, 1, -1 do
        local spot = spots[i]
        if not spot or (now - (spot.time or 0)) > ttl then
            table.remove(spots, i)
        end
    end
end

function UI:AddTargetPracticeHandledSpot(pos)
    if not pos then
        return
    end

    self:CleanTargetPracticeHandledSpots()
    table.insert(self.targetPracticeHandledSpots, {
        x = pos.X,
        z = pos.Z,
        time = os.clock(),
    })
end

function UI:IsTargetPracticeHandledSpot(pos)
    if not pos then
        return false
    end

    self:CleanTargetPracticeHandledSpots()
    local radius = tonumber(self.targetPracticeHandledRadius) or 10

    for _, spot in ipairs(self.targetPracticeHandledSpots or {}) do
        local dx = pos.X - spot.x
        local dz = pos.Z - spot.z
        if Vector3.new(dx, 0, dz).Magnitude <= radius then
            return true
        end
    end

    return false
end

function UI:DebugTargetPractice(event, ...)
    if not self.targetPracticeDebug then
        return
    end

    local now = os.clock()
    local key = tostring(event or "log")
    local interval = 0.35
    if key == "scan" or key == "no_target" or key == "skip" then
        interval = 1.5
    elseif key == "candidates" then
        interval = 4
    end

    self.targetPracticeDebugTicks = self.targetPracticeDebugTicks or {}
    if now - (self.targetPracticeDebugTicks[key] or 0) < interval then
        return
    end
    self.targetPracticeDebugTicks[key] = now

    print("[TargetPractice]", key, ...)
end

function UI:GetTargetPracticePath(obj)
    if not obj then
        return "nil"
    end

    local path = tostring(obj.Name)
    local parent = obj.Parent
    local depth = 0

    while parent and parent ~= game and depth < 8 do
        path = tostring(parent.Name) .. "." .. path
        parent = parent.Parent
        depth = depth + 1
    end

    return "game." .. path
end

function UI:HasTargetPracticeBadAncestor(obj)
    local particles = game.Workspace:FindFirstChild("Particles")
    local parent = obj and obj.Parent

    while parent and parent ~= particles and parent ~= game do
        if parent.Name == "PetalShuriken" then
            return true
        end

        parent = parent.Parent
    end

    return false
end

function UI:IsTargetPracticeCrosshairPart(obj, particles)
    if not obj or not obj.Parent or not obj:IsA("BasePart") then
        return false, nil
    end

    local name = tostring(obj.Name or "")
    if name == "Crosshair" then
        return true, "name=Crosshair"
    end

    local lowerName = string.lower(name)
    if string.find(lowerName, "crosshair", 1, true) or string.find(lowerName, "target", 1, true) then
        return true, "name=" .. name
    end

    local parent = obj.Parent
    local depth = 0

    while parent and parent ~= particles and parent ~= game and depth < 5 do
        local parentName = tostring(parent.Name or "")
        local lowerParent = string.lower(parentName)

        if string.find(lowerParent, "crosshair", 1, true)
            or string.find(lowerParent, "target", 1, true)
            or string.find(lowerParent, "practice", 1, true) then
            return true, "ancestor=" .. parentName
        end

        parent = parent.Parent
        depth = depth + 1
    end

    return false, nil
end

function UI:GetTargetPracticeCrosshairs(hrp, source)
    local particles = game.Workspace:FindFirstChild("Particles")
    if not particles or not hrp then
        self:DebugTargetPractice("scan", "source=" .. tostring(source or "unknown"), "particles=" .. tostring(particles ~= nil), "hrp=" .. tostring(hrp ~= nil))
        return {}
    end

    self:CleanTargetPracticeHandledSpots()

    local hrpPos = hrp.Position
    local found = {}
    local petalFallback = {}
    local totalDesc = 0
    local totalCrosshair = 0
    local totalTargetLike = 0
    local basePartCount = 0
    local accepted = 0
    local rejectedPetal = 0
    local blacklisted = 0
    local sampleNames = {}
    local interestingSamples = {}

    for _, obj in pairs(particles:GetDescendants()) do
        totalDesc = totalDesc + 1
        if obj:IsA("BasePart") then
            basePartCount = basePartCount + 1

            if #sampleNames < 8 then
                table.insert(sampleNames, tostring(obj.Name))
            end

            local lowerName = string.lower(tostring(obj.Name or ""))
            if #interestingSamples < 8 and (
                string.find(lowerName, "cross", 1, true)
                or string.find(lowerName, "target", 1, true)
                or string.find(lowerName, "practice", 1, true)
                or string.find(lowerName, "aim", 1, true)
            ) then
                table.insert(interestingSamples, self:GetTargetPracticePath(obj))
            end
        end

        local isTargetPracticePart, targetReason = self:IsTargetPracticeCrosshairPart(obj, particles)
        if isTargetPracticePart then
            if obj.Name == "Crosshair" then
                totalCrosshair = totalCrosshair + 1
            end
            totalTargetLike = totalTargetLike + 1

            local hasBadAncestor = self:HasTargetPracticeBadAncestor(obj)
            if not hasBadAncestor then
                local pos = obj.Position
                if not self:IsTargetPracticeHandledSpot(pos) then
                    local dx = hrpPos.X - pos.X
                    local dz = hrpPos.Z - pos.Z
                    local distSquared = dx * dx + dz * dz
                    accepted = accepted + 1

                    table.insert(found, {
                        part = obj,
                        pos = pos,
                        distSquared = distSquared,
                        dist = Vector3.new(dx, 0, dz).Magnitude,
                        reason = targetReason,
                        path = self:GetTargetPracticePath(obj),
                    })
                else
                    blacklisted = blacklisted + 1
                end
            else
                rejectedPetal = rejectedPetal + 1
                if self.targetPracticeAllowPetalFallback and obj.Name == "Crosshair" then
                    local pos = obj.Position
                    if not self:IsTargetPracticeHandledSpot(pos) then
                        local dx = hrpPos.X - pos.X
                        local dz = hrpPos.Z - pos.Z
                        local distSquared = dx * dx + dz * dz

                        table.insert(petalFallback, {
                            part = obj,
                            pos = pos,
                            distSquared = distSquared,
                            dist = Vector3.new(dx, 0, dz).Magnitude,
                            reason = (targetReason or "name=Crosshair") .. ":petalFallback",
                            path = self:GetTargetPracticePath(obj),
                            allowBadAncestor = true,
                        })

                        if #interestingSamples < 8 then
                            table.insert(interestingSamples, "fallback:" .. self:GetTargetPracticePath(obj))
                        end
                    else
                        blacklisted = blacklisted + 1
                    end
                end
            end
        end
    end

    table.sort(found, function(a, b)
        return a.distSquared < b.distSquared
    end)

    table.sort(petalFallback, function(a, b)
        return a.distSquared < b.distSquared
    end)

    local usedPetalFallback = false
    if #found <= 0 and #petalFallback > 0 then
        found = petalFallback
        usedPetalFallback = true
    end

    local first = found[1]
    self:DebugTargetPractice(
        "scan",
        "source=" .. tostring(source or "unknown"),
        "desc=" .. tostring(totalDesc),
        "baseParts=" .. tostring(basePartCount),
        "crosshair=" .. tostring(totalCrosshair),
        "targetLike=" .. tostring(totalTargetLike),
        "accepted=" .. tostring(accepted),
        "petal=" .. tostring(rejectedPetal),
        "fallback=" .. tostring(#petalFallback),
        "usingFallback=" .. tostring(usedPetalFallback),
        "blacklisted=" .. tostring(blacklisted),
        first and ("closest=" .. string.format("%.1f", first.dist or 0)) or "closest=none"
    )

    if totalCrosshair <= 0 then
        if #interestingSamples > 0 then
            self:DebugTargetPractice("candidates", "source=" .. tostring(source or "unknown"), "interesting=" .. table.concat(interestingSamples, " | "))
        elseif #sampleNames > 0 then
            self:DebugTargetPractice("candidates", "source=" .. tostring(source or "unknown"), "samples=" .. table.concat(sampleNames, ", "))
        end
    end

    return found
end

function UI:HandleTargetPracticeInterrupt(character, hrp, source)
    if not self.farmTargetPractice then
        return false
    end

    if not self.autoFarmEnabled or not self.autoFarmRunning then
        self:DebugTargetPractice("skip", "source=" .. tostring(source or "unknown"), "autoFarmEnabled=" .. tostring(self.autoFarmEnabled), "autoFarmRunning=" .. tostring(self.autoFarmRunning))
        return false
    end

    if not character or not hrp then
        self:DebugTargetPractice("skip", "source=" .. tostring(source or "unknown"), "character=" .. tostring(character ~= nil), "hrp=" .. tostring(hrp ~= nil))
        return false
    end

    local crosshairs = self:GetTargetPracticeCrosshairs(hrp, source)
    local targetData = crosshairs[1]
    if not targetData or not targetData.part then
        self:DebugTargetPractice("no_target", "source=" .. tostring(source or "unknown"), "valid=0")
        return false
    end

    local crosshair = targetData.part
    local allowBadAncestor = targetData.allowBadAncestor == true
    if not crosshair.Parent or (self:HasTargetPracticeBadAncestor(crosshair) and not allowBadAncestor) then
        self:AddTargetPracticeHandledSpot(targetData.pos)
        self:DebugTargetPractice("skip", "selected invalid before walk")
        return false
    end

    self.targetPracticeActive = true
    self.status = "Farm Target Practice"
    self.needsRedraw = true

    StopWalking()
    task.wait(0.02)

    local walkStart = os.clock()
    local timeoutSeconds = tonumber(self.targetPracticeTimeout) or 5
    local reachRadius = tonumber(self.targetPracticeReachRadius) or 5
    local reachSquared = reachRadius * reachRadius
    local stableTime = tonumber(self.targetPracticeStableTime) or 0.12
    local retargetInterval = tonumber(self.targetPracticeRetargetInterval) or 0.2
    local reached = false
    local exitReason = "stopped"
    local lastWalkDebug = 0
    local lastRetarget = 0
    local insideSince = nil

    self:DebugTargetPractice(
        "target",
        "source=" .. tostring(source or "unknown"),
        "dist=" .. string.format("%.1f", targetData.dist or 0),
        "pos=" .. tostring(crosshair.Position),
        "reason=" .. tostring(targetData.reason or "unknown"),
        "path=" .. tostring(targetData.path or "unknown"),
        "allowBadAncestor=" .. tostring(allowBadAncestor),
        "reach=" .. tostring(reachRadius),
        "timeout=" .. tostring(timeoutSeconds)
    )

    while self.autoFarmEnabled and self.autoFarmRunning and self.farmTargetPractice do
        if not crosshair or not crosshair.Parent then
            exitReason = "despawned"
            break
        end

        if self:HasTargetPracticeBadAncestor(crosshair) and not allowBadAncestor then
            exitReason = "petal_ancestor"
            break
        end

        character = game.Players.LocalPlayer.Character
        if not character then
            exitReason = "lost_character"
            break
        end

        hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then
            exitReason = "lost_hrp"
            break
        end

        local humanoid = character:FindFirstChild("Humanoid")
        if not humanoid then
            exitReason = "lost_humanoid"
            break
        end

        local crosshairPos = crosshair.Position
        local targetPos = Vector3.new(crosshairPos.X, hrp.Position.Y, crosshairPos.Z)
        if WalkToService then
            WalkToService.currentTarget = targetPos
        end

        local currentPos = hrp.Position
        local dx = currentPos.X - crosshairPos.X
        local dz = currentPos.Z - crosshairPos.Z
        local distSquared = dx * dx + dz * dz

        if distSquared <= reachSquared then
            insideSince = insideSince or os.clock()
            if os.clock() - insideSince >= stableTime then
                reached = true
                exitReason = "reached"
                break
            end
        else
            insideSince = nil
        end

        if os.clock() - walkStart > timeoutSeconds then
            exitReason = "timeout"
            break
        end

        if os.clock() - lastRetarget >= retargetInterval then
            lastRetarget = os.clock()

            if not IsWalking() then
                WalkTo(targetPos)
            end
        end

        if os.clock() - lastWalkDebug >= 0.45 then
            lastWalkDebug = os.clock()
            self:DebugTargetPractice(
                "walking",
                "dist=" .. string.format("%.1f", Vector3.new(dx, 0, dz).Magnitude),
                "reach=" .. string.format("%.1f", reachRadius),
                "isWalking=" .. tostring(IsWalking()),
                "target=" .. tostring(crosshairPos)
            )
        end

        task.wait(0.04)
    end

    local lastPos = targetData.pos
    if crosshair and crosshair.Parent then
        lastPos = crosshair.Position
    end
    if reached or exitReason == "despawned" or exitReason == "petal_ancestor" or exitReason == "timeout" then
        self:AddTargetPracticeHandledSpot(lastPos)
    end

    StopWalking()
    self.targetPracticeActive = false

    if reached then
        self.status = "Target Practice Hit"
    else
        self.status = "Auto Farm Active"
    end
    self:DebugTargetPractice("done", "reason=" .. tostring(exitReason), "reached=" .. tostring(reached), "elapsed=" .. string.format("%.2f", os.clock() - walkStart))
    self.needsRedraw = true

    return true
end

function UI:TryTargetPracticeInterrupt(source)
    if not self.farmTargetPractice or self.targetPracticeActive then
        return false
    end

    local now = os.clock()
    local interval = tonumber(self.targetPracticeCheckInterval) or 0.65
    if now - (self.targetPracticeLastCheck or 0) < interval then
        return false
    end
    self.targetPracticeLastCheck = now

    local player = game.Players.LocalPlayer
    local character = player and player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")

    if not character or not hrp then
        self:DebugTargetPractice("skip", "source=" .. tostring(source or "unknown"), "character=" .. tostring(character ~= nil), "hrp=" .. tostring(hrp ~= nil))
        return false
    end

    local handled = self:HandleTargetPracticeInterrupt(character, hrp, source)
    if handled then
        self:DebugTargetPractice("interrupt", "source=" .. tostring(source or "unknown"))
    end

    return handled
end

function UI:GoToNearestTarget(target)
    if not target then return false end
    
    local targetPos = target.position
    local targetType = target.type
    WalkTo(targetPos)
    local startTime = os.clock()
    local timeoutSeconds = 15
    
    while IsWalking() and self.autoFarmEnabled do
        local player = game.Players.LocalPlayer
        local character = player.Character
        if character then
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local currentPos = hrp.Position
                local dx = currentPos.X - targetPos.X
                local dz = currentPos.Z - targetPos.Z
                local distance2D = Vector3.new(dx, 0, dz).Magnitude
                
                if distance2D < 4 then
                    StopWalking()
                    return true
                end
            end
        end
        
        if os.clock() - startTime > timeoutSeconds then
            print("Timeout walking to " .. targetType)
            StopWalking()
            return false
        end
        
        task.wait(0.1)
    end
    
    StopWalking()
    return false
end

function UI:HandleTarget(target)
    if not target then return false end
    
    local targetType = target.type
    
    if targetType == "bloom" then
        return self:GrindBloom(target.object)
    elseif targetType == "token" then
        -- Tokens are passively collected
        return true
    elseif targetType == "balloon" then
        return self:FarmUnderBalloon(target.object)
    elseif targetType == "cloud" then
        return self:FarmUnderCloud(target.object)
    elseif targetType == "bubble" then
        return self:FarmBubbles({target.object})
    elseif targetType == "flame" then
        return self:FarmFlames({target.object})
    end
    
    return false
end

