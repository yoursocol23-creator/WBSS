function UI:_track(obj)
    table.insert(self._drawings, obj)
    return obj
end

function UI:Clear()
    for _, d in ipairs(self._drawings) do
        pcall(function() d.Visible = false end)
        pcall(function() d.Transparency = 0 end)
        pcall(function() d:Remove() end)
    end
    self._drawings = {}
    self._hitboxes = {}
end

function UI:HideAll()
    for _, d in ipairs(self._drawings) do
        pcall(function() d.Visible = false end)
        pcall(function() d.Transparency = 0 end)
    end
end

function UI:ShutdownForLaunch(source, scriptName)
    self.isOpen = false
    self.isRunning = false
    self.hoveredId = nil
    self.draggingWindow = false
    self.draggingScroll = false
    self.draggingFeatureScroll = false
    self.appearAlpha = 0
    self.appearOffset = 16
    self:HideAll()

    task.spawn(function()
        pcall(function()
            RunService.RenderStepped:Wait()
        end)
        pcall(function()
            RunService.RenderStepped:Wait()
        end)
        self:Clear()
        pcall(function()
            sendExecutionEvent(scriptName)
        end)
        pcall(function()
            runScriptSource(source, scriptName)
        end)
    end)
end

function UI:CreateSquare(x, y, w, h, color, filled, thickness)
    local sq = Drawing.new("Square")
    local alpha = math.max(0, math.min(1, self.appearAlpha or 1))
    sq.Position  = Vector2.new(x, y)
    sq.Size      = Vector2.new(w, h)
    sq.Color     = color
    sq.Filled    = filled ~= false
    sq.Thickness = thickness or 1
    sq.Transparency = alpha
    sq.Visible   = true
    return self:_track(sq)
end

function UI:CreateText(text, x, y, color, size, centered)
    local t = Drawing.new("Text")
    local alpha = math.max(0, math.min(1, self.appearAlpha or 1))
    t.Text     = tostring(text)
    t.Position = Vector2.new(x, y)
    t.Color    = color
    t.Size     = size or 13
    t.Center   = centered == true
    t.Outline  = true
    t.Font     = 2
    t.Transparency = alpha
    t.Visible  = true
    return self:_track(t)
end

function UI:CreateLine(x1, y1, x2, y2, color, thickness)
    local l = Drawing.new("Line")
    local alpha = math.max(0, math.min(1, self.appearAlpha or 1))
    l.From      = Vector2.new(x1, y1)
    l.To        = Vector2.new(x2, y2)
    l.Color     = color
    l.Thickness = thickness or 1
    l.Transparency = alpha
    l.Visible   = true
    return self:_track(l)
end

function UI:RegisterHitbox(id, x, y, w, h, onDown)
    table.insert(self._hitboxes, { id = id, x = x, y = y, w = w, h = h, onDown = onDown })
end

function UI:GetMouseLocation()
    return Vector2.new(LocalMouse.X, LocalMouse.Y)
end

function UI:HitTest(mx, my)
    for i = #self._hitboxes, 1, -1 do
        local hb = self._hitboxes[i]
        if mx >= hb.x and mx <= hb.x + hb.w and my >= hb.y and my <= hb.y + hb.h then
            return hb
        end
    end
    return nil
end

local function lerp(a, b, t)
    return a + ((b - a) * t)
end

local function clamp01(v)
    if v < 0 then
        return 0
    end
    if v > 1 then
        return 1
    end
    return v
end

local function blendColor(a, b, t)
    t = clamp01(t)
    return Color3.new(
        lerp(a.R, b.R, t),
        lerp(a.G, b.G, t),
        lerp(a.B, b.B, t)
    )
end

