function UI:IsPositionInMondoBoundary(position)
    local config = self.mondoChickConfig
    
    local withinX = position.X >= config.boundaryMin.X and position.X <= config.boundaryMax.X
    local withinZ = position.Z >= config.boundaryMin.Z and position.Z <= config.boundaryMax.Z
    local withinY = math.abs(position.Y - config.boundaryMin.Y) <= 60
    
    return withinX and withinZ and withinY
end

function UI:ClampPositionToMondoBoundary(position)
    local config = self.mondoChickConfig
    
    local clampedX = math.max(config.boundaryMin.X, math.min(position.X, config.boundaryMax.X))
    local clampedZ = math.max(config.boundaryMin.Z, math.min(position.Z, config.boundaryMax.Z))
    local clampedY = config.boundaryMin.Y
    
    return Vector3.new(clampedX, clampedY, clampedZ)
end

function UI:FightMondoChick()
    
    local player = game.Players.LocalPlayer
    local character = player.Character
    
    if not character then
        return false
    end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        return false
    end
    
    local previousStatus = self.status
    local previousField = self.selectedOption
    
    
    self.pausedForTimedAction = true
    StopWalking()
    self:ClearTweenQueue()
    task.wait(0.5)
    
    self.status = "Going to Mondo Chick"
    self.needsRedraw = true
    
    local fightPos = self.mondoChickConfig.fightPosition
    
    self:QueueTween(hrp, fightPos, true)
    
    local maxWaitTime = 60
    local startWait = os.clock()
    
    self:WaitForTween(60, function() return self.autoFarmEnabled end)
    
    task.wait(1)
    
    if not self:CheckForMondoChick() then
        
        if self.autoFarmEnabled and previousField and previousField ~= "Select Field..." then
            self.status = "Returning to " .. previousField
            self.needsRedraw = true
            
            
            local flowerZones = GetFlowerZonesFolder()
            if flowerZones then
                local targetZone = GetFlowerZone(previousField)
                if targetZone then
                    character = player.Character
                    if character then
                        hrp = character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local fieldPos = Vector3.new(targetZone.Position.X, targetZone.Position.Y + 10, targetZone.Position.Z)
                            self:QueueTween(hrp, fieldPos, true)
                            
                            startWait = os.clock()
                            self:WaitForTween(60, function() return self.autoFarmEnabled end)
                        end
                    end
                end
            end
        end
        
        self.pausedForTimedAction = false
        self.status = previousStatus
        self.needsRedraw = true
        
        return false
    end
    
    self.status = "Fighting Mondo Chick"
    self.needsRedraw = true
    
    -- Main combat loop
    local fightStartTime = os.clock()
    local maxFightDuration = self.lootMondo and math.huge or self.mondoTimeToKill
    
    
    local loopCount = 0
    
    while self.autoFarmEnabled and self.killMondo and self:CheckForMondoChick() do
        loopCount = loopCount + 1
        
        
        -- Check fight duration (only if time-based)
        if not self.lootMondo and (os.clock() - fightStartTime) >= maxFightDuration then
            break
        end
        
        character = player.Character
        if not character then 
            break 
        end
        
        hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then 
            break 
        end
        
        local hrpPos = hrp.Position
        
        local mondoData = self:GetMondoChickPosition()
        
        if not mondoData then
            task.wait(0.3)
            continue
        end
        
        local currentDistance = mondoData.distance
        local mondoPos = mondoData.position
        local mondoVel = mondoData.velocity
        
        local predictedPos = mondoData.predictedPosition
        
        local pdx = hrpPos.X - predictedPos.X
        local pdz = hrpPos.Z - predictedPos.Z
        local predictedDistance = Vector3.new(pdx, 0, pdz).Magnitude
        
        local currentDanger = math.max(0, self.mondoChickConfig.minDistance - currentDistance)
        local predictedDanger = math.max(0, self.mondoChickConfig.minDistance - predictedDistance)
        local totalDanger = currentDanger + predictedDanger * 2
        
        local targetPos = nil
        local action = ""
        
        if totalDanger > 0 then
            action = "ðŸš¨ESCAPE"
            
            local escapeX = hrpPos.X + (hrpPos.X - predictedPos.X) * 3
            local escapeZ = hrpPos.Z + (hrpPos.Z - predictedPos.Z) * 3
            
            escapeX = escapeX + (hrpPos.X - mondoPos.X) * 1.5
            escapeZ = escapeZ + (hrpPos.Z - mondoPos.Z) * 1.5
            
            targetPos = Vector3.new(escapeX, self.mondoChickConfig.boundaryMin.Y, escapeZ)
            
        elseif currentDistance < self.mondoChickConfig.idealDistance or 
               predictedDistance < self.mondoChickConfig.idealDistance then
            
            action = "RETREAT"
            
            local awayX = hrpPos.X + (hrpPos.X - predictedPos.X) * 1.5
            local awayZ = hrpPos.Z + (hrpPos.Z - predictedPos.Z) * 1.5
            targetPos = Vector3.new(awayX, self.mondoChickConfig.boundaryMin.Y, awayZ)
            
        elseif currentDistance > self.mondoChickConfig.maxDistance and
               predictedDistance > self.mondoChickConfig.maxDistance then
            
            action = "APPROACH"
            
            local towardsX = hrpPos.X + (predictedPos.X - hrpPos.X) * 0.4
            local towardsZ = hrpPos.Z + (predictedPos.Z - hrpPos.Z) * 0.4
            targetPos = Vector3.new(towardsX, self.mondoChickConfig.boundaryMin.Y, towardsZ)
            
        else
            action = "STRAFE"
            
            local toPredictedX = predictedPos.X - hrpPos.X
            local toPredictedZ = predictedPos.Z - hrpPos.Z
            
            local perpX = -toPredictedZ
            local perpZ = toPredictedX
            
            local perpLen = Vector3.new(perpX, 0, perpZ).Magnitude
            if perpLen > 0.1 then
                perpX = perpX / perpLen * 25
                perpZ = perpZ / perpLen * 25
            else
                local angle = math.atan2(hrpPos.Z - mondoPos.Z, hrpPos.X - mondoPos.X) + math.rad(45)
                perpX = math.cos(angle) * 30 - (mondoPos.X - hrpPos.X)
                perpZ = math.sin(angle) * 30 - (mondoPos.Z - hrpPos.Z)
            end
            
            targetPos = Vector3.new(hrpPos.X + perpX, self.mondoChickConfig.boundaryMin.Y, hrpPos.Z + perpZ)
        end
        
        targetPos = self:ClampPositionToMondoBoundary(targetPos)
        
        -- Token collection (only if not in danger)
        if action ~= "ðŸš¨ESCAPE" and action ~= "RETREAT" then
            local collectibles = game.Workspace:FindFirstChild("Collectibles")
            if collectibles then
                for _, token in pairs(collectibles:GetChildren()) do
                    if token.Name == "C" and token:IsA("BasePart") and token.Parent then
                        if token.Transparency < 0.2 then
                            local tokenPos = token.Position
                            
                            local tdx = tokenPos.X - targetPos.X
                            local tdz = tokenPos.Z - targetPos.Z
                            local tokenDistToPath = Vector3.new(tdx, 0, tdz).Magnitude
                            
                            if tokenDistToPath < 12 then
                                local dxFromMondo = tokenPos.X - predictedPos.X
                                local dzFromMondo = tokenPos.Z - predictedPos.Z
                                local tokenDistFromMondo = Vector3.new(dxFromMondo, 0, dzFromMondo).Magnitude
                                
                                if tokenDistFromMondo > 20 then
                                    targetPos = Vector3.new(
                                        targetPos.X + (tokenPos.X - targetPos.X) * 0.6,
                                        self.mondoChickConfig.boundaryMin.Y,
                                        targetPos.Z + (tokenPos.Z - targetPos.Z) * 0.6
                                    )
                                    action = action .. "+TOKEN"
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
        
        -- Show time remaining if time-based
        if not self.lootMondo then
            local timeRemaining = maxFightDuration - (os.clock() - fightStartTime)
            self.status = action .. " (" .. math.floor(timeRemaining) .. "s)"
        else
            self.status = action .. " (Looting)"
        end
        self.needsRedraw = true
        
        WalkTo(targetPos)
        
        local moveStart = os.clock()
        while IsWalking() and os.clock() - moveStart < self.mondoChickConfig.moveInterval do
            task.wait(0.05)
        end
        
        StopWalking()
        task.wait(0.05)
    end
    
    StopWalking()
    if self.lootMondo and self.autoFarmEnabled then
        self.status = "Looting Mondo"
        self.needsRedraw = true
        
        local collectStart = os.clock()
        local recentTokens = {}
        
        while self.autoFarmEnabled and (os.clock() - collectStart) < 30 do
            local collectibles = game.Workspace:FindFirstChild("Collectibles")
            if collectibles then
                character = player.Character
                if character then
                    hrp = character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local hrpPos = hrp.Position
                        local closestToken = nil
                        local closestDist = math.huge
                        
                        for _, token in pairs(collectibles:GetChildren()) do
                            if token.Name == "C" and token:IsA("BasePart") and token.Parent then
                                if token.Transparency >= 0.2 then continue end
                                local tokenPos = token.Position
                                local isRecent = false
                                for _, rp in ipairs(recentTokens) do
                                    if math.abs(tokenPos.X-rp.X) < 3 and math.abs(tokenPos.Z-rp.Z) < 3 then
                                        isRecent = true
                                        break
                                    end
                                end
                                if not isRecent then
                                    local dx = hrpPos.X - tokenPos.X
                                    local dz = hrpPos.Z - tokenPos.Z
                                    local dist = dx*dx + dz*dz
                                    if dist < 2500 and dist < closestDist then
                                        closestDist = dist
                                        closestToken = tokenPos
                                    end
                                end
                            end
                        end
                        
                        if closestToken then
                            WalkTo(closestToken)
                            local walkStart = os.clock()
                            while IsWalking() and self.autoFarmEnabled do
                                if os.clock() - walkStart > 3 then StopWalking() break end
                                hrp = character:FindFirstChild("HumanoidRootPart")
                                if hrp then
                                    local dx = hrp.Position.X - closestToken.X
                                    local dz = hrp.Position.Z - closestToken.Z
                                    if dx*dx + dz*dz < 25 then StopWalking() break end
                                end
                                task.wait(0.05)
                            end
                            StopWalking()
                            table.insert(recentTokens, closestToken)
                            if #recentTokens > 10 then table.remove(recentTokens, 1) end
                        end
                    end
                end
            end
            task.wait(0.05)
        end
        
        StopWalking()
    end


    -- Return to field
