    end
    
    print("=== FARMING " .. #bubbles .. " BUBBLES ===")
    self.status = "Farming Bubbles"
    self.needsRedraw = true
    
    local player = game.Players.LocalPlayer
    local character = player.Character
    if not character then return false end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    -- Walk to each bubble quickly - no waiting
    for i, bubble in ipairs(bubbles) do
        -- ENHANCED: Validate bubble more thoroughly
        local bubbleValid = pcall(function()
            return bubble and bubble.Parent and bubble.Position and bubble.Position.X
        end)
        
        if not bubbleValid then
            print("âš ï¸ Bubble " .. i .. " is nil or invalid, skipping...")
            continue
        end
        
        -- Double-check bubble still exists before walking
        if not bubble or not bubble.Parent then
            print("âš ï¸ Bubble " .. i .. " despawned before walk, skipping...")
            continue
        end
        
        if not self.autoFarmEnabled or not self.farmBubbles then
            StopWalking()  -- Add this
            return false
        end

        -- RE-CHECK: Bubble might have despawned since loop start
        if not bubble or not bubble.Parent then
            print("âš ï¸ Bubble " .. i .. " despawned during iteration, skipping...")
            continue
        end

        local bubblePos = bubble.Position

        WalkTo(bubblePos)

        local startTime = os.clock()
        while IsWalking() and self.autoFarmEnabled and self.farmBubbles do
            if self:TryTargetPracticeInterrupt("bubble_walk") then
                if not bubble or not bubble.Parent then
                    break
                end

                bubblePos = bubble.Position
                WalkTo(bubblePos)
                startTime = os.clock()
                task.wait(0.05)
                continue
            end

            -- RE-CHECK: Bubble might despawn mid-walk
            if not bubble or not bubble.Parent then
                print("âš ï¸ Bubble despawned mid-walk, stopping...")
                StopWalking()
                break
            end
            
            if os.clock() - startTime > 2 then  -- Changed from 1 to 2 seconds
                StopWalking()
                break
            end
            
            hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local currentPos = hrp.Position
