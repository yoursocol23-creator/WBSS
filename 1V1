    local bgColor = self.configNameInputActive and Color3.fromRGB(50, 55, 65) or Color3.fromRGB(40, 45, 55)
    self:CreateRect(sliderX, textboxY, textboxWidth, 24, bgColor, 1, 4, true)

    if self.configNameInputActive then
        self:CreateRect(sliderX, textboxY, textboxWidth, 24, Color3.fromRGB(16, 185, 129), 1, 4, false)
    end

    local displayText = self.configNameText or ""
    if #displayText == 0 and not self.configNameInputActive then
        displayText = "Click to type name..."
    end

    local textColor = Color3.fromRGB(255, 255, 255)
    if #displayText == 0 or displayText == "Click to type name..." then
        textColor = Color3.fromRGB(150, 160, 175)
    end

    self:CreateText(displayText, sliderX + 5, textboxY + 6, textColor, 12)

    if self.configNameInputActive then
        local cursorBlink = math.floor(os.clock() * 2) % 2 == 0
        if cursorBlink then
            local cursorX = sliderX + 5 + (#displayText * 7)
            self:CreateRect(cursorX, textboxY + 5, 2, 14, Color3.fromRGB(16, 185, 129), 1, 0, true)
        end
    end

    -- Save/Load/Delete buttons
    local btnRowY = textboxY + 34

    self:CreateRect(sliderX, btnRowY, 44, 24, Color3.fromRGB(16, 185, 129), 1, 6, true)
    self:CreateText("Save", sliderX + 8, btnRowY + 6, Color3.fromRGB(255, 255, 255), 12)
    if not self.savedConfigDropdownOpen then
        self:RegisterButton(sliderX, btnRowY, 44, 24, function()
            local configName = self.configNameText
            if not configName or #configName == 0 then
                configName = nil
            end
            self:ExportConfig(configName)
            self.configNameText = ""
            self.configNameInputActive = false
            self:RefreshSavedConfigs()
            self.needsRedraw = true
        end)
    end

    self:CreateRect(sliderX + 52, btnRowY, 44, 24, Color3.fromRGB(59, 130, 246), 1, 6, true)
    self:CreateText("Load", sliderX + 62, btnRowY + 6, Color3.fromRGB(255, 255, 255), 12)
    if not self.savedConfigDropdownOpen then
        self:RegisterButton(sliderX + 52, btnRowY, 44, 24, function()
            if self.selectedSavedConfig and self.selectedSavedConfig ~= "None" then
                self:ImportConfig(self.selectedSavedConfig)
            else
                self:ImportConfig()
            end
        end)
    end

    self:CreateRect(sliderX + 104, btnRowY, 46, 24, Color3.fromRGB(239, 68, 68), 1, 6, true)
    self:CreateText("Delete", sliderX + 110, btnRowY + 6, Color3.fromRGB(255, 255, 255), 12)
    if not self.savedConfigDropdownOpen then
        self:RegisterButton(sliderX + 104, btnRowY, 46, 24, function()
            if self.selectedSavedConfig and self.selectedSavedConfig ~= "None" then
                local path = CONFIG_FOLDER .. "/" .. self.selectedSavedConfig .. CONFIG_EXTENSION
                pcall(function() delfile(path) end)
                self.selectedSavedConfig = "None"
                self:RefreshSavedConfigs()
                self.status = "Config deleted!"
                self.needsRedraw = true
                spawn(function()
                    wait(3)
                    if self.status == "Config deleted!" then
                        self.status = "Ready"
                        self.needsRedraw = true
                    end
                end)
            end
        end)
    end

    -- Render config dropdown
    if self.savedConfigDropdownOpen then
        local options = {}
        for _, cfg in ipairs(self.savedConfigs) do
            table.insert(options, cfg.name)
        end
        if #options == 0 then
            table.insert(options, "No configs found")
        end

        local menuY = configY + 28
        self:CreateRect(sliderX, menuY, 150, #options * 24, Color3.fromRGB(25, 28, 35), 1, 8, true)

        for i, option in ipairs(options) do
            local optionY = menuY + ((i - 1) * 24)
            self:CreateRect(sliderX + 1, optionY + 1, 148, 22, Color3.fromRGB(40, 45, 55), 1, 0, true)
            self:CreateText(option, sliderX + 8, optionY + 6, Color3.fromRGB(200, 210, 220), 11)
            self:RegisterButton(sliderX, optionY, 150, 24, function()
                if not self.lastMousePressed and option ~= "No configs found" then
                    self.selectedSavedConfig = option
                    self.savedConfigDropdownOpen = false
                    self.needsRedraw = true
                end
            end)
        end
    end

    -- VERSION TEXT
    local versionY = btnRowY + 40

    if not self.savedConfigDropdownOpen and not (self.status == "Config saved!" or self.status == "Config loaded!" or self.status:match("^Config")) then
        self:CreateText(version, sliderX, versionY, Color3.fromRGB(100, 110, 125), 11)
        self:CreateText("Lito", sliderX, versionY + 18, Color3.fromRGB(100, 110, 125), 11)
    end
    
    -- RENDER TWEEN METHOD DROPDOWN
    if self.tweenMethodDropdownOpen then
        local options = {"Position", "Velocity", "Custom"}
        local menuY = tweenMethodY + 28
        
        self:CreateRect(sliderX, menuY, 150, #options * 24, Color3.fromRGB(25, 28, 35), 1, 8, true)
        
        for i, option in ipairs(options) do
            local optionY = menuY + ((i - 1) * 24)
            
            self:CreateRect(sliderX + 1, optionY + 1, 148, 22, Color3.fromRGB(40, 45, 55), 1, 0, true)
            self:CreateText(option, sliderX + 8, optionY + 6, Color3.fromRGB(200, 210, 220), 11)
            
            self:RegisterButton(sliderX, optionY, 150, 24, function()
                if not self.lastMousePressed then
                    self.tweenMethod = option
                    TweenService.currentMethod = option
                    self.tweenMethodDropdownOpen = false
                    self.needsRedraw = true
                    print("Tween method changed to: " .. option)
                end
            end)
        end
    end
end


function UI:StartAutoQuest()
    if self.autoQuestRunning then
        print("DEBUG QUEST: Auto Quest already running!")
        return
    end
    
    if not self.autoFarmEnabled then
        print("DEBUG QUEST: Auto Farm is not enabled!")
        self.autoQuest = false
        self.needsRedraw = true
        return
    end
    
    self.autoQuestRunning = true
    print("DEBUG QUEST: ✓ Auto Quest thread starting...")
    
    -- Run in separate thread
    self.autoQuestThread = spawn(function()
        print("DEBUG QUEST: === AUTO QUEST STARTED ===")
        
        while self.autoQuest and self.autoQuestRunning do
            print("DEBUG QUEST: ========== NEW QUEST CHECK LOOP ==========")
            
            if not self.autoFarmEnabled then
                print("DEBUG QUEST: ❌ Auto Farm disabled - stopping Auto Quest")
                break
            end
            
            local success, err = pcall(function()
                local player = game.Players.LocalPlayer
                
                local playerGui = player:FindFirstChild("PlayerGui")
                if not playerGui then return end
                
                local screenGui = playerGui:FindFirstChild("ScreenGui")
                if not screenGui then return end
                
                local menus = screenGui:FindFirstChild("Menus")
                if not menus then return end
                
                local children = menus:FindFirstChild("Children")
                if not children then return end
                
                local quests = children:FindFirstChild("Quests")
                if not quests then return end
                
                local content = quests:FindFirstChild("Content")
                if not content then return end
                
                local frame = content:FindFirstChild("Frame")
                if not frame then return end
                
                -- Collect all quests and their requirements
                local allQuestRequirements = {}
                
                for _, questBox in pairs(frame:GetChildren()) do
                    if questBox.Name == "QuestBox" then
                        local titleBarBG = questBox:FindFirstChild("TitleBarBG")
                        if not titleBarBG then continue end
                        
                        local titleBar = titleBarBG:FindFirstChild("TitleBar")
                        if not titleBar then continue end
                        
                        local questName = titleBar.Text
                        print("DEBUG QUEST: 📋 Found quest: \"" .. questName .. "\"")
                        
                        local shouldProcess = false
                        local isBrownBear = string.find(questName, "Brown Bear:")
                        local isPolarBear = string.find(questName, "Polar Bear:")

                        if self.autoDoAll then
                            shouldProcess = true
                            print("DEBUG QUEST: Do All is ON - processing quest")
                        elseif isBrownBear and self.autoBrowBear then
                            shouldProcess = true
                            print("DEBUG QUEST: Brown Bear quest and toggle is ON - processing quest")
                        elseif isPolarBear and self.autoPolarBear then
                            shouldProcess = true
                            print("DEBUG QUEST: Polar Bear quest and toggle is ON - processing quest")
                        end
                        
                        if not shouldProcess then
                            print("DEBUG QUEST: Skipping quest (toggles are OFF)")
                            continue
                        end
                        
                        -- DEBUG: Count TaskBars
                        local taskBarCount = 0
                        for _, child in pairs(questBox:GetChildren()) do
                            if child.Name == "TaskBar" then
                                taskBarCount = taskBarCount + 1
                            end
                        end
                        print("DEBUG QUEST: Found " .. taskBarCount .. " TaskBars in this quest")
                        
                        local allComplete = true
                        local tasks = {}
                        
                        -- Collect all tasks
                        for _, taskBar in pairs(questBox:GetChildren()) do
                            if taskBar.Name == "TaskBar" and taskBar:IsA("Frame") then
                                local description = taskBar:FindFirstChild("Description")
                                
                                if description and description:IsA("TextLabel") then
                                    local taskText = description.Text
                                    
                                    if taskText and #taskText > 3 then
                                        taskText = taskText:gsub("[\n\r]+", " "):gsub("%s+", " ")
                                        
                                        local isComplete = string.find(string.lower(taskText), "complete") ~= nil
                                        local hasTalkTo = string.find(taskText, "Talk to ") ~= nil
                                        
                                        print("DEBUG QUEST:     Task: " .. taskText .. " | Complete: " .. tostring(isComplete))

                                        if not isComplete and not hasTalkTo then
                                            allComplete = false
                                            
                                            -- Parse requirement
                                            local requirement = self:ParseQuestRequirement(taskText)
                                            if requirement then
                                                -- Check if kill_mob requirement has a configured spawner
                                                if requirement.type == "kill_mob" then
                                                    local spawnerInfo = self:GetMobSpawnerCooldown(requirement.mob)
                                                    
                                                    if not spawnerInfo then
                                                        print("DEBUG QUEST: ⚠️ Skipping kill_mob requirement (spawner not configured): " .. requirement.mob)
                                                        continue
                                                    end
                                                    
                                                    if self.questKillMobs then
                                                        table.insert(allQuestRequirements, {
                                                            questName = questName,
                                                            questBox = questBox,
                                                            requirement = requirement,
                                                            tasks = tasks
                                                        })
                                                        print("DEBUG QUEST: ✓ Added kill mob requirement: " .. requirement.mob .. " (" .. requirement.amount .. ")")
                                                    end
                                                elseif requirement.type == "pollen" and self.questCollectPollen then
                                                    table.insert(allQuestRequirements, {
                                                        questName = questName,
                                                        questBox = questBox,
                                                        requirement = requirement,
                                                        tasks = tasks
                                                    })
                                                    print("DEBUG QUEST: ✓ Added pollen requirement: " .. requirement.field .. " (" .. requirement.amount .. ")")
                                                end
                                            end
                                        end
                                        
                                        table.insert(tasks, {text = taskText, complete = isComplete, hasTalkTo = hasTalkTo})
                                    else
                                        print("DEBUG QUEST:     Task text too short or empty: '" .. tostring(taskText) .. "'")
                                    end
                                else
                                    print("DEBUG QUEST:     TaskBar missing Description or not TextLabel")
                                end
                            end
                        end
                        
                        -- If all tasks complete, add to list for claiming
                        if allComplete then
                            print("DEBUG QUEST: ✓✓✓ ALL TASKS COMPLETE FOR: " .. questName)
                            
                            -- Find the "Talk to" task
                            local talkToTask = nil
                            for _, task in ipairs(tasks) do
                                if task.hasTalkTo then
                                    talkToTask = task
                                    break
                                end
                            end
                            
                            if talkToTask then
                                print("DEBUG QUEST: Found Talk To task, adding to claim list")
                                table.insert(allQuestRequirements, {
                                    questName = questName,
                                    questBox = questBox,
                                    requirement = nil,
                                    tasks = tasks,
                                    readyToClaim = true,
                                    talkToTask = talkToTask
                                })
                            else
                                print("DEBUG QUEST: No Talk To task found for completed quest")
                            end
                        end
                    end
                end
                
                print("DEBUG QUEST: Total quest requirements collected: " .. #allQuestRequirements)
                
                -- Sort by pollen amount (lowest first)
                table.sort(allQuestRequirements, function(a, b)
                    -- Prioritize ready-to-claim quests
                    if a.readyToClaim and not b.readyToClaim then return true end
                    if not a.readyToClaim and b.readyToClaim then return false end
                    
                    -- Then sort by amount (pollen or mob kills)
                    if a.requirement and b.requirement then
                        return a.requirement.amount < b.requirement.amount
                    end
                    return false
                end)
                
                -- Process the first quest in the sorted list
                if #allQuestRequirements > 0 then
                    local currentQuest = allQuestRequirements[1]
                    
                    -- If ready to claim
                    if currentQuest.readyToClaim then
                        if self.claimQuest then
                            local npcName = string.match(currentQuest.talkToTask.text, "Talk to ([^%.]+)")
                            
                            if npcName then
                                print("DEBUG QUEST: === CLAIMING QUEST FROM: " .. npcName .. " ===")
                                
                                local wasAutoFarming = self.autoFarmEnabled
                                local previousStatus = self.status
                                self.pausedForTimedAction = true
                                
                                StopWalking()
                                self:ClearTweenQueue()
                                wait(0.5)
                                
                                -- Get initial quest count
                                local initialQuestCount = #frame:GetChildren()
                                for _, child in pairs(frame:GetChildren()) do
                                    if child.Name ~= "QuestBox" then
                                        initialQuestCount = initialQuestCount - 1
                                    end
                                end
                                print("DEBUG QUEST: Initial quest count:", initialQuestCount)
                                
                                -- Find NPC position
                                local npcPos = nil
                                local npcs = game.Workspace:FindFirstChild("NPCs")
                                if npcs then
                                    local npc = npcs:FindFirstChild(npcName)
                                    if npc then
                                        local platform = npc:FindFirstChild("Platform")
                                        if platform and platform:IsA("BasePart") then
                                            npcPos = Vector3.new(platform.Position.X, platform.Position.Y + 5, platform.Position.Z)
                                            print("DEBUG QUEST: ✓ NPC position found:", npcPos)
                                        end
                                    end
                                end
                                
                                if npcPos then
                                    character = player.Character
                                    if character then
                                        hrp = character:FindFirstChild("HumanoidRootPart")
                                        if hrp then
                                            self.status = "Going to " .. npcName
                                            self.needsRedraw = true
                                            
                                            print("DEBUG QUEST: Tweening to NPC...")
                                            self:QueueTween(hrp, npcPos, true)
                                            
                                            local startWait = os.clock()
                                            while self.processingTween and self.autoFarmEnabled do
                                                if os.clock() - startWait > 60 then
                                                    print("DEBUG QUEST: ❌ Tween timeout!")
                                                    self:ClearTweenQueue()
                                                    break
                                                end
                                                wait(0.1)
                                            end
                                            
                                            print("DEBUG QUEST: ✓ Arrived at NPC")
                                            wait(0.5)
                                            
                                            -- Retry loop (2 attempts max)
                                            local maxAttempts = 2
                                            
                                            for attempt = 1, maxAttempts do
                                                print("DEBUG QUEST: === ATTEMPT " .. attempt .. "/" .. maxAttempts .. " ===")
                                                
                                                -- Wait for Roblox to be active
                                                while not isrbxactive() and self.autoFarmEnabled do
                                                    warn("DEBUG QUEST: Roblox not active - waiting...")
                                                    self.status = "Waiting for Roblox window"
                                                    self.needsRedraw = true
                                                    wait(0.5)
                                                end
                                                
                                                if not self.autoFarmEnabled then break end
                                                
                                                -- STEP 1: Turn in completed quest
                                                print("DEBUG QUEST: Step 1: Pressing E to open NPC dialogue...")
                                                self.status = "Claiming Quest from " .. npcName
                                                self.needsRedraw = true
                                                
                                                keypress(0x45)
                                                wait(0.1)
                                                keyrelease(0x45)
                                                wait(0.5)
                                                
                                                -- Click through dialogue until quest count decreases
                                                print("DEBUG QUEST: Clicking through turn-in dialogue...")
                                                local turnInTimeout = os.clock()
                                                local questTurnedIn = false
                                                
                                                while self.autoFarmEnabled and (os.clock() - turnInTimeout) < 15 do
                                                    -- Check current quest count
                                                    local currentQuestCount = 0
                                                    pcall(function()
                                                        playerGui = player:FindFirstChild("PlayerGui")
                                                        if playerGui then
                                                            screenGui = playerGui:FindFirstChild("ScreenGui")
                                                            if screenGui then
                                                                menus = screenGui:FindFirstChild("Menus")
                                                                if menus then
                                                                    children = menus:FindFirstChild("Children")
                                                                    if children then
                                                                        quests = children:FindFirstChild("Quests")
                                                                        if quests then
                                                                            content = quests:FindFirstChild("Content")
                                                                            if content then
                                                                                frame = content:FindFirstChild("Frame")
                                                                                if frame then
                                                                                    for _, child in pairs(frame:GetChildren()) do
                                                                                        if child.Name == "QuestBox" then
                                                                                            currentQuestCount = currentQuestCount + 1
                                                                                        end
                                                                                    end
                                                                                end
                                                                            end
                                                                        end
                                                                    end
                                                                end
                                                            end
                                                        end
                                                    end)
                                                    
                                                    print("DEBUG QUEST: Quest count: " .. currentQuestCount .. " (waiting for " .. (initialQuestCount - 1) .. ")")
                                                    
                                                    if currentQuestCount < initialQuestCount then
                                                        print("DEBUG QUEST: ✓ Quest turned in! (" .. initialQuestCount .. " -> " .. currentQuestCount .. ")")
                                                        questTurnedIn = true
                                                        break
                                                    end
                                                    
                                                    -- RANDOM OFFSET WITHIN ±5 PIXELS
                                                    local offsetX = math.random(-5, 5)
                                                    local offsetY = math.random(-5, 5)
                                                    local clickX = 1000 + offsetX
                                                    local clickY = 833 + offsetY
                                                    
                                                    mousemoveabs(clickX, clickY)
                                                    wait(0.05)
                                                    mouse1click()
                                                    wait(0.05)
                                                    print("DEBUG QUEST: ✓ Clicked at (" .. clickX .. ", " .. clickY .. ")!")
                                                    wait(0.2)
                                                end
                                                
                                                if not questTurnedIn then
                                                    print("DEBUG QUEST: ⚠️ Quest turn-in timeout (Attempt " .. attempt .. ")")
                                                    if attempt < maxAttempts then
                                                        print("DEBUG QUEST: Retrying...")
                                                        wait(1)
                                                        continue
                                                    else
                                                        print("DEBUG QUEST: ❌ Max attempts reached, resuming auto farm")
                                                        break
                                                    end
                                                end
                                                
                                                wait(0.5)
                                                
                                                -- STEP 2: Accept new quest
                                                print("DEBUG QUEST: Step 2: Pressing E again to accept new quest...")
                                                keypress(0x45)
                                                wait(0.1)
                                                keyrelease(0x45)
                                                wait(0.5)
                                                
                                                -- Click through dialogue until quest count increases
                                                print("DEBUG QUEST: Clicking through accept dialogue...")
                                                local acceptTimeout = os.clock()
                                                local questAccepted = false
                                                local targetQuestCount = initialQuestCount
                                                
                                                while self.autoFarmEnabled and (os.clock() - acceptTimeout) < 15 do
                                                    -- Check current quest count
                                                    local currentQuestCount = 0
                                                    pcall(function()
                                                        playerGui = player:FindFirstChild("PlayerGui")
                                                        if playerGui then
                                                            screenGui = playerGui:FindFirstChild("ScreenGui")
                                                            if screenGui then
                                                                menus = screenGui:FindFirstChild("Menus")
                                                                if menus then
                                                                    children = menus:FindFirstChild("Children")
                                                                    if children then
                                                                        quests = children:FindFirstChild("Quests")
                                                                        if quests then
                                                                            content = quests:FindFirstChild("Content")
                                                                            if content then
                                                                                frame = content:FindFirstChild("Frame")
                                                                                if frame then
                                                                                    for _, child in pairs(frame:GetChildren()) do
                                                                                        if child.Name == "QuestBox" then
                                                                                            currentQuestCount = currentQuestCount + 1
                                                                                        end
                                                                                    end
                                                                                end
                                                                            end
                                                                        end
                                                                    end
                                                                end
                                                            end
                                                        end
                                                    end)
                                                    
                                                    print("DEBUG QUEST: Quest count: " .. currentQuestCount .. " (waiting for " .. targetQuestCount .. ")")
                                                    
                                                    if currentQuestCount >= targetQuestCount then
                                                        print("DEBUG QUEST: ✓ New quest accepted! Quest count: " .. currentQuestCount)
                                                        questAccepted = true
                                                        break
                                                    end
                                                    
                                                    -- RANDOM OFFSET WITHIN ±5 PIXELS
                                                    local offsetX = math.random(-5, 5)
                                                    local offsetY = math.random(-5, 5)
                                                    local clickX = 1000 + offsetX
                                                    local clickY = 833 + offsetY
                                                    
                                                    mousemoveabs(clickX, clickY)
                                                    wait(0.05)
                                                    mouse1click()
                                                    wait(0.05)
                                                    print("DEBUG QUEST: ✓ Clicked at (" .. clickX .. ", " .. clickY .. ")!")
                                                    wait(0.2)
                                                end
                                                
                                                if questAccepted then
                                                    print("DEBUG QUEST: ✓✓✓ Quest claiming complete!")
                                                    break
                                                else
                                                    print("DEBUG QUEST: ⚠️ New quest acceptance timeout (Attempt " .. attempt .. ")")
                                                    if attempt < maxAttempts then
                                                        print("DEBUG QUEST: Retrying...")
                                                        wait(1)
                                                    else
                                                        print("DEBUG QUEST: ❌ Max attempts reached, resuming auto farm")
                                                    end
                                                end
                                            end
                                            
                                            -- Return to ORIGINAL field if auto farming
                                            local returnField = self.questOriginalField
                                            if wasAutoFarming and returnField and returnField ~= "Select Field..." then
                                                print("DEBUG QUEST: Returning to ORIGINAL field: " .. returnField)
                                                self.status = "Returning to " .. returnField
                                                self.needsRedraw = true
                                                
                                                local returnSuccess = pcall(function()
                                                    local flowerZones = game.Workspace.FlowerZones
                                                    if flowerZones then
                                                        local targetZone = flowerZones:FindFirstChild(returnField)
                                                        if targetZone then
                                                            character = player.Character
                                                            if character then
                                                                hrp = character:FindFirstChild("HumanoidRootPart")
                                                                if hrp then
                                                                    local fieldPos = Vector3.new(targetZone.Position.X, targetZone.Position.Y + 10, targetZone.Position.Z)
                                                                    self:QueueTween(hrp, fieldPos, true)
                                                                    
                                                                    local startWait = os.clock()
                                                                    while self.processingTween and self.autoFarmEnabled do
                                                                        if os.clock() - startWait > 60 then
                                                                            print("DEBUG QUEST: ❌ Return to field timeout!")
                                                                            self:ClearTweenQueue()
                                                                            break
                                                                        end
                                                                        wait(0.1)
                                                                    end
                                                                    
                                                                    print("DEBUG QUEST: ✓ Returned to field: " .. returnField)
                                                                    self.selectedOption = returnField
                                                                end
                                                            end
                                                        end
                                                    end
                                                end)
                                                
                                                if not returnSuccess then
                                                    print("DEBUG QUEST: ❌ Failed to return to field")
                                                end
                                            end
                                        end
                                    end
                                else
                                    print("DEBUG QUEST: ❌ Could not find NPC position for: " .. npcName)
                                end
                                
                                -- Resume auto farm
                                self.pausedForTimedAction = false
                                self.status = previousStatus
                                self.needsRedraw = true
                            end
                        else
                            print("DEBUG QUEST: Claim Quest is DISABLED - skipping claim")
                        end
                    -- If has requirement
                    elseif currentQuest.requirement then
                        local requirement = currentQuest.requirement
                        
                        if requirement.type == "pollen" and self.questCollectPollen then
                            print("DEBUG QUEST: === WORKING ON POLLEN REQUIREMENT ===")
                            print("DEBUG QUEST: Quest:", currentQuest.questName)
                            print("DEBUG QUEST: Field:", requirement.field, "| Amount:", requirement.amount)
                            
                            -- Switch to quest field if needed
                            if self.selectedOption ~= requirement.field then
                                -- Always update the saved field to current field before switching
                                self.questOriginalField = self.selectedOption
                                print("DEBUG QUEST: Saved original field:", self.questOriginalField)
                                
                                print("DEBUG QUEST: Switching from '" .. self.selectedOption .. "' to '" .. requirement.field .. "'")
                                self.selectedOption = requirement.field
                                self.sprinklersPlaced = false
                                self.status = "Quest: " .. requirement.field
                                self.needsRedraw = true
                                wait(2)
                            else
                                print("DEBUG QUEST: Already in correct field: " .. requirement.field)
                            end
                            
                        elseif requirement.type == "kill_mob" and self.questKillMobs then
                            print("DEBUG QUEST: === WORKING ON KILL MOB REQUIREMENT ===")
                            print("DEBUG QUEST: Quest:", currentQuest.questName)
                            print("DEBUG QUEST: Mob:", requirement.mob, "| Amount:", requirement.amount)
                            
                            -- Check mob spawner cooldown
                            local spawnerInfo = self:GetMobSpawnerCooldown(requirement.mob)
                            
                            if spawnerInfo then
                                print("DEBUG QUEST: Spawner:", spawnerInfo.spawner)
                                print("DEBUG QUEST: Field:", spawnerInfo.field)
                                print("DEBUG QUEST: Timer:", spawnerInfo.timer)
                                print("DEBUG QUEST: Ready:", tostring(spawnerInfo.ready))
                                
                                if spawnerInfo.ready and spawnerInfo.field then
                                    -- Switch to mob field if needed
                                    if self.selectedOption ~= spawnerInfo.field then
                                        self.questOriginalField = self.selectedOption
                                        print("DEBUG QUEST: Saved original field:", self.questOriginalField)
                                        
                                        print("DEBUG QUEST: Switching to mob field: " .. spawnerInfo.field)
                                        self.selectedOption = spawnerInfo.field
                                        self.sprinklersPlaced = false
                                        self.status = "Quest: Kill " .. requirement.mob
                                        self.needsRedraw = true
                                        wait(2)
                                    else
                                        print("DEBUG QUEST: Already in mob field: " .. spawnerInfo.field)
                                    end
                                else
                                    print("DEBUG QUEST: Mob spawner not ready yet, waiting...")
                                    
                                    -- ✅ NEW: Return to original field while waiting
                                    local returnField = self.questOriginalField
                                    if returnField and returnField ~= "Select Field..." and self.selectedOption ~= returnField then
                                        print("DEBUG QUEST: Returning to auto-farm field while waiting: " .. returnField)
                                        self.selectedOption = returnField
                                        self.sprinklersPlaced = false
                                        self.status = "Auto Farming"
                                        self.needsRedraw = true
                                    end
                                end
                            else
                                print("DEBUG QUEST: ⚠️ Spawner not configured for: " .. requirement.mob .. " - SKIPPING")
                            end
                        end
                    end
                else
                    print("DEBUG QUEST: No quests to work on")
                    
                    -- ✅ NEW: Return to original field when no quest work
                    local returnField = self.questOriginalField
                    if returnField and returnField ~= "Select Field..." and self.selectedOption ~= returnField then
                        print("DEBUG QUEST: No quest tasks - returning to auto-farm field: " .. returnField)
                        self.selectedOption = returnField
                        self.sprinklersPlaced = false
                        self.status = "Auto Farming"
                        self.needsRedraw = true
                    end
                end
                
            end)
            
            if not success then
                print("DEBUG QUEST: ❌ Error:", tostring(err))
            end
            
            print("DEBUG QUEST: Waiting 5 seconds before next check...")
            wait(5)
        end
        
        print("DEBUG QUEST: === AUTO QUEST STOPPED ===")
        self.autoQuestRunning = false
        self.autoQuestThread = nil
    end)
end

function UI:StopAutoQuest()
    print("Stopping Auto Quest...")
    self.autoQuest = false
    self.autoQuestRunning = false
    
    -- Return to original field if one was saved
    if self.questOriginalField and self.questOriginalField ~= "Select Field..." then
        print("DEBUG QUEST: Returning to original field before stopping:", self.questOriginalField)
        self.selectedOption = self.questOriginalField
        self.sprinklersPlaced = false
        self.needsRedraw = true
        
        -- Tween back to original field
        local player = game.Players.LocalPlayer
        local character = player.Character
        if character then
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local flowerZones = game.Workspace.FlowerZones
                if flowerZones then
                    local targetZone = flowerZones:FindFirstChild(self.questOriginalField)
                    if targetZone then
                        local fieldPos = Vector3.new(targetZone.Position.X, targetZone.Position.Y + 10, targetZone.Position.Z)
                        self:QueueTween(hrp, fieldPos, true)
                    end
                end
            end
        end
    end
    
    -- Clear saved field
    self.questOriginalField = nil
    
    if self.autoQuestThread then
        self.autoQuestThread = nil
    end
end



