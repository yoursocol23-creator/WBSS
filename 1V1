function UI:FindNearestHub(position)
    local hubs = {"sunflower_fence_1", "dand_mush_mid", "gate_5_ramp", "Blue_Front"}
    local closestHub = nil
    local closestDistance = math.huge
    
    for _, hubName in ipairs(hubs) do
        local hubPos = self.pathNodes[hubName]
        if hubPos then
            local dx = position.X - hubPos.X
            local dz = position.Z - hubPos.Z
            local distance = math.sqrt(dx * dx + dz * dz)
            
            if distance < closestDistance then
                closestDistance = distance
                closestHub = hubName
            end
        end
    end
    
    return closestHub
end

