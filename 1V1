function UI:WalkToHive()
    self.status = "Finding Hive"
    self.needsRedraw = true
    
    spawn(function()
        local player = game.Players.LocalPlayer
        local character = player.Character
        
        if not character then
            self.status = "Error: No character"
            self.needsRedraw = true
            return
        end
        
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then
            self.status = "Error: No HRP"
            self.needsRedraw = true
            return
        end
        
        local honeycombs = game.Workspace:FindFirstChild("Honeycombs")
        if not honeycombs then
            print("ERROR: Honeycombs not found!")
            self.status = "No Honeycombs!"
            self.needsRedraw = true
            return
        end
        
        -- Check if player already owns a hive (multi-method check)
        for _, hive in pairs(honeycombs:GetChildren()) do
            local owner = hive:FindFirstChild("Owner")
            if owner then
                local isOwned = false
                
                -- Method 1: Direct comparison
                if owner.Value == player then
                    isOwned = true
                end
                
                -- Method 2: Name comparison
                if not isOwned then
                    local success, ownerName = pcall(function() 
                        return owner.Value.Name 
                    end)
                    if success and ownerName == player.Name then
                        isOwned = true
                    end
                end
                
                -- Method 3: String contains name
                if not isOwned then
                    local ownerStr = tostring(owner.Value)
                    if ownerStr:find(player.Name) then
                        isOwned = true
                    end
                end
                
                if isOwned then
                    self.status = "Hive Owned"
                    self.needsRedraw = true
                    return
                end
            end
        end
        
        -- Find unclaimed hive
        local availableHive = nil
        for _, hive in pairs(honeycombs:GetChildren()) do
            local owner = hive:FindFirstChild("Owner")
            if owner then
                local ownerValue = tostring(owner.Value)
                if ownerValue:find("Unreadable_name") then
                    availableHive = hive
                    break
                end
            end
        end
        
        if not availableHive then
            self.status = "No hives available"
            self.needsRedraw = true
            return
        end
        
        self.status = "Claiming " .. availableHive.Name
        self.needsRedraw = true
        
        local hivePart = availableHive:FindFirstChild("Display") or availableHive:FindFirstChildWhichIsA("BasePart")
        if not hivePart then
            print("ERROR: No Display part found")
            return
        end
        
        local hivePos = Vector3.new(hivePart.Position.X, hivePart.Position.Y - 15, hivePart.Position.Z - 15)
        
        WalkTo(hivePos)
        local walkStart = os.clock()
        while IsWalking() do
            if os.clock() - walkStart > 15 then
                StopWalking()
                break
            end
            local hrpNow = character:FindFirstChild("HumanoidRootPart")
            if hrpNow then
                local dx = hrpNow.Position.X - hivePos.X
                local dz = hrpNow.Position.Z - hivePos.Z
                if math.sqrt(dx*dx + dz*dz) < 5 then
                    StopWalking()
                    break
                end
            end
            wait(0.1)
        end
        
        self.status = "Claiming hive..."
        self.needsRedraw = true
        
        wait(0.5)
        
        keypress(0x45)
        wait(0.2)
        keyrelease(0x45)
        
