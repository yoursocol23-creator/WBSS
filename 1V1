function UI:ExecuteNodeAction(nodeName)
    local nodeConfig = self.nodeActions[nodeName]
    if not nodeConfig then return false end
    
    local actionFunc = self.pathActions[nodeConfig.action]
    if not actionFunc then return false end
    
    -- Wait for Roblox to be active
    while not isrbxactive() do
        warn("Roblox not active - waiting to execute action")
        wait(0.5)
    end
    
    print("🎯 Action: " .. nodeConfig.action .. " at " .. nodeName)
    actionFunc()
    return true
end

function UI:PathfindBetweenNodes(startNode, endNode)
    if startNode == endNode then
        return {startNode}
    end
    
    
    local distances = {}
    local previous = {}
    local unvisited = {}
    
    for nodeName, _ in pairs(self.pathNodes) do
        distances[nodeName] = math.huge
        unvisited[nodeName] = true
    end
    
    distances[startNode] = 0
    
    while next(unvisited) do
        local currentNode = nil
        local smallestDistance = math.huge
        
        for nodeName, _ in pairs(unvisited) do
            if distances[nodeName] < smallestDistance then
                smallestDistance = distances[nodeName]
                currentNode = nodeName
            end
        end
        
        if not currentNode or smallestDistance == math.huge then
            print("ERROR: No path found - disconnected graph")
            break
        end
        
        if currentNode == endNode then
            local path = {}
            local node = endNode
            local totalDistance = distances[endNode]
            
            while node do
                table.insert(path, 1, node)
                node = previous[node]
            end
            
            print("Found path with total distance: " .. string.format("%.1f", totalDistance) .. " studs")
            print("Path: " .. table.concat(path, " → "))
            return path
        end
        
        unvisited[currentNode] = nil
        
        local neighbors = self.pathConnections[currentNode]
        if neighbors then
            for _, neighborName in ipairs(neighbors) do
                if unvisited[neighborName] then
                    local currentPos = self.pathNodes[currentNode]
                    local neighborPos = self.pathNodes[neighborName]
                    
                    local dx = neighborPos.X - currentPos.X
                    local dz = neighborPos.Z - currentPos.Z
                    local edgeDistance = math.sqrt(dx * dx + dz * dz)
                    -- Special case: area_10_cannon to spawn is a cannon shot (shorter distance)
                    if (currentNode == "area_10_cannon" and neighborName == "spawn") then
                        edgeDistance = 10
                    end
                    
                    local newDistance = distances[currentNode] + edgeDistance
                    
                    if newDistance < distances[neighborName] then
                        distances[neighborName] = newDistance
                        previous[neighborName] = currentNode
                    end
                end
            end
        end
    end
    
    print("ERROR: No path from " .. startNode .. " to " .. endNode)
    return nil
end

function UI:WalkPath(pathNodes)
    
    -- CRITICAL: Stop any existing walking operations before starting new path
    print("DEBUG WALKPATH: Stopping any existing walks before starting new path")
    StopWalking()
    wait(0.3)
    
    -- Also clear any tween queue to prevent interference
    if self.processingTween then
        print("DEBUG WALKPATH: Clearing existing tween queue")
        self:ClearTweenQueue()
        wait(0.2)
    end
    
    local player = game.Players.LocalPlayer
    local character = player.Character
    if not character then 
        print("ERROR: No character")
        return false 
    end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then 
        print("ERROR: No HRP")
        return false 
    end
    
    for i = 1, #pathNodes do
        local targetPos = self.pathNodes[pathNodes[i]]
        if not targetPos then
            print("ERROR: Invalid node " .. pathNodes[i])
            return false
        end
        hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then
            print("ERROR: Lost HRP during walk")
            return false
        end
        
        local currentPos = hrp.Position
        local dx = targetPos.X - currentPos.X
        local dz = targetPos.Z - currentPos.Z
        local distance2D = math.sqrt(dx * dx + dz * dz)
        
        print("DEBUG: Distance to node: " .. string.format("%.1f", distance2D) .. " studs")
        
        -- ALWAYS walk to the node first (if far away)
        if distance2D > 10 then
            WalkTo(targetPos)
            
            local startTime = os.clock()
            local loopCount = 0
            local lastStuckCheck = os.clock()
            local lastStuckPos = hrp.Position
            local lastDistance = distance2D
            
            while IsWalking() and self.autoFarmEnabled do
                loopCount = loopCount + 1
                
                if os.clock() - startTime > 30 then
                    print("ERROR: Walk timeout at node " .. pathNodes[i])
                    print("Walk failed, using tween")
                    StopWalking()
                    
                    -- Use tween as fallback
                    hrp = character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        self:QueueTween(hrp, targetPos, true)
                        while self.processingTween and self.autoFarmEnabled do
                            wait(0.1)
                        end
                    end
                    break
                end
                
                hrp = character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    currentPos = hrp.Position
                    dx = currentPos.X - targetPos.X
                    dz = currentPos.Z - targetPos.Z
                    distance2D = math.sqrt(dx * dx + dz * dz)
                    
                    if loopCount % 10 == 0 then
                        print("DEBUG: Distance to target: " .. string.format("%.1f", distance2D) .. " studs")
                    end
                    
                    -- Check if stuck OR overshooting (not moving for 3 seconds)
                    if os.clock() - lastStuckCheck >= 3 then
                        local stuckDx = currentPos.X - lastStuckPos.X
                        local stuckDz = currentPos.Z - lastStuckPos.Z
                        local movedSinceCheck = math.sqrt(stuckDx * stuckDx + stuckDz * stuckDz)
                        
                        -- Also check if distance stopped decreasing (stuck against wall)
                        local distanceChange = math.abs(distance2D - lastDistance)
                        
                        if movedSinceCheck < 2 and distanceChange < 0.5 then
                            print("⚠️ STUCK/OVERSHOOT DETECTED! Moved " .. string.format("%.1f", movedSinceCheck) .. " studs, distance changed " .. string.format("%.1f", distanceChange))
                            StopWalking()
                            
                            -- Check if we overshot (past the target)
                            local dotProduct = (targetPos.X - currentPos.X) * (targetPos.X - lastStuckPos.X) + 
                                             (targetPos.Z - currentPos.Z) * (targetPos.Z - lastStuckPos.Z)
                            
                            print("DEBUG STUCK: DotProduct = " .. string.format("%.2f", dotProduct))
                            print("DEBUG STUCK: Current node index = " .. i .. "/" .. #pathNodes)
                            print("DEBUG STUCK: Current node name = " .. pathNodes[i])
                            print("DEBUG STUCK: Distance to target = " .. string.format("%.1f", distance2D))
                            
                            -- If already within 15 studs, just mark as arrived and move on
                            if distance2D < 15 then
                                print("✓ Close enough (" .. string.format("%.1f", distance2D) .. " studs), marking as arrived")
                                print("✓ Arrived at " .. pathNodes[i])
                                break
                            end
                            
                            -- Distance too far, need to tween
                            if dotProduct < 0 then
                                print(" OVERSHOOT DETECTED - tweening back to node")
                            else
                                print(" STUCK - tweening to current node: " .. pathNodes[i])
                            end
                            
                            hrp = character:FindFirstChild("HumanoidRootPart")
                            if not hrp then
                                print("ERROR: Lost HRP during stuck handling")
                                return false
                            end
                            
                            -- Clear any existing tweens first
                            print("DEBUG STUCK: Clearing existing tweens...")
                            self:ClearTweenQueue()
                            wait(0.3)
                            
                            -- Queue the tween
                            print("DEBUG STUCK: Queueing tween to " .. pathNodes[i])
                            local tweenSuccess = pcall(function()
                                self:QueueTween(hrp, targetPos, true)
                            end)
                            
                            if not tweenSuccess then
                                print("ERROR: Failed to queue tween, marking as arrived anyway")
                                break
                            end
                            
                            print("DEBUG STUCK: Waiting for tween to complete (max 15s)...")
                            
                            -- Wait for tween with simpler logic
                            local tweenStartTime = os.clock()
                            local maxTweenWait = 15
                            
                            while self.autoFarmEnabled do
                                local elapsed = os.clock() - tweenStartTime
                                
                                -- Timeout check
                                if elapsed > maxTweenWait then
                                    print("ERROR: Tween timeout after 15s, force exiting")
                                    self:ClearTweenQueue()
                                    break
                                end
                                
                                -- Progress logging
                                if math.floor(elapsed * 10) % 20 == 0 then
                                    print("DEBUG STUCK: Waiting... (" .. string.format("%.1f", elapsed) .. "s)")
                                end
                                
                                -- Check if we're no longer processing OR if we've arrived
                                hrp = character:FindFirstChild("HumanoidRootPart")
                                if hrp then
                                    local checkPos = hrp.Position
                                    local cdx = checkPos.X - targetPos.X
                                    local cdz = checkPos.Z - targetPos.Z
                                    local checkDist = math.sqrt(cdx * cdx + cdz * cdz)
                                    
                                    -- If we got close enough, consider it done
                                    if checkDist < 10 then
                                        print("DEBUG STUCK: Close enough now (" .. string.format("%.1f", checkDist) .. " studs)")
                                        self:ClearTweenQueue()
                                        break
                                    end
                                    
                                    -- If no longer processing and still far, something's wrong
                                    if not self.processingTween and checkDist > 10 then
                                        print("WARNING: Tween stopped but still " .. string.format("%.1f", checkDist) .. " studs away")
                                        -- Try one more time
                                        if elapsed < 5 then
                                            print("DEBUG STUCK: Retrying tween...")
                                            self:QueueTween(hrp, targetPos, true)
                                        else
                                            print("DEBUG STUCK: Giving up, marking as arrived")
                                            break
                                        end
                                    end
                                    
                                    -- If processing stopped and we're close, we're done
                                    if not self.processingTween then
                                        print("DEBUG STUCK: Tween processing stopped")
                                        break
                                    end
                                else
                                    print("ERROR: Lost HRP during tween wait")
                                    self:ClearTweenQueue()
                                    return false
                                end
                                
                                wait(0.1)
                            end
                            
                            print("✓ Tween handling complete, arrived at " .. pathNodes[i])
                            break  -- Exit inner walk loop and continue to next node
                        end
                        
                        lastStuckCheck = os.clock()
                        lastStuckPos = currentPos
                        lastDistance = distance2D
                    end
                    
                    if distance2D < 4 then
                        print("✓ Arrived at " .. pathNodes[i])
                        StopWalking()
                        break
                    end
                end
                wait(0.1)
            end
            StopWalking()
            wait(0.1)  -- Small delay before next node
        end
        
        local nodeConfig = self.nodeActions[pathNodes[i]]
        if nodeConfig and nodeConfig.action == "pressE" then
            print("🎯 Cannon node detected: " .. pathNodes[i])
            
            print("Waiting 1s before pressing E")
            wait(1)
            
            while not isrbxactive() do
                warn("Roblox not active - waiting to press E")
                wait(0.5)
            end
            
            print("Pressing E to activate cannon...")
            self:ExecuteNodeAction(pathNodes[i])
            
            print("Waiting 2s for cannon launch...")
            wait(2)
            
            print("✓ Cannon launch complete")
        
        elseif nodeConfig and i < #pathNodes then
            local nextNodePos = self.pathNodes[pathNodes[i + 1]]
            if nextNodePos then
                local retryCount = 0
                local maxRetries = 3
                local jumpSuccess = false
                
                while retryCount < maxRetries and not jumpSuccess do
                    hrp = character:FindFirstChild("HumanoidRootPart")
                    if not hrp then
                        print("ERROR: Lost HRP before jump")
                        return false
                    end
                    
                    WalkTo(nextNodePos)
                    wait(0.1)
                    
                    local preJumpPos = hrp.Position
                    
                    self:ExecuteNodeAction(pathNodes[i])
                    
                    local progressTimer = 0
                    local lastCheckPos = preJumpPos
                    local totalMoved = 0
                    local stuckCounter = 0
                    
                    while progressTimer < 2 and IsWalking() and self.autoFarmEnabled do
                        wait(0.1)
                        progressTimer = progressTimer + 0.1
                        
                        hrp = character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local currentCheckPos = hrp.Position
                            local dx = currentCheckPos.X - lastCheckPos.X
                            local dy = currentCheckPos.Y - lastCheckPos.Y
                            local dz = currentCheckPos.Z - lastCheckPos.Z
                            local movedThisCheck = math.sqrt(dx * dx + dy * dy + dz * dz)
                            
                            totalMoved = totalMoved + movedThisCheck
                            
                            if movedThisCheck < 0.5 then
                                stuckCounter = stuckCounter + 1
                                if stuckCounter >= 5 then
                                    break
                                end
                            else
                                stuckCounter = 0
                            end

                            -- Check for death
                            local player = game.Players.LocalPlayer
                            local character = player.Character
                            if not character then
                                print("ERROR: Character lost during walk (death detected)")
                                StopWalking()
                                return false
                            end
                            
                            lastCheckPos = currentCheckPos
                            
                            local dxNext = currentCheckPos.X - nextNodePos.X
                            local dzNext = currentCheckPos.Z - nextNodePos.Z
                            local distToNext = math.sqrt(dxNext * dxNext + dzNext * dzNext)
                            
                            if distToNext < 10 then
                                jumpSuccess = true
                                StopWalking()
                                break
                            end
                        end
                    end
                    
                    if not jumpSuccess then
                        if totalMoved > 10 then
                            jumpSuccess = true
                        else
                            retryCount = retryCount + 1
                            StopWalking()
                            print("Jump failed (stuck, only moved " .. string.format("%.1f", totalMoved) .. " studs), retry " .. retryCount .. "/" .. maxRetries)
                            
                            if retryCount < maxRetries then
                                wait(0.5)
                            end
                        end
                    end
                end
                
                if not jumpSuccess then
                    hrp = character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        StopWalking()
                        self:QueueTween(hrp, nextNodePos, true)
                        while self.processingTween and self.autoFarmEnabled do
                            wait(0.1)
                        end
                        print("✓ Tweened over to " .. pathNodes[i + 1])
                    end
                end
            end
        end
    end
    return true
end

