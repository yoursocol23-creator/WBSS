local function getRequestFunction()
    local env = nil
    pcall(function()
        if type(getgenv) == "function" then
            env = getgenv()
        end
    end)

    if type(request) == "function" then
        return request
    end
    if type(httprequest) == "function" then
        return httprequest
    end
    if type(http_request) == "function" then
        return http_request
    end
    if env then
        if type(env.request) == "function" then
            return env.request
        end
        if type(env.httprequest) == "function" then
            return env.httprequest
        end
        if type(env.http_request) == "function" then
            return env.http_request
        end
    end
    if syn and type(syn.request) == "function" then
        return syn.request
    end
    if http and type(http.request) == "function" then
        return http.request
    end
    if fluxus and type(fluxus.request) == "function" then
        return fluxus.request
    end
    return nil
end

local function sendExecutionEvent(scriptName)
    if type(ANALYTICS_URL) ~= "string" or ANALYTICS_URL == "" then
        if ANALYTICS_DEBUG then
            warn("[Windy Loader Analytics] skipped: no analytics url configured")
        end
        return false
    end

    local username = "Unknown"
    if LocalPlayer and type(LocalPlayer.Name) == "string" and LocalPlayer.Name ~= "" then
        username = LocalPlayer.Name
    end

    local payload = {
        username = username,
        script = tostring(scriptName or "Unknown"),
        executedAt = os.time(),
    }

    local bodyOk, body = pcall(function()
        return HttpService:JSONEncode(payload)
    end)
    if not bodyOk or type(body) ~= "string" then
        if ANALYTICS_DEBUG then
            warn("[Windy Loader Analytics] failed: could not encode payload for " .. tostring(scriptName or "Unknown"))
        end
        return false
    end

    if ANALYTICS_DEBUG then
        warn("[Windy Loader Analytics] sending username=" .. tostring(username) .. " script=" .. tostring(scriptName or "Unknown"))
    end

    task.spawn(function()
        local ok = false
        local response = nil

        if game and type(game.HttpPost) == "function" then
            ok, response = pcall(function()
                return game:HttpPost(
                    ANALYTICS_URL,
                    body,
                    "application/json"
                )
            end)
            if ANALYTICS_DEBUG then
                if ok then
                    warn("[Windy Loader Analytics] HttpPost response body=" .. tostring(response))
                else
                    warn("[Windy Loader Analytics] HttpPost error: " .. tostring(response))
                end
            end
        else
            local requestFn = getRequestFunction()
            if type(requestFn) ~= "function" then
                if ANALYTICS_DEBUG then
                    warn("[Windy Loader Analytics] skipped: no supported request function or HttpPost")
                end
                return
            end

            ok, response = pcall(function()
                return requestFn({
                    Url = ANALYTICS_URL,
                    Method = "POST",
                    Headers = {
                        ["Content-Type"] = "application/json",
                    },
                    Body = body,
                })
            end)
            if ANALYTICS_DEBUG then
                if not ok then
                    warn("[Windy Loader Analytics] request error: " .. tostring(response))
                else
                    local statusCode = response and (response.StatusCode or response.Status or response.status_code) or "unknown"
                    local statusBody = response and (response.Body or response.body or "") or ""
                    warn("[Windy Loader Analytics] response status=" .. tostring(statusCode) .. " body=" .. tostring(statusBody))
                end
            end
        end

        if ANALYTICS_DEBUG and not ok then
            if game and type(game.HttpPost) == "function" then
                -- already logged above
            else
                -- already logged above
            end
        end
    end)

    return true
end


