function UI:StartTrainSnail()
    if self.trainSnailRunning then
        print("Train Snail already running!")
        return
    end

    local DEBUG_STUMP_CROSSHAIR = true
    local lastScanDebug = 0

    local recentHandledSpots = {}
    local HANDLED_RADIUS = 7
    local HANDLED_TTL = 1.5

    local function dprint(...)
        if DEBUG_STUMP_CROSSHAIR then
            print("[STUMP CROSSHAIR]", ...)
        end
    end

    local function CleanHandledSpots()
        local now = os.clock()

        for i = #recentHandledSpots, 1, -1 do
            local spot = recentHandledSpots[i]
            if now - spot.time > HANDLED_TTL then
                table.remove(recentHandledSpots, i)
            end
        end
    end

    local function AddHandledSpot(pos)
        if not pos then return end

        table.insert(recentHandledSpots, {
            x = pos.X,
            z = pos.Z,
            time = os.clock()
        })

        dprint(
            "BLACKLIST SPOT:",
            "x=" .. string.format("%.1f", pos.X),
            "z=" .. string.format("%.1f", pos.Z),
            "ttl=" .. tostring(HANDLED_TTL) .. "s"
        )
    end

    local function IsHandledSpot(pos)
        if not pos then return false end

        CleanHandledSpots()

        for _, spot in ipairs(recentHandledSpots) do
            local dx = pos.X - spot.x
            local dz = pos.Z - spot.z
            local dist = Vector3.new(dx, 0, dz).Magnitude

            if dist <= HANDLED_RADIUS then
                return true
            end
        end

        return false
    end

    local function GetFullPath(obj)
        local path = obj.Name
        local parent = obj.Parent

        while parent and parent ~= game do
            path = parent.Name .. "." .. path
            parent = parent.Parent
        end

        return "game." .. path
    end

    local function HasBadAncestor(obj)
        local particles = game.Workspace:FindFirstChild("Particles")
        local parent = obj.Parent

        while parent and parent ~= particles and parent ~= game do
            if parent.Name == "PetalShuriken" then
                return true
            end

            parent = parent.Parent
        end

        return false
    end

    local function GetStumpCrosshairs(hrp, fieldPos, fieldSize)
        local particles = game.Workspace:FindFirstChild("Particles")
        if not particles or not hrp then
            return {}
        end

        CleanHandledSpots()

        local hrpPos = hrp.Position
        local found = {}

        local totalDesc = 0
        local totalCrosshair = 0
        local accepted = 0
        local blacklisted = 0
        local rejected = 0
        local rejectedPetal = 0

        local xLimit = math.max(fieldSize.X / 2, 150)
        local zLimit = math.max(fieldSize.Z / 2, 150)
        local yLimit = 140

        -- Descendants are needed because real stump crosshairs are not always direct children.
        -- But PetalShuriken descendants are fake/moving crosshairs, so ignore them.
        for _, obj in pairs(particles:GetDescendants()) do
            totalDesc = totalDesc + 1

            if obj.Name == "Crosshair" and obj:IsA("BasePart") and obj.Parent then
                totalCrosshair = totalCrosshair + 1

                if HasBadAncestor(obj) then
                    rejectedPetal = rejectedPetal + 1
                    continue
                end

                local pos = obj.Position

                local dxField = math.abs(pos.X - fieldPos.X)
                local dzField = math.abs(pos.Z - fieldPos.Z)
                local dyField = math.abs(pos.Y - fieldPos.Y)

                local insideX = dxField <= xLimit
                local insideZ = dzField <= zLimit
                local closeY = dyField <= yLimit

                if insideX and insideZ and closeY then
                    if IsHandledSpot(pos) then
                        blacklisted = blacklisted + 1
                    else
                        accepted = accepted + 1

                        local dx = hrpPos.X - pos.X
                        local dz = hrpPos.Z - pos.Z
                        local distSquared = dx * dx + dz * dz

                        table.insert(found, {
                            part = obj,
                            pos = pos,
                            distSquared = distSquared,
                            dist = Vector3.new(dx, 0, dz).Magnitude,
                            path = GetFullPath(obj)
                        })
                    end
                else
                    rejected = rejected + 1
                end
            end
        end

        table.sort(found, function(a, b)
            return a.distSquared < b.distSquared
        end)

        local now = os.clock()
        if DEBUG_STUMP_CROSSHAIR and now - lastScanDebug >= 0.35 then
            lastScanDebug = now

            dprint(
                "scan DESC FILTERED:",
                "desc=" .. totalDesc,
                "crosshair=" .. totalCrosshair,
                "accepted=" .. accepted,
                "blacklisted=" .. blacklisted,
                "rejected=" .. rejected,
                "rejectedPetal=" .. rejectedPetal,
                "validNow=" .. #found,
                "handledSpots=" .. #recentHandledSpots
            )

            for i, data in ipairs(found) do
                dprint(
                    "#" .. i,
                    "dist=" .. string.format("%.1f", data.dist),
                    "pos=" .. tostring(data.pos),
                    data.path
                )
            end
        end

        return found
    end

    local function WalkToCrosshairGroup(character, hrp, fieldPos, fieldSize)
        local handledCount = 0
        local maxHandleCount = 12
        local groupStart = os.clock()

        while self.trainSnail and self.trainSnailRunning do
            hrp = character:FindFirstChild("HumanoidRootPart")
            if not hrp then
                dprint("STOP GROUP: lost HRP")
                StopWalking()
                break
            end

            local crosshairs = GetStumpCrosshairs(hrp, fieldPos, fieldSize)

            if #crosshairs <= 0 then
                if handledCount > 0 then
                    dprint("GROUP DONE: handled", handledCount, "crosshair(s)")
                end

                StopWalking()
                break
            end

            if handledCount >= maxHandleCount then
                dprint("GROUP STOP: hit maxHandleCount", maxHandleCount)
                StopWalking()
                break
            end

            if os.clock() - groupStart > 8 then
                dprint("GROUP STOP: timeout after 8s, handled", handledCount)
                StopWalking()
                break
            end

            local targetData = crosshairs[1]
            local crosshair = targetData.part

            if not crosshair or not crosshair.Parent then
                AddHandledSpot(targetData.pos)
                task.wait(0.02)
                continue
            end

            if HasBadAncestor(crosshair) then
                dprint("SKIP: PetalShuriken crosshair", targetData.path)
                AddHandledSpot(crosshair.Position)
                task.wait(0.02)
                continue
            end

            handledCount = handledCount + 1

            local startPos = crosshair.Position
            AddHandledSpot(startPos)

            dprint(
                "TARGET",
                handledCount,
                "dist=" .. string.format("%.1f", targetData.dist),
                "pos=" .. tostring(startPos),
                targetData.path
            )

            local crosshairPos = crosshair.Position
            local targetPos = Vector3.new(crosshairPos.X, hrp.Position.Y, crosshairPos.Z)

            self.status = "Walking to Stump Crosshair " .. tostring(handledCount)
            self.needsRedraw = true

            StopWalking()
            WalkTo(targetPos)

            local walkStart = os.clock()
            local lastWalkDebug = 0
            local reached = false

            while self.trainSnail and self.trainSnailRunning and crosshair and crosshair.Parent do
                hrp = character:FindFirstChild("HumanoidRootPart")
                if not hrp then
                    dprint("STOP TARGET: lost HRP")
                    StopWalking()
                    break
                end

                if HasBadAncestor(crosshair) then
                    dprint("STOP TARGET: PetalShuriken crosshair ignored")
                    StopWalking()
                    break
                end

                crosshairPos = crosshair.Position
                targetPos = Vector3.new(crosshairPos.X, hrp.Position.Y, crosshairPos.Z)

                if WalkToService then
                    WalkToService.currentTarget = targetPos
                end

                local currentPos = hrp.Position
                local dx = currentPos.X - crosshairPos.X
                local dz = currentPos.Z - crosshairPos.Z
                local distSquared = dx * dx + dz * dz
                local dist = Vector3.new(dx, 0, dz).Magnitude

                if os.clock() - lastWalkDebug >= 0.45 then
                    lastWalkDebug = os.clock()

                    dprint(
                        "walking target",
                        handledCount,
                        "dist=" .. string.format("%.1f", dist),
                        "isWalking=" .. tostring(IsWalking()),
                        "target=" .. tostring(crosshairPos)
                    )
                end

                if distSquared < 20.25 then -- 4.5 studs
                    dprint("REACHED target", handledCount, "dist=" .. string.format("%.1f", dist))
                    reached = true
                    StopWalking()
                    break
                end

                if os.clock() - walkStart > 3.5 then
                    dprint("TARGET TIMEOUT", handledCount, "dist=" .. string.format("%.1f", dist))
                    StopWalking()
                    break
                end

                if not IsWalking() then
                    WalkTo(targetPos)
                end

                task.wait(0.04)
            end

            if not crosshair or not crosshair.Parent then
                dprint("TARGET DESPAWNED", handledCount)
            elseif not reached then
                dprint("SKIPPING target", handledCount, "after timeout/not reached")
            end

            StopWalking()
            task.wait(0.02)
        end

        return handledCount > 0
    end

    self.trainSnailRunning = true
    self.status = "Train Snail Active"
    self.needsRedraw = true

    task.spawn(function()
        while self.trainSnail and self.trainSnailRunning do
            local success, err = pcall(function()
                local player = game.Players.LocalPlayer
                local character = player.Character

                if not character then
                    task.wait(1)
                    return
                end

                local hrp = character:FindFirstChild("HumanoidRootPart")
                if not hrp then
                    task.wait(1)
                    return
                end

                local flowerZones = GetFlowerZonesFolder()
                if not flowerZones then
                    task.wait(1)
                    return
                end

                local stumpField = GetFlowerZone("Stump Field")
                if not stumpField then
                    print("ERROR: Stump Field not found")
                    task.wait(5)
                    return
                end

                local hrpPos = hrp.Position
                local fieldPos = stumpField.Position
                local fieldSize = stumpField.Size

                local withinX = math.abs(hrpPos.X - fieldPos.X) <= fieldSize.X / 2
                local withinZ = math.abs(hrpPos.Z - fieldPos.Z) <= fieldSize.Z / 2
                local withinY = math.abs(hrpPos.Y - fieldPos.Y) <= 50
                local inField = withinX and withinZ and withinY

                if inField then
                    local innerZoneX = fieldSize.X / 4
                    local innerZoneZ = fieldSize.Z / 4

                    self.status = "Training at Stump Field"
                    self.needsRedraw = true

                    hrp = character:FindFirstChild("HumanoidRootPart")
                    if not hrp then
                        task.wait(0.2)
                        return
                    end

                    -- PRIORITY 1:
                    -- Real stump crosshairs.
                    -- Uses descendants, but filters PetalShuriken.
                    -- Ignores 50% safe zone for crosshairs.
                    local handledCrosshairs = WalkToCrosshairGroup(character, hrp, fieldPos, fieldSize)

                    if handledCrosshairs then
                        task.wait(0.03)
                        return
                    end

                    -- No real crosshairs found, now enforce 50% safe zone.
                    hrpPos = hrp.Position

                    local withinInnerX = math.abs(hrpPos.X - fieldPos.X) <= innerZoneX
                    local withinInnerZ = math.abs(hrpPos.Z - fieldPos.Z) <= innerZoneZ
                    local inInnerZone = withinInnerX and withinInnerZ

                    if not inInnerZone then
                        self.status = "Returning to Safe Zone"
                        self.needsRedraw = true

                        StopWalking()

                        local centerPos = Vector3.new(fieldPos.X, fieldPos.Y + 10, fieldPos.Z)
                        self:QueueTween(hrp, centerPos, true)

                        self:WaitForTween(60, function() return self.trainSnail end)

                        task.wait(0.5)
                        return
                    end

                    -- PRIORITY 2:
                    -- Normal token logic still uses the 50% inner safe zone.
                    local collectibles = game.Workspace:FindFirstChild("Collectibles")
                    if collectibles then
                        hrp = character:FindFirstChild("HumanoidRootPart")

                        if hrp then
                            local hrpPos2 = hrp.Position
                            local closestToken = nil
                            local closestDistance = math.huge

                            for _, token in pairs(collectibles:GetChildren()) do
                                if token.Name == "C" and token:IsA("BasePart") and token.Parent then
                                    if token.Transparency >= 0.2 then
                                        continue
                                    end

                                    local tokenPos = token.Position

                                    if tokenPos and type(tokenPos) == "userdata" then
                                        local posX, posY, posZ = GetPosition(token)

                                        if posX and posY and posZ then
                                            local tokenInnerX = math.abs(posX - fieldPos.X) <= innerZoneX
                                            local tokenInnerZ = math.abs(posZ - fieldPos.Z) <= innerZoneZ

                                            if tokenInnerX and tokenInnerZ then
                                                local dy = math.abs(hrpPos2.Y - posY)

                                                if dy <= 10 then
                                                    local dx = hrpPos2.X - posX
                                                    local dz = hrpPos2.Z - posZ
                                                    local distSquared = dx * dx + dz * dz

                                                    if distSquared < 2500 and distSquared < closestDistance then
                                                        closestDistance = distSquared
                                                        closestToken = Vector3.new(posX, posY, posZ)
                                                    end
                                                end
                                            end
                                        end
                                    end
                                end
                            end

                            if closestToken then
                                WalkTo(closestToken)
                                task.wait(0.5)
                                StopWalking()
                            else
                                task.wait(0.2)
                            end
                        end
                    else
                        task.wait(0.2)
                    end
                else
                    self.status = "Going to Stump Field"
                    self.needsRedraw = true

                    local centerPos = Vector3.new(fieldPos.X, fieldPos.Y + 10, fieldPos.Z)
                    self:QueueTween(hrp, centerPos, true)

                    self:WaitForTween(60, function() return self.trainSnail end)
                end
            end)

            if not success then
                print("ERROR in Train Snail: " .. tostring(err))
                task.wait(2)
            end

            task.wait(0.05)
        end

        self.trainSnailRunning = false
        self.status = "Stopped"
        self.needsRedraw = true
    end)
end

