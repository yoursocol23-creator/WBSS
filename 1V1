    local contentY = 80
    
    self:CreateText("Quests & NPCs", contentX, contentY, Color3.fromRGB(255, 255, 255), 20)
    
    contentY = contentY + 40
    
    -- Claim Quest toggle
    local value = self.claimQuest or false
    
    self:CreateRect(contentX, contentY, 196, 22, Color3.fromRGB(30, 35, 45))
    self:CreateText("Claim Quest", contentX + 8, contentY + 6, Color3.fromRGB(200, 210, 220), 12)
    
    local switchX = contentX + 170
    local switchColor = value and Color3.fromRGB(16, 185, 129) or Color3.fromRGB(60, 70, 85)
    self:CreateRect(switchX, contentY + 6, 20, 10, switchColor)
    
    local circleX = value and switchX + 12 or switchX + 1
    self:CreateRect(circleX, contentY + 7, 7, 7, Color3.fromRGB(255, 255, 255))
    
    self:RegisterButton(contentX, contentY, 196, 22, function()
        self.claimQuest = not self.claimQuest
        self.needsRedraw = true
    end)
    
    contentY = contentY + 28
    
    -- Auto Quest toggle
    local value = self.autoQuest or false

    self:CreateRect(contentX, contentY, 196, 22, Color3.fromRGB(30, 35, 45))
    self:CreateText("Auto Quest", contentX + 8, contentY + 6, Color3.fromRGB(200, 210, 220), 12)

    local switchX = contentX + 170
    local switchColor = value and Color3.fromRGB(16, 185, 129) or Color3.fromRGB(60, 70, 85)
    self:CreateRect(switchX, contentY + 6, 20, 10, switchColor)

    local circleX = value and switchX + 12 or switchX + 1
    self:CreateRect(circleX, contentY + 7, 7, 7, Color3.fromRGB(255, 255, 255))

    self:RegisterButton(contentX, contentY, 196, 22, function()
        if not self.autoFarmEnabled and not self.autoQuest then
            notify("Windy - Auto Quest", "Turn on Auto Farm first", "8")
            return
        end
        
        self.autoQuest = not self.autoQuest
        self.needsRedraw = true
        
        if self.autoQuest then
            self:StartAutoQuest()
        else
            self:StopAutoQuest()
        end
    end)
        
