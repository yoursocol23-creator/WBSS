UI.spawnerTimerTracking = {}  

function UI:GetMobSpawnerCooldown(mobName)
    local monsterSpawners = game.Workspace:FindFirstChild("MonsterSpawners")
    if not monsterSpawners then
        return nil
    end
    
    local foundSpawners = {}
    local currentTime = os.clock()
    
    for spawnerName, spawnerData in pairs(self.mobSpawners) do
        
        if spawnerData.mob == mobName then
            
            local spawner = monsterSpawners:FindFirstChild(spawnerName)
            if spawner then
                
                -- Get field from Territory
                local territory = spawner:FindFirstChild("Territory")
                if territory then
                    if territory.Value then
                        -- âœ… FIX: Extract the Name from the Instance
                        if type(territory.Value) == "string" then
                            spawnerData.field = territory.Value
                        elseif territory.Value.Name then
                            spawnerData.field = territory.Value.Name
                        else
                            spawnerData.field = tostring(territory.Value)
                        end
                    else
                        print("DEBUG SPAWNER: Territory exists but Value is nil")
                    end
                else
                    print("DEBUG SPAWNER: Territory not found in spawner")
                end
                
                -- Get timer
                local attachment = spawner:FindFirstChild("Attachment")
                if attachment then
                    
                    local timerGui = attachment:FindFirstChild("TimerGui")
                    if timerGui then
                        
                        local timerLabel = timerGui:FindFirstChild("TimerLabel")
                        if timerLabel then
                            
                            if timerLabel.Text then
                                local text = timerLabel.Text
                                
                                local _, colonCount = string.gsub(text, ":", "")
                                
                                -- 1:00 = READY like 50/50
                                local isReady = (colonCount == 1)
                                
                                if not isReady and (string.find(text, "1s") or string.find(text, "2s") or string.find(text, "3s")) then
                                    if not self.spawnerTimerTracking[spawnerName] then
                                        self.spawnerTimerTracking[spawnerName] = {
                                            lastText = text,
                                            stuckSince = currentTime
                                        }
                                        print("DEBUG SPAWNER:   Started tracking stuck timer: '" .. text .. "'")
                                    else
                                        local tracked = self.spawnerTimerTracking[spawnerName]
                                        
                                        -- If timer text changed, reset tracking
                                        if tracked.lastText ~= text then
                                            tracked.lastText = text
                                            tracked.stuckSince = currentTime
                                            print("DEBUG SPAWNER:   Timer changed, reset tracking: '" .. text .. "'")
                                        else
                                            -- Timer hasn't changed - check how long it's been stuck
                                            local stuckDuration = currentTime - tracked.stuckSince
                                            print("DEBUG SPAWNER:   Timer stuck at '" .. text .. "' for " .. string.format("%.1f", stuckDuration) .. "s")
                                            
                                            if stuckDuration >= 10 then
                                                print("DEBUG SPAWNER: Timer stuck for 10 marking as READY")
                                                isReady = true
                                            end
                                        end
                                    end
                                else
                                    if self.spawnerTimerTracking[spawnerName] then
                                        self.spawnerTimerTracking[spawnerName] = nil
                                    end
                                end
                                
                                
                                local spawnerInfo = {
                                    spawner = spawnerName,
                                    field = spawnerData.field,
                                    timer = text,
                                    ready = isReady
                                }
                                
                                table.insert(foundSpawners, spawnerInfo)
                                
                                -- If this spawner is ready, return it immediately
                                if isReady then
                                    print("DEBUG SPAWNER:   Spawner:", spawnerName)
                                    print("DEBUG SPAWNER:   Field:", spawnerData.field)
                                    return spawnerInfo
                                end
                            else
                                print("DEBUG SPAWNER: âŒ TimerLabel.Text is nil")
                            end
                        else
                            print("DEBUG SPAWNER: âŒ TimerLabel not found in TimerGui")
                        end
                    else
                        print("DEBUG SPAWNER: âŒ TimerGui not found in Attachment")
                    end
                else
                    print("DEBUG SPAWNER: âŒ Attachment not found in spawner")
                end
            else
                print("DEBUG SPAWNER: âŒ Spawner instance not found: '" .. spawnerName .. "'")
            end
        end
    end
    
    if #foundSpawners > 0 then
        print("DEBUG SPAWNER: No ready spawners, returning first found (on cooldown)")
        print("DEBUG SPAWNER:   Spawner:", foundSpawners[1].spawner)
        print("DEBUG SPAWNER:   Timer:", foundSpawners[1].timer)
        return foundSpawners[1]
    end
    
    print("DEBUG SPAWNER: âŒ No spawners found for mob:", mobName)
    return nil
end

function UI:ParseQuestRequirement(taskText)
    print("DEBUG PARSER: === PARSING TASK ===")
    print("DEBUG PARSER: Raw text: '" .. taskText .. "'")
    
    -- Parse "Collect [Amount] Pollen from the [Field]. [Progress]/[Amount]"
    local amount, field = string.match(taskText, "Collect ([%d,]+) Pollen from the (.-)%.")
    
    if amount and field then
        -- Remove commas from amount
        amount = tonumber((amount:gsub(",", "")))
        -- Trim whitespace from field name
        field = field:match("^%s*(.-)%s*$")
        
        print("DEBUG PARSER: Field pollen requirement detected")
        print("DEBUG PARSER:   Field:", field)
        print("DEBUG PARSER:   Amount:", amount)
        return {
            type = "pollen",
            field = field,
            amount = amount
        }
    end
    
    local amount, color = string.match(taskText, "Collect ([%d,]+) ([%a]+) Pollen%.")
    
    if amount and color then
        -- Remove commas from amount
        amount = tonumber((amount:gsub(",", "")))
        
        -- Map color to field
        local colorToField = {
            ["White"] = "Dandelion Field",
            ["Red"] = "Mushroom Field",
            ["Blue"] = "Blue Flower Field"
        }
        
        local field = colorToField[color]
        
        if field then
            print("DEBUG PARSER:   Color pollen requirement detected")
            print("DEBUG PARSER:   Color:", color)
            print("DEBUG PARSER:   Field:", field)
            print("DEBUG PARSER:   Amount:", amount)
            return {
                type = "pollen",
                field = field,
                amount = amount,
                color = color
            }
        else
            print("DEBUG PARSER: âŒ Unknown pollen color:", color)
        end
    end
    
    -- Parse "Defeat [Amount] [Mob Name]. [Progress]/[Total]"
    local amount, mobName = string.match(taskText, "Defeat (%d+) ([%a%s]+)%.")
    
    if amount and mobName then
        amount = tonumber(amount)
        mobName = mobName:match("^%s*(.-)%s*$") -- Trim whitespace
        
        print("DEBUG PARSER:   Kill mob requirement detected")
        print("DEBUG PARSER:   Mob:", mobName)
        print("DEBUG PARSER:   Amount:", amount)
        return {
            type = "kill_mob",
            mob = mobName,
            amount = amount
        }
    end
    
    print("DEBUG PARSER: âŒ No pattern matched - unknown task type")
    return nil
end

