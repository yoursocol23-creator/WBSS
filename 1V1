function UI:StartConfigNameInput()
    if self.configNameInputActive then 
        return 
    end
    
    self.configNameInputActive = true
    self.configNameText = self.configNameText or ""
    
    task.spawn(function()
        local lastKeyStates = {}
        local loopCount = 0
        
        
        while self.configNameInputActive and self.isRunning do
            loopCount = loopCount + 1
            
            -- If dropdown opens, stop typing immediately
            if self.savedConfigDropdownOpen then
                self.configNameInputActive = false
                self.needsRedraw = true
                break
            end
            
            -- Freeze player movement
            pcall(function()
                local player = game.Players.LocalPlayer
                local character = player.Character
                if character then
                    local hrp = character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        hrp.Velocity = Vector3.new(0, 0, 0)
                        hrp.RotVelocity = Vector3.new(0, 0, 0)
                    end
                end
            end)
            
            
            -- Backspace (0x08)
            local backspacePressed = iskeypressed(0x08)
            if backspacePressed and not lastKeyStates[0x08] then
                if #self.configNameText > 0 then
                    self.configNameText = self.configNameText:sub(1, -2)
                    self.needsRedraw = true
                end
            end
            lastKeyStates[0x08] = backspacePressed
            
            -- Enter (0x0D)
            local enterPressed = iskeypressed(0x0D)
            if enterPressed and not lastKeyStates[0x0D] then
                self.configNameInputActive = false
                self.needsRedraw = true
                break
            end
            lastKeyStates[0x0D] = enterPressed
            
            -- Escape (0x1B)
            local escapePressed = iskeypressed(0x1B)
            if escapePressed and not lastKeyStates[0x1B] then
                self.configNameText = ""
                self.configNameInputActive = false
                self.needsRedraw = true
                break
            end
            lastKeyStates[0x1B] = escapePressed
            
            -- Shift (0x10)
            local shiftHeld = iskeypressed(0x10)
            
            -- Space (0x20)
            local spacePressed = iskeypressed(0x20)
            if spacePressed and not lastKeyStates[0x20] then
                if #self.configNameText < 30 then
                    self.configNameText = self.configNameText .. " "
                    self.needsRedraw = true
                end
            end
            lastKeyStates[0x20] = spacePressed
            
            -- Letters A-Z (0x41-0x5A)
            for keycode = 0x41, 0x5A do
                local keyPressed = iskeypressed(keycode)
                if keyPressed and not lastKeyStates[keycode] then
                    if #self.configNameText < 30 then
                        local letter = string.char(keycode)
                        if not shiftHeld then
                            letter = letter:lower()
                        end
                        self.configNameText = self.configNameText .. letter
                        self.needsRedraw = true
                    else
                        print("Character limit reached (30)")
                    end
                end
                lastKeyStates[keycode] = keyPressed
            end
            
            -- Numbers 0-9 (0x30-0x39)
            for keycode = 0x30, 0x39 do
                local keyPressed = iskeypressed(keycode)
                if keyPressed and not lastKeyStates[keycode] then
                    if #self.configNameText < 30 then
                        self.configNameText = self.configNameText .. string.char(keycode)
                        self.needsRedraw = true
                    end
                end
                lastKeyStates[keycode] = keyPressed
            end
            
            -- Minus/Underscore (0xBD)
            local minusPressed = iskeypressed(0xBD)
            if minusPressed and not lastKeyStates[0xBD] then
                if #self.configNameText < 30 then
                    local char = shiftHeld and "_" or "-"
                    self.configNameText = self.configNameText .. char
                    self.needsRedraw = true
                end
            end
            lastKeyStates[0xBD] = minusPressed
            
            task.wait(0.05)
        end
        
    end)
end
function UI:ExportConfig(customName)
    local config = {}
    for _, key in ipairs(self.configKeys) do
        local val = self[key]
        if val ~= nil then
            config[key] = val
        end
    end
    
    local parts = {}
    for k, v in pairs(config) do
        local valStr
        if type(v) == "boolean" then
            valStr = tostring(v)
        elseif type(v) == "number" then
            valStr = tostring(v)
        elseif type(v) == "string" then
            valStr = '"' .. v:gsub('"', '\\"'):gsub(" ", "%%SPACE%%") .. '"'
        end
        if valStr then
            table.insert(parts, k .. "=" .. valStr)
        end
    end
    
    table.sort(parts)
    local configStr = "WINDYCFG:{" .. table.concat(parts, ",") .. "}"
    
    if not isfolder(CONFIG_FOLDER) then
        makefolder(CONFIG_FOLDER)
    end
    
    local filename
    if customName and #customName > 0 then
        -- Use custom name (sanitize it)
        local sanitized = customName:gsub("[^%w%s%-_]", ""):gsub("%s+", "_")
        filename = CONFIG_FOLDER .. "/" .. sanitized .. CONFIG_EXTENSION
    else
        -- Auto-generate numbered name
        local index = 1
        while isfile(CONFIG_FOLDER .. "/Main_" .. index .. CONFIG_EXTENSION) do
            index = index + 1
        end
        filename = CONFIG_FOLDER .. "/Main_" .. index .. CONFIG_EXTENSION
        customName = "Main_" .. index
    end
    
    writefile(filename, configStr)
    
    self.selectedSavedConfig = customName
    self:RefreshSavedConfigs()
    
    print("Config saved to: " .. filename)
    self.status = "Saved as " .. customName .. "!"
    self.needsRedraw = true
    
    task.spawn(function()
        task.wait(3)
        if self.status == "Saved as " .. customName .. "!" then
            self.status = "Ready"
            self.needsRedraw = true
        end
    end)
end

function UI:RefreshSavedConfigs()
    self.savedConfigs = {}
    
    if not isfolder(CONFIG_FOLDER) then
        makefolder(CONFIG_FOLDER)
        return
    end
    
    local files = listfiles(CONFIG_FOLDER)
    for _, filepath in ipairs(files) do
        if filepath:match(CONFIG_EXTENSION .. "$") then
            -- Extract just the filename
            local filename = filepath:match("([^/\\]+)$")
            table.insert(self.savedConfigs, {
                name = filename:gsub(CONFIG_EXTENSION, ""),
                path = filepath
            })
        end
    end
    
    -- Sort by name (most recent first due to timestamp)
    table.sort(self.savedConfigs, function(a, b)
        return a.name > b.name
    end)
end

function UI:ImportConfig(configName)
    if not isfolder(CONFIG_FOLDER) then
        makefolder(CONFIG_FOLDER)
    end
    
    local configPath
    if configName and configName ~= "None" then
        configPath = CONFIG_FOLDER .. "/" .. configName .. CONFIG_EXTENSION
    else
        -- Fallback: load Main_1 if it exists, else old Main
        if isfile(CONFIG_FOLDER .. "/Main_1" .. CONFIG_EXTENSION) then
            configPath = CONFIG_FOLDER .. "/Main_1" .. CONFIG_EXTENSION
        else
            configPath = CONFIG_FOLDER .. "/Main" .. CONFIG_EXTENSION
        end
    end
    
    -- Read from file
    if not isfile(configPath) then
        warn("Config file not found: " .. configPath)
        notify("Windy - Config", "Config file not found: WindyConfigs/Main.cfg", 8)
        self.status = "No save found!"
        self.needsRedraw = true
        task.spawn(function()
            task.wait(3)
            if self.status == "No save found!" then
                self.status = "Ready"
                self.needsRedraw = true
            end
        end)
        return false
    end
    
    local configStr = readfile(configPath)
    -- DON'T strip all spaces - keep the format intact
    
    if not configStr:match("^WINDYCFG:{") then
        warn("Invalid config format!")
        self.status = "Invalid config!"
        self.needsRedraw = true
        return false
    end
    
    local content = configStr:match("^WINDYCFG:{(.+)}$")
    if not content then
        warn("Failed to parse config!")
        self.status = "Parse failed!"
        self.needsRedraw = true
        return false
    end
    
    local validKeys = {}
    for _, k in ipairs(self.configKeys) do
        validKeys[k] = true
    end
    
    local loaded = 0
    local errors = 0
    
    local pos = 1
    local len = #content
    
    while pos <= len do
        local keyStart = pos
        local eqPos = content:find("=", pos, true)
        if not eqPos then break end
        
        local key = content:sub(keyStart, eqPos - 1)
        pos = eqPos + 1
        
        local value = nil
        local nextPos = nil
        
        if content:sub(pos, pos) == '"' then
            local valStart = pos + 1
            local p = valStart
            while p <= len do
                if content:sub(p, p) == '"' and content:sub(p-1, p-1) ~= '\\' then
                    break
                end
                p = p + 1
            end
            local rawVal = content:sub(valStart, p - 1)
            -- FIXED: Restore spaces
            value = rawVal:gsub('\\"', '"'):gsub("%%SPACE%%", " ")
            nextPos = p + 2
        else
            local commaPos = content:find(",", pos, true)
            if commaPos then
                value = content:sub(pos, commaPos - 1)
                nextPos = commaPos + 1
            else
                value = content:sub(pos)
                nextPos = len + 1
            end
            
            if value == "true" then
                value = true
            elseif value == "false" then
                value = false
            else
                value = tonumber(value)
            end
        end
        
        if validKeys[key] and value ~= nil then
            self[key] = value
            loaded = loaded + 1
        elseif not validKeys[key] then
            warn("Unknown config key: " .. tostring(key))
            errors = errors + 1
        end
        
        pos = nextPos or (len + 1)
    end
    
    if self.tweenMethod then
        TweenService.currentMethod = self.tweenMethod
    end
    
    print("Config loaded " .. loaded .. " values, " .. errors .. " unknown keys")
    self.status = "Config loaded!"
    self.sprinklersPlaced = false
    self.needsRedraw = true
    
    -- NEW: Actually start autofarm if it was enabled in config
    if self.autoFarmEnabled then
        self:StartAutoFarm()
    end
    
    if self.catchCoconuts then
        self:StartCatchCoconuts()
    end

    task.spawn(function()
        task.wait(3)
        if self.status == "Config loaded!" then
            self.status = "Ready"
            self.needsRedraw = true
        end
    end)
    
    return true
end

function UI:StartCatchCoconuts()
    if self.catchCoconutsRunning then return end
    self.catchCoconutsRunning = true
    self.coconutActive = false

    task.spawn(function()
        while self.catchCoconuts and self.catchCoconutsRunning and self.autoFarmEnabled do
            local P = game.Workspace:FindFirstChild("Particles")
            local disks = {}

            if P then
                local total = 0
                local rejected = 0
                local character = game.Players.LocalPlayer.Character
                local hrp = character and character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    for _, c in pairs(P:GetChildren()) do
                        if c.Name == "WarningDisk" and c.Parent then
                            total = total + 1
                            -- PRIORITY: Skip if stars are being caught
                            if c.Size.X < 20 and self.starActive then
                                rejected = rejected + 1
                            elseif c.Size.X >= 20 then
                                local dx = hrp.Position.X - c.Position.X
                                local dz = hrp.Position.Z - c.Position.Z
                                table.insert(disks, {disk = c, dist = Vector3.new(dx, 0, dz).Magnitude, pos = c.Position})
                            else
                                rejected = rejected + 1
                            end
                        end
                    end
                end
            end

            if #disks > 0 then
                if not self.coconutActive then
                    self.coconutActive = true
                    StopWalking()
                    self:ClearTweenQueue()
                end

                table.sort(disks, function(a, b) return a.dist < b.dist end)

                for _, data in ipairs(disks) do
                    if not data.disk.Parent then
                        continue
                    end


                    -- Walk to disk
                    local t = os.clock()
                    while self.catchCoconuts and self.catchCoconutsRunning and self.autoFarmEnabled do
                        if not data.disk.Parent then 
                            break 
                        end
                        if os.clock() - t > 8 then
                            break
                        end
                        local character2 = game.Players.LocalPlayer.Character
                        local hrp2 = character2 and character2:FindFirstChild("HumanoidRootPart")
                        if hrp2 then
                            local dx = hrp2.Position.X - data.pos.X
                            local dz = hrp2.Position.Z - data.pos.Z
                            if Vector3.new(dx, 0, dz).Magnitude < 5 then
                                break
                            end
                        end
                        WalkTo(Vector3.new(data.pos.X, data.pos.Y, data.pos.Z))
                        task.wait(0.1)
                    end

                    local waitT = os.clock()
                    while data.disk.Parent and self.catchCoconuts and self.catchCoconutsRunning and self.autoFarmEnabled do
                        if os.clock() - waitT > 10 then
                            break
                        end
                        WalkTo(Vector3.new(data.pos.X, data.pos.Y, data.pos.Z))
                        task.wait(0.1)
                    end
                end
                
            else
                if self.coconutActive then
                    self.coconutActive = false
                end
            end

            task.wait(0.05)
        end

        self.coconutActive = false
        self.catchCoconutsRunning = false
    end)
