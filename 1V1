function UI:GetScriptImageData(index)
    local scriptInfo = SCRIPTS[index]
    if not scriptInfo or type(scriptInfo.imageUrl) ~= "string" or scriptInfo.imageUrl == "" then
        return nil
    end

    if self._scriptImageState[index] == "failed" then
        return nil
    end

    if self._scriptImageData[index] then
        return self._scriptImageData[index]
    end

    if self._scriptImageState[index] == "loading" then
        return nil
    end

    self._scriptImageState[index] = "loading"
    task.spawn(function()
        local ok, data = pcall(function()
            return game:HttpGet(scriptInfo.imageUrl)
        end)
        if ok and type(data) == "string" and data ~= "" then
            self._scriptImageData[index] = data
            self._scriptImageState[index] = "ready"
            self.needsRedraw = true
        else
            self._scriptImageState[index] = "failed"
        end
    end)

    return nil
end

function UI:SetListScroll(newScroll)
    local maxScroll = math.max(0, self.listMaxScroll or 0)
    local clamped = math.max(0, math.min(maxScroll, newScroll or 0))
    if math.abs(clamped - (self.listScroll or 0)) > 0.5 then
        self.listScroll = clamped
        self.needsRedraw = true
    else
        self.listScroll = clamped
    end
end

function UI:SetFeatureScroll(newScroll)
    local maxScroll = math.max(0, self.featureMaxScroll or 0)
    local clamped = math.max(0, math.min(maxScroll, newScroll or 0))
    if math.abs(clamped - (self.featureScroll or 0)) > 0.5 then
        self.featureScroll = clamped
        self.needsRedraw = true
    else
        self.featureScroll = clamped
    end
end

runScriptSource = function(source, scriptName)
    if type(loadstring) ~= "function" then
        notifyMessage("Loader Error", "Executor is missing loadstring")
        return false
    end

    if type(source) ~= "string" or source == "" then
        notifyMessage("Missing Source", tostring(scriptName or "Script"))
        return false
    end

    local chunk, compileErr = loadstring(source)
    if not chunk then
        notifyMessage("Compile Failed", tostring(compileErr))
        return false
    end

    local okRun, runErr = pcall(chunk)
    if not okRun then
        notifyMessage("Runtime Error", tostring(runErr))
        return false
    end

    notifyMessage("Loaded", tostring(scriptName or "Script"))
    return true
end

function UI:Render()
    self:Clear()

    if (self.appearAlpha or 0) <= 0.01 then
        self.needsRedraw = false
        return
    end

    local x        = self.window.x
    local y        = self.window.y + math.floor(self.appearOffset + 0.5)
    local w        = self.window.width
    local h        = self.window.height
    local sidebarW = self.window.sidebarWidth
    local selected = SCRIPTS[self.selectedIndex] or SCRIPTS[1]

    local headerH  = 34
    local sidebarX = x + 8
    local sidebarY = y + headerH + 8
    local sidebarH = h - headerH - 16

    local contentX = x + sidebarW + 18
    local contentY = y + headerH + 8
    local contentW = w - sidebarW - 26
    local contentH = h - headerH - 16

    local footerH   = 38
    local mainCardX = contentX + 10
    local mainCardY = contentY + 10
    local mainCardW = contentW - 20
    local mainCardH = contentH - footerH - 22
    local footerY   = contentY + contentH - footerH

    self:CreateSquare(x, y, w, h, Theme.bg, true)
    self:CreateSquare(x, y, w, h, Theme.border, false, 1)

    self:CreateSquare(x, y, w, headerH, Theme.shell, true)
    self:CreateLine(x + 1, y + 1, x + w - 2, y + 1, Theme.topHighlight, 1)
    self:CreateLine(x, y + headerH, x + w, y + headerH, Theme.borderSoft, 1)
    self:CreateText("WINDY LOADER",   x + 12,  y + 9,  Theme.text,     14, false)
    self:CreateText("v1.0.6", x + 118, y + 10, Theme.textMuted, 13, false)

    local closeHovered = self.hoveredId == "close"
    local closeX = x + w - 30
    local closeY = y + 7
    self:CreateSquare(closeX, closeY, 18, 18, closeHovered and Theme.panelHover or Theme.shell, true)
    self:CreateSquare(closeX, closeY, 18, 18, Theme.border, false, 1)
    self:CreateText("X", closeX + 9, closeY + 8, closeHovered and Theme.accent or Theme.textDim, 12, true)
    self:RegisterHitbox("close", closeX, closeY, 18, 18, function()
        self.isRunning = false
        self:HideAll()
        self:Clear()
    end)

    self:RegisterHitbox("drag", x, y, w - 34, headerH, function()
        local mp = self:GetMouseLocation()
        self.draggingWindow = true
        self.dragOffsetX = mp.X - self.window.x
        self.dragOffsetY = mp.Y - self.window.y
    end)

    self:CreateSquare(sidebarX, sidebarY, sidebarW, sidebarH, Theme.panel, true)
    self:CreateSquare(sidebarX, sidebarY, sidebarW, sidebarH, Theme.border, false, 1)
    -- image
    local drewImage = false
    if self._logoData then
        local ok, img = pcall(Drawing.new, "Image")
        if ok and img then
            local applied = pcall(function()
                local alpha = math.max(0, math.min(1, self.appearAlpha or 1))
                img.Position = Vector2.new(sidebarX + 10, sidebarY + 10)
                img.Size     = Vector2.new(28, 28)
                img.Data     = self._logoData
                img.Transparency = alpha
                img.Visible  = true
            end)
            if applied then
                self:_track(img)
                drewImage = true
            else
                pcall(function() img:Remove() end)
                self._logoData = nil
            end
        end
    end
    if not drewImage then
        self:CreateSquare(sidebarX + 10, sidebarY + 10, 28, 28, Theme.accent, true)
        self:CreateText("W", sidebarX + 24, sidebarY + 14, Color3.fromRGB(10, 10, 10), 13, true)
    end
    self:CreateText("WINDY",  sidebarX + 46, sidebarY + 9,  Theme.text,    13, false)
    self:CreateText("LOADER", sidebarX + 46, sidebarY + 23, Theme.textDim, 13, false)

    self:CreateLine(sidebarX + 10, sidebarY + 48, sidebarX + sidebarW - 10, sidebarY + 48, Theme.borderSoft, 1)
    self:CreateText("GAMES", sidebarX + 10, sidebarY + 56, Theme.textMuted, 12, false)

    local rowH = 30
    local rowGap = 6
    local listStartY = sidebarY + 78
    local listBottomPadding = 10
    local scrollTrackW = 6
    local scrollTrackX = sidebarX + sidebarW - 12
    local listClipX = sidebarX + 8
    local listClipY = listStartY
    local listClipW = sidebarW - 24
    local listClipH = math.max(20, (sidebarY + sidebarH - listBottomPadding) - listStartY)
    local contentHeight = (#SCRIPTS * rowH) + (math.max(0, #SCRIPTS - 1) * rowGap)
    local maxScroll = math.max(0, contentHeight - listClipH)
    self.listMaxScroll = maxScroll
    self.listScroll = math.max(0, math.min(maxScroll, self.listScroll or 0))
    self.listMetrics = {
        trackX = scrollTrackX,
        trackY = listClipY,
        trackW = scrollTrackW,
        trackH = listClipH,
    }

    for index, scriptInfo in ipairs(SCRIPTS) do
        local buttonId   = "script_" .. tostring(index)
        local hovered    = self.hoveredId == buttonId
        local isSelected = self.selectedIndex == index
        local rowAnim    = self:GetRowAnim(index)
        local rowY = listStartY + ((index - 1) * (rowH + rowGap)) - self.listScroll
        local rowX = sidebarX + 8
        local rowW = sidebarW - 24

        if rowY + rowH >= listClipY and rowY <= listClipY + listClipH then
            local fillBase   = isSelected and Theme.panelActive or Theme.panel
            local fillHover  = isSelected and blendColor(Theme.panelActive, Theme.accentDark, 0.35) or Theme.panelHover
            local fillColor  = blendColor(fillBase, fillHover, rowAnim)
            local borderColor = isSelected and blendColor(Theme.accentDark, Theme.accent, rowAnim * 0.45) or blendColor(Theme.borderSoft, Theme.border, rowAnim)
            local textColor  = isSelected and blendColor(Theme.text, Theme.accent, rowAnim * 0.12) or blendColor(Theme.textDim, Theme.text, rowAnim)

            self:CreateSquare(rowX, rowY, rowW, rowH, fillColor, true)
            self:CreateSquare(rowX, rowY, rowW, rowH, borderColor, false, 1)
            if isSelected then
                self:CreateSquare(rowX, rowY, 3, rowH, blendColor(Theme.accentDark, Theme.accent, 0.55 + (rowAnim * 0.45)), true)
            end
            self:CreateText(
                scriptInfo.name,
                rowX + 10, rowY + 8,
                textColor,
                12, false
            )
            self:RegisterHitbox(buttonId, rowX, rowY, rowW, rowH, function()
                self.selectedIndex = index
                self.needsRedraw   = true
            end)
        end
    end

    self:CreateSquare(scrollTrackX, listClipY, scrollTrackW, listClipH, Theme.panel2, true)
    self:CreateSquare(scrollTrackX, listClipY, scrollTrackW, listClipH, Theme.borderSoft, false, 1)
    if maxScroll > 0 then
        local thumbH = math.max(28, math.floor((listClipH / contentHeight) * listClipH))
        local thumbTravel = math.max(0, listClipH - thumbH)
        local thumbY = listClipY + math.floor((self.listScroll / maxScroll) * thumbTravel + 0.5)
        local scrollHovered = self.hoveredId == "games_scroll"
        self:CreateSquare(scrollTrackX + 1, thumbY, scrollTrackW - 2, thumbH, scrollHovered and Theme.accent or Theme.border, true)
        self:RegisterHitbox("games_scroll", scrollTrackX - 2, thumbY, scrollTrackW + 4, thumbH, function()
            local mp = self:GetMouseLocation()
            self.draggingScroll = true
            self.dragScrollOffsetY = mp.Y - thumbY
        end)
    end

    self:CreateSquare(contentX, contentY, contentW, contentH, Theme.panel, true)
    self:CreateSquare(contentX, contentY, contentW, contentH, Theme.border, false, 1)
    self:CreateSquare(mainCardX, mainCardY, mainCardW, mainCardH, Theme.panel2, true)
    self:CreateSquare(mainCardX, mainCardY, mainCardW, mainCardH, Theme.borderSoft, false, 1)

    local selectedImageX = mainCardX + 12
    local selectedImageY = mainCardY + 18
    local selectedImageSize = 58
    local selectedTextX = selectedImageX + selectedImageSize + 16

    self:CreateSquare(selectedImageX, selectedImageY, selectedImageSize, selectedImageSize, Theme.panel, true)
    self:CreateSquare(selectedImageX, selectedImageY, selectedImageSize, selectedImageSize, Theme.border, false, 1)

    local selectedImageData = self:GetScriptImageData(self.selectedIndex)
    local selectedDrewImage = false
    if selectedImageData then
        local ok, img = pcall(Drawing.new, "Image")
        if ok and img then
            local applied = pcall(function()
                local alpha = math.max(0, math.min(1, self.appearAlpha or 1))
                img.Position = Vector2.new(selectedImageX + 4, selectedImageY + 4)
                img.Size = Vector2.new(selectedImageSize - 8, selectedImageSize - 8)
                img.Data = selectedImageData
                img.Transparency = alpha
                img.Visible = true
            end)
            if applied then
                self:_track(img)
                selectedDrewImage = true
            else
                pcall(function() img:Remove() end)
            end
        end
    end
    if not selectedDrewImage then
        self:CreateSquare(selectedImageX + 10, selectedImageY + 10, selectedImageSize - 20, selectedImageSize - 20, Theme.accentDark, true)
        self:CreateText("W", selectedImageX + math.floor(selectedImageSize * 0.5), selectedImageY + 18, Theme.accent, 18, true)
    end

    self:CreateText("SELECTED SCRIPT", selectedTextX, mainCardY + 14, Theme.textMuted, 12, false)
    self:CreateText(selected.name or "Unknown", selectedTextX, mainCardY + 40, Theme.text, 17, false)

    local featuresBoxY = mainCardY + 96
    local featuresBoxBottom = footerY - 32
    local featuresBoxH = math.max(92, featuresBoxBottom - featuresBoxY)
    local features = selected.features or {}

    self:CreateSquare(mainCardX + 12, featuresBoxY, mainCardW - 24, featuresBoxH, Theme.panel, true)
    self:CreateSquare(mainCardX + 12, featuresBoxY, mainCardW - 24, featuresBoxH, Theme.border, false, 1)
    self:CreateText("FEATURES", mainCardX + 22, featuresBoxY + 12, Theme.textMuted, 12, false)

    local featureTrackW = 6
    local featureTrackX = mainCardX + mainCardW - 20
    local featureListX = mainCardX + 22
    local featureListY = featuresBoxY + 34
    local featureListW = mainCardW - 54
    local featureLineH = 16
    local featureContentH = #features * featureLineH
    local featureClipH = featuresBoxH - 42
    local featureMaxScroll = math.max(0, featureContentH - featureClipH)
    self.featureMaxScroll = featureMaxScroll
    self.featureScroll = math.max(0, math.min(featureMaxScroll, self.featureScroll or 0))
    self.featureMetrics = {
        trackX = featureTrackX,
        trackY = featureListY - 2,
        trackW = featureTrackW,
        trackH = featureClipH + 4,
        areaX = featureListX,
        areaY = featureListY,
        areaW = featureListW,
        areaH = featureClipH,
    }

    self:CreateSquare(featureTrackX, featureListY - 2, featureTrackW, featureClipH + 4, Theme.panel2, true)
    self:CreateSquare(featureTrackX, featureListY - 2, featureTrackW, featureClipH + 4, Theme.borderSoft, false, 1)

    if #features == 0 then
        self:CreateText("No features listed", featureListX, featureListY, Theme.textDim, 12, false)
    else
        for i = 1, #features do
            local lineY = featureListY + ((i - 1) * featureLineH) - self.featureScroll
            if lineY + featureLineH >= featureListY and lineY <= featureListY + featureClipH then
                self:CreateText("- " .. tostring(features[i]), featureListX, lineY, Theme.text, 12, false)
            end
        end

        if featureMaxScroll > 0 then
            local featureThumbH = math.max(24, math.floor((featureClipH / featureContentH) * featureClipH))
            local featureThumbTravel = math.max(0, featureClipH - featureThumbH)
            local featureThumbY = featureListY + math.floor((self.featureScroll / featureMaxScroll) * featureThumbTravel + 0.5)
            local featureScrollHovered = self.hoveredId == "features_scroll"
            self:CreateSquare(featureTrackX + 1, featureThumbY, featureTrackW - 2, featureThumbH, featureScrollHovered and Theme.accent or Theme.border, true)
            self:RegisterHitbox("features_scroll", featureTrackX - 2, featureThumbY, featureTrackW + 4, featureThumbH, function()
                local mp = self:GetMouseLocation()
                self.draggingFeatureScroll = true
                self.dragFeatureScrollOffsetY = mp.Y - featureThumbY
            end)
        end
    end

    self:CreateText("Scripts: " .. tostring(#SCRIPTS), mainCardX + 12, mainCardY + mainCardH - 20, Theme.textMuted, 12, false)

    local loadHovered = self.hoveredId == "load_selected"
    local loadAnim = self:GetButtonAnim("load_selected")
    local loadPressAnim = self:GetButtonPressAnim("load_selected")
    local loadX = contentX + 10
    local loadY = footerY
    local loadW = contentW - 20
    local loadH = 28

    local pressOffset = math.floor((loadPressAnim * 2) + 0.5)
    local btnShadowColor = blendColor(Theme.panel2, Theme.accentDark, loadAnim * 0.2)
    local btnColor = blendColor(Theme.accent, Theme.accentDark, (loadAnim * 0.35) + (loadPressAnim * 0.4))
    local btnBorderColor = blendColor(Theme.border, Theme.accentDark, loadAnim * 0.35)
    local btnTextColor = blendColor(Color3.fromRGB(255, 255, 255), Color3.fromRGB(230, 255, 230), loadAnim * 0.2)

    if loadPressAnim < 0.95 then
        self:CreateSquare(loadX, loadY + 2, loadW, loadH, btnShadowColor, true)
    end
    self:CreateSquare(loadX, loadY + pressOffset, loadW, loadH, btnColor, true)
    self:CreateSquare(loadX, loadY + pressOffset, loadW, loadH, btnBorderColor, false, 1)
    self:CreateSquare(loadX + 1, loadY + pressOffset + 1, loadW - 2, 1, blendColor(Theme.topHighlight, Color3.fromRGB(255, 255, 255), loadAnim * 0.18), true)
    self:CreateText("LOAD SCRIPT", loadX + (loadW * 0.5), loadY + 14 + pressOffset, btnTextColor, 13, true)

    self:RegisterHitbox("load_selected", loadX, loadY, loadW, loadH + 2, function()
        if type(selected.source) == "string" and selected.source ~= "" then
            self:ShutdownForLaunch(selected.source, selected.name)
        end
    end)

    self.needsRedraw = false
end

local steppedConn
local lastMouseDown = false
local lastZDown = false
local lastUpDown = false
local lastDownDown = false

steppedConn = RunService.RenderStepped:Connect(function(dt)
    if not UI.isRunning then
        steppedConn:Disconnect()
        return
    end

    dt = math.min(dt or 0.016, 0.05)

    local mp = UI:GetMouseLocation()
    local mx, my = mp.X, mp.Y
    local mouseDown = false
    local downOk, downValue = pcall(function()
        return ismouse1pressed()
    end)
    if downOk then
        mouseDown = downValue == true
    end

    local upDown = false
    local upOk, upValue = pcall(function()
        return UserInputService:IsKeyDown(Enum.KeyCode.Up)
    end)
    if upOk then
        upDown = upValue == true
    end

    local downArrowDown = false
    local downArrowOk, downArrowValue = pcall(function()
        return UserInputService:IsKeyDown(Enum.KeyCode.Down)
    end)
    if downArrowOk then
        downArrowDown = downArrowValue == true
    end

    local zDown = false
    local keyOk, keyValue = pcall(function()
        return UserInputService:IsKeyDown(Enum.KeyCode.Z)
    end)
    if keyOk then
        zDown = keyValue == true
    elseif type(iskeydown) == "function" then
        local altOk, altValue = pcall(function()
            return iskeydown(Enum.KeyCode.Z)
        end)
        if altOk then
            zDown = altValue == true
        end
    end

    if zDown and not lastZDown then
        UI.isOpen = not UI.isOpen
        if UI.isOpen then
            UI.needsRedraw = true
        else
            UI.hoveredId = nil
            UI.draggingWindow = false
            UI.draggingScroll = false
            UI.draggingFeatureScroll = false
        end
    end
    lastZDown = zDown

    if UI.isOpen and mouseDown and not lastMouseDown then
        local hb = UI:HitTest(mx, my)
        if hb and hb.onDown then
            hb.onDown()
        end
    end

    if not mouseDown and lastMouseDown then
        UI.draggingWindow = false
        UI.draggingScroll = false
        UI.draggingFeatureScroll = false
    end

    lastMouseDown = mouseDown

    if UI.isOpen and UI.draggingWindow and mouseDown then
        UI.window.x = mx - UI.dragOffsetX
        UI.window.y = my - UI.dragOffsetY
        UI.needsRedraw = true
    end

    if UI.isOpen and UI.draggingScroll and mouseDown and UI.listMetrics and (UI.listMaxScroll or 0) > 0 then
        local metrics = UI.listMetrics
        local contentHeight = (#SCRIPTS * 30) + (math.max(0, #SCRIPTS - 1) * 6)
        local thumbH = math.max(28, math.floor((metrics.trackH / contentHeight) * metrics.trackH))
        local thumbTravel = math.max(0, metrics.trackH - thumbH)
        if thumbTravel > 0 then
            local thumbTop = my - (UI.dragScrollOffsetY or 0)
            local ratio = (thumbTop - metrics.trackY) / thumbTravel
            UI:SetListScroll(ratio * UI.listMaxScroll)
        end
    end

    if UI.isOpen and UI.draggingFeatureScroll and mouseDown and UI.featureMetrics and (UI.featureMaxScroll or 0) > 0 then
        local metrics = UI.featureMetrics
        local featureCount = #(SCRIPTS[UI.selectedIndex] and SCRIPTS[UI.selectedIndex].features or {})
        local featureContentHeight = math.max(1, featureCount * 16)
        local thumbH = math.max(24, math.floor((metrics.areaH / featureContentHeight) * metrics.areaH))
        local thumbTravel = math.max(0, metrics.areaH - thumbH)
        if thumbTravel > 0 then
            local thumbTop = my - (UI.dragFeatureScrollOffsetY or 0)
            local ratio = (thumbTop - metrics.areaY) / thumbTravel
            UI:SetFeatureScroll(ratio * UI.featureMaxScroll)
        end
    end

    if UI.isOpen and UI.listMaxScroll and UI.listMaxScroll > 0 then
        local metrics = UI.listMetrics
        local mouseInList = metrics
            and mx >= (metrics.trackX - 140)
            and mx <= (metrics.trackX + metrics.trackW + 8)
            and my >= metrics.trackY
            and my <= (metrics.trackY + metrics.trackH)

        if mouseInList and upDown and not lastUpDown then
            UI:SetListScroll((UI.listScroll or 0) - 28)
        end
        if mouseInList and downArrowDown and not lastDownDown then
            UI:SetListScroll((UI.listScroll or 0) + 28)
        end
    end

    if UI.isOpen and UI.featureMaxScroll and UI.featureMaxScroll > 0 then
        local metrics = UI.featureMetrics
        local mouseInFeatures = metrics
            and mx >= metrics.areaX
            and mx <= (metrics.trackX + metrics.trackW + 8)
            and my >= (metrics.areaY - 2)
            and my <= (metrics.areaY + metrics.areaH + 2)

        if mouseInFeatures and upDown and not lastUpDown then
            UI:SetFeatureScroll((UI.featureScroll or 0) - 16)
        end
        if mouseInFeatures and downArrowDown and not lastDownDown then
            UI:SetFeatureScroll((UI.featureScroll or 0) + 16)
        end
    end

    lastUpDown = upDown
    lastDownDown = downArrowDown

    local hb = UI.isOpen and UI:HitTest(mx, my) or nil
    local newHover = hb and hb.id or nil
    if newHover ~= UI.hoveredId then
        UI.hoveredId   = newHover
        UI.needsRedraw = true
    end

    local appearTarget = UI.isOpen and 1 or 0
    local nextAlpha = lerp(UI.appearAlpha, appearTarget, math.min(1, dt * 10))
    local offsetTarget = UI.isOpen and 0 or 16
    local nextOffset = lerp(UI.appearOffset, offsetTarget, math.min(1, dt * 10))
    if math.abs(nextAlpha - UI.appearAlpha) > 0.001 then
        UI.appearAlpha = nextAlpha
        UI.needsRedraw = true
    else
        UI.appearAlpha = appearTarget
    end
    if math.abs(nextOffset - UI.appearOffset) > 0.05 then
        UI.appearOffset = nextOffset
        UI.needsRedraw = true
    else
        UI.appearOffset = offsetTarget
    end

    for index = 1, #SCRIPTS do
        local target = 0
        if UI.isOpen and UI.selectedIndex == index then
            target = 1
        elseif UI.isOpen and UI.hoveredId == ("script_" .. tostring(index)) then
            target = 0.65
        end

        local current = UI:GetRowAnim(index)
        local nextValue = lerp(current, target, math.min(1, dt * 14))
        if math.abs(nextValue - current) > 0.001 then
            UI:SetRowAnim(index, nextValue)
            UI.needsRedraw = true
        else
            UI:SetRowAnim(index, target)
        end
    end

    do
        local target = (UI.isOpen and UI.hoveredId == "load_selected") and 1 or 0
        local current = UI:GetButtonAnim("load_selected")
        local nextValue = lerp(current, target, math.min(1, dt * 16))
        if math.abs(nextValue - current) > 0.001 then
            UI:SetButtonAnim("load_selected", nextValue)
            UI.needsRedraw = true
        else
            UI:SetButtonAnim("load_selected", target)
        end
    end

    do
        local target = (UI.isOpen and mouseDown and UI.hoveredId == "load_selected") and 1 or 0
        local current = UI:GetButtonPressAnim("load_selected")
        local nextValue = lerp(current, target, math.min(1, dt * 22))
        if math.abs(nextValue - current) > 0.001 then
            UI:SetButtonPressAnim("load_selected", nextValue)
            UI.needsRedraw = true
        else
            UI:SetButtonPressAnim("load_selected", target)
        end
    end

    if not UI.isOpen and UI.appearAlpha <= 0.02 then
        if #UI._drawings > 0 then
            UI:HideAll()
            UI:Clear()
        end
        UI.needsRedraw = false
        return
    end

    if UI.needsRedraw then
        UI:Render()
    end
end)
UI:Render()
pcall(function()
    notifyMessage("Windy Loader", "Pick a game to load")
end)
