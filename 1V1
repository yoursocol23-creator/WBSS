function UI:CollectDispenser(dispenserKey)
    local config = self.dispenserConfig[dispenserKey]
    
    if not config then
        print("ERROR: Invalid dispenser key: " .. dispenserKey)
        return false
    end
    
    local player = game.Players.LocalPlayer
    local character = player.Character
    
    if not character then
        print("ERROR: No character for " .. config.name)
        return false
    end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        print("ERROR: No HRP for " .. config.name)
        return false
    end
    
    local previousStatus = self.status
    
    self.pausedForTimedAction = true
    StopWalking()
    self:ClearTweenQueue()
    task.wait(0.5)
    
    self.status = "Going to " .. config.name
    self.needsRedraw = true
    
    -- NEW: Check if pathfinding is enabled AND this dispenser supports it
    if self.testWalkEnabled and config.pathfindingNode then
        print("Using pathfinding for " .. config.name)
        
        -- Find closest node to current position
        local closestNode = nil
        local closestDistance = math.huge
        
        for nodeName, nodePos in pairs(self.pathNodes) do
            local dx = hrp.Position.X - nodePos.X
            local dz = hrp.Position.Z - nodePos.Z
            local distance = Vector3.new(dx, 0, dz).Magnitude
            
            if distance < closestDistance then
                closestDistance = distance
                closestNode = nodeName
            end
        end
        
        print("Closest node: " .. tostring(closestNode) .. " (" .. string.format("%.1f", closestDistance) .. " studs)")
        
        if closestNode and self.pathNodes[closestNode] then
            local nodePos = self.pathNodes[closestNode]
            
            print("Walking to closest node for 2s...")
            WalkTo(nodePos)
            
            local walkStart = os.clock()
            while IsWalking() and self.autoFarmEnabled do
                if os.clock() - walkStart > 2 then
                    print("2s timeout, tweening to node instead")
                    StopWalking()
                    self:QueueTween(hrp, nodePos, true)
                    
                    local tweenStart = os.clock()
                    self:WaitForTween(60, function() return self.autoFarmEnabled end)
                    break
                end
                task.wait(0.1)
            end
            
            StopWalking()
            task.wait(0.5)
        end
        
        if closestNode then
            local path = self:PathfindBetweenNodes(closestNode, config.pathfindingNode)
            
            if path then
                -- Check if player died during initial walk
                character = player.Character
                if not character then
                    print("ERROR: Character lost during pathfinding setup")
                    self.pausedForTimedAction = false
                    self.status = previousStatus
                    self.needsRedraw = true
                    return false
                end
                
                local walkSuccess = self:WalkPath(path)
                
                -- Check if player died during pathfinding
                character = player.Character
                if not character then
                    print("ERROR: Character lost during pathfinding")
                    self.pausedForTimedAction = false
                    self.status = previousStatus
                    self.needsRedraw = true
                    return false
                end
                
                if walkSuccess then
                    print("âœ“ Walked to " .. config.name .. " via pathfinding")
                    WalkTo(config.position)
                    local startTime = os.clock()
                    while IsWalking() and self.autoFarmEnabled do
                        local player = game.Players.LocalPlayer
                        local character = player.Character
                        if character then
                            local hrp = character:FindFirstChild("HumanoidRootPart")
                            if hrp then
                                local currentPos = hrp.Position
                                local dx = currentPos.X - config.position.X
                                local dz = currentPos.Z - config.position.Z
                                local distance2D = Vector3.new(dx, 0, dz).Magnitude
                                
                                if distance2D < 2 then
                                    StopWalking()
                                    break
                                end
                            end
                        end
                        
                        if os.clock() - startTime > 10 then
                            StopWalking()
                            break
                        end
                        task.wait(0.1)
                    end
                    StopWalking()
                else
                    print("Pathfinding failed, using tween")
                    self:QueueTween(hrp, config.position, true)
                    
                    local maxWaitTime = 60
                    local startWait = os.clock()
                    
                    self:WaitForTween(60, function() return self.autoFarmEnabled end)
                end
            else
                print("No path found, using tween")
                self:QueueTween(hrp, config.position, true)
                
                local maxWaitTime = 60
                local startWait = os.clock()
                
                self:WaitForTween(60, function() return self.autoFarmEnabled end)
            end
        else
            print("No node found, using tween")
            self:QueueTween(hrp, config.position, true)
            
            local maxWaitTime = 60
            local startWait = os.clock()
            
            self:WaitForTween(60, function() return self.autoFarmEnabled end)
        end
    else
        -- Normal tween (pathfinding disabled or dispenser doesn't support it)
        print("Tweening to " .. config.name .. "...")
        self:QueueTween(hrp, config.position, true)
        
        local maxWaitTime = 60
        local startWait = os.clock()
        
        self:WaitForTween(60, function() return self.autoFarmEnabled end)
    end

    print("âœ“ Arrived at " .. config.name)
    task.wait(0.5)

    while not isrbxactive() and self.autoFarmEnabled do
        warn("Roblox Is Not Active - waiting to collect " .. config.name)
        self.status = "Waiting for Roblox window"
        self.needsRedraw = true
        task.wait(0.5)
    end
    
    if self.autoFarmEnabled then
        self.status = "Collecting " .. config.name
        self.needsRedraw = true
        
        -- Special handling for glue (needs to place sprinkler first)
        if config.specialHandling == "glue" then
            print("Placing glue sprinkler (pressing 2)...")
            keypress(config.key)
            task.wait(0.1)
            keyrelease(config.key)
            task.wait(config.waitAfterPress)
            
            -- Check player's Y level AFTER placing sprinkler
            hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local playerY = hrp.Position.Y
                print("Player Y level: " .. string.format("%.1f", playerY))
                
                if playerY > 10000 then
                    print("Y level > 10k")
                    self.status = "Going to Glue Collection Area"
                    self.needsRedraw = true
                    local glueCollectionPos = Vector3.new(270, 25257, -722)
                    self:QueueTween(hrp, glueCollectionPos, true)
                    local startWait = os.clock()
                    self:WaitForTween(60, function() return self.autoFarmEnabled end)
                    task.wait(1)
                    keypress(0x45)  -- E key
                    task.wait(0.1)
                    keyrelease(0x45)
                    task.wait(1)
                else
                    warn("Y level < 10k,")
                end
            end
            character = player.Character
            if character then
                local humanoid = character:FindFirstChild("Humanoid")
                if humanoid and humanoid.Address then
                    local addr = humanoid.Address
                    local v = Vector3.new(0, 0, 0)
                    memory_write("float", addr + 0x18C + 8, v.Z)
                    print("âœ“ Reset initiated")
                    
                    local respawned = WaitForRespawn(30)
                    
                    if respawned then
                        self.status = "Waiting for bees..."
                        self.needsRedraw = true
                        task.wait(15)
                    else
                        print("ERROR: Failed to respawn after glue")
                    end
                else
                    print("ERROR: Could not reset player - no humanoid address")
                end
            end
            
        elseif config.specialHandling == "beesmas_tokens" then
            print("Pressing E to activate " .. config.name .. "...")
            keypress(config.key)
            task.wait(0.1)
            keyrelease(config.key)
            task.wait(config.waitAfterPress)
            
            print(" " .. config.name .. " activated!")
            print("Waiting For Cutscene")
            
            local collectStartTime = os.clock()
            local recentTokens = {}
            
            while self.autoFarmEnabled and (os.clock() - collectStartTime) < 6 do
                local collectibles = game.Workspace:FindFirstChild("Collectibles")
                if collectibles then
                    character = player.Character
                    if character then
                        hrp = character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local hrpPos = hrp.Position
                            local closestToken = nil
                            local closestDistance = math.huge
                            local foundAnyToken = false
                            
                            for _, token in pairs(collectibles:GetChildren()) do
                                if token.Name == "C" and token:IsA("BasePart") and token.Parent then
                                    if token.Transparency >= 0.2 then
                                        continue
                                    end
                                    local tokenPos = token.Position
                                    if tokenPos then
                                        local isRecent = false
                                        for _, recentPos in ipairs(recentTokens) do
                                            local tdx = math.abs(tokenPos.X - recentPos.X)
                                            local tdy = math.abs(tokenPos.Y - recentPos.Y)
                                            local tdz = math.abs(tokenPos.Z - recentPos.Z)
                                            if tdx < 3 and tdy < 3 and tdz < 3 then
                                                isRecent = true
                                                break
                                            end
                                        end
                                        
                                        if not isRecent then
                                            local dx = hrpPos.X - tokenPos.X
                                            local dy = hrpPos.Y - tokenPos.Y
                                            local dz = hrpPos.Z - tokenPos.Z
                                            local distance = Vector3.new(dx, dy, dz).Magnitude
                                            
                                            -- Check if within 14 studs
                                            if distance <= 14 then
                                                foundAnyToken = true
                                                if distance < closestDistance then
                                                    closestDistance = distance
                                                    closestToken = tokenPos
                                                end
                                            end
                                        end
                                    end
                                end
                            end
                            
                            -- If no tokens within 14 studs, exit early
                            if not foundAnyToken then
                                StopWalking()
                                break
                            end
                            
                            -- Walk to closest token
                            if closestToken then
                                WalkTo(closestToken)
                                
                                local startTime = os.clock()
                                while IsWalking() and self.autoFarmEnabled do
                                    if os.clock() - startTime > 2 then
                                        StopWalking()
                                        break
                                    end
                                    
                                    hrp = character:FindFirstChild("HumanoidRootPart")
                                    if hrp then
                                        local currentPos = hrp.Position
                                        local cdx = currentPos.X - closestToken.X
                                        local cdz = currentPos.Z - closestToken.Z
                                        local distSquared = cdx * cdx + cdz * cdz
                                        
                                        if distSquared < 16 then
                                            StopWalking()
                                            break
                                        end
                                    end
                                    
                                    task.wait(0.05)
                                end
                                
                                StopWalking()
                                
                                table.insert(recentTokens, closestToken)
                                if #recentTokens > 10 then
                                    table.remove(recentTokens, 1)
                                end
                            end
                        end
                    end
                end
                
                task.wait(0.05)
            end
            
            StopWalking()
            print("âœ“ Token collection complete for " .. config.name)
            
        elseif config.specialHandling == "beesmas_snow_machine" then
            keypress(config.key)
            task.wait(0.1)
            keyrelease(config.key)
            task.wait(config.waitAfterPress)
        else
            print("Pressing key to collect " .. config.name .. "...")
            keypress(config.key)
            task.wait(0.1)
            keyrelease(config.key)
            task.wait(config.waitAfterPress)
        end
    end
    if self.autoFarmEnabled and self.selectedOption and self.selectedOption ~= "Select Field..." then
        print("Returning to " .. self.selectedOption)
        self.status = "Returning to " .. self.selectedOption
        self.needsRedraw = true
        
        local flowerZones = GetFlowerZonesFolder()
        if flowerZones then
            local targetZone = GetFlowerZone(self.selectedOption)
            if targetZone then
                character = player.Character
                if character then
                    hrp = character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local fieldPos = Vector3.new(targetZone.Position.X, targetZone.Position.Y + 10, targetZone.Position.Z)
                        if self.testWalkEnabled and config.pathfindingNode and self.fieldToHub[self.selectedOption or ""] then
                            print("Using pathfinding to return from " .. config.name)
                            local currentNode = config.pathfindingNode
                            local targetFieldHub = self.fieldToHub[self.selectedOption]
                            
                            if targetFieldHub then
                                local returnPath = self:PathfindBetweenNodes(config.pathfindingNode, targetFieldHub)
                                
                                if returnPath then
                                    local walkSuccess = self:WalkPath(returnPath)
                                    
                                    if walkSuccess then
                                        WalkTo(fieldPos)
                                        local startTime = os.clock()
                                        while IsWalking() and self.autoFarmEnabled do
                                            hrp = character:FindFirstChild("HumanoidRootPart")
                                            if hrp then
                                                local currentPos = hrp.Position
                                                local dx = currentPos.X - fieldPos.X
                                                local dz = currentPos.Z - fieldPos.Z
                                                local distance2D = Vector3.new(dx, 0, dz).Magnitude
                                                
                                                if distance2D < 15 then
                                                    StopWalking()
                                                    break
                                                end
                                            end
                                            
                                            if os.clock() - startTime > 15 then
                                                print("Walk to field center timeout")
                                                StopWalking()
                                                break
                                            end
                                            task.wait(0.1)
                                        end
                                        StopWalking()
                                        self.diedDuringAutoFarm = false
                                        self.pausedForTimedAction = false
                                    else
                                        print("Walk failed, using tween")
                                        self:QueueTween(hrp, fieldPos, true)
                                        local startWait = os.clock()
                                        self:WaitForTween(60, function() return self.autoFarmEnabled end)
                                    end
                                else
                                    self:QueueTween(hrp, fieldPos, true)
