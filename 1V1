function UI:StartTimedActionsHandler()
    
    if self.timedActionsThread then
        task.cancel(self.timedActionsThread)
        self.timedActionsThread = nil
    end
    
    local loadedFromFile = self:LoadCooldowns()
    
    if not loadedFromFile then
        print("set cooldowns no cooldown.json")
        for key, config in pairs(self.dispenserConfig) do
            local timerKey = "last" .. key:gsub("^%l", string.upper) .. "Time"
            if not self[timerKey] then
                self[timerKey] = os.clock() - config.interval
            end
        end
        if not self.lastTunnelBearTime then self.lastTunnelBearTime = os.clock() - 172800 end
        if not self.lastKingBeetleTime then self.lastKingBeetleTime = os.clock() - 86400 end
        if not self.lastCommandoChickTime then self.lastCommandoChickTime = os.clock() - 1800 end
        self:SaveCooldowns()
    end
    
    self.timedActionsThread = task.spawn(function()
        
        while self.isRunning and self.autoFarmEnabled do
            
            if self.pausedForTimedAction then
                task.wait(1)
                continue
            end
            
            local currentTime = os.clock()
            
            -- Dispensers - sequential one at a time
            for key, config in pairs(self.dispenserConfig) do
                if not self.isRunning or not self.autoFarmEnabled then break end
                
                if config.timedDispenser and config.enabled(self) then
                    local timerKey = "last" .. key:gsub("^%l", string.upper) .. "Time"
                    
                    if not self[timerKey] then
                        self[timerKey] = os.clock() - config.interval
                        print("Initialized missing timer for " .. config.name)
                    end
                    
                    local elapsed = currentTime - self[timerKey]
                    
                    if elapsed >= config.interval then
                        self.pausedForTimedAction = true
                        self:CollectDispenser(key)
                        self[timerKey] = os.clock()
                        currentTime = os.clock()
                        self:SaveCooldowns()
                        self.pausedForTimedAction = false
                    end
                end
            end
            
            if not self.isRunning or not self.autoFarmEnabled then break end
            
            -- TunnelBear
            if self.killTunnelBear then
                currentTime = os.clock()
                if not self.lastTunnelBearTime then self.lastTunnelBearTime = os.clock() - 172800 end
                local elapsed = currentTime - self.lastTunnelBearTime
                if elapsed >= 172800 then
                    self.pausedForTimedAction = true
                    local success = self:FightTunnelBear()
                    if success then self.lastTunnelBearTime = os.clock() end
                    self:SaveCooldowns()
                    self.pausedForTimedAction = false
                end
            end
            
            if not self.isRunning or not self.autoFarmEnabled then break end
            
            -- KingBeetle
            if self.killKingBeetle then
                currentTime = os.clock()
                if not self.lastKingBeetleTime then self.lastKingBeetleTime = os.clock() - 86400 end
                local elapsed = currentTime - self.lastKingBeetleTime
                if elapsed >= 86400 then
                    self.pausedForTimedAction = true
                    local success = self:KillKingBeetle()
                    if success then self.lastKingBeetleTime = os.clock() end
                    self:SaveCooldowns()
                    self.pausedForTimedAction = false
                end
            end
            
            if not self.isRunning or not self.autoFarmEnabled then break end
            
            -- CommandoChick
            if self.killCommandoChick then
                currentTime = os.clock()
                if not self.lastCommandoChickTime then self.lastCommandoChickTime = os.clock() - 1800 end
                local elapsed = currentTime - self.lastCommandoChickTime
                if elapsed >= 1800 then
                    self.pausedForTimedAction = true
                    self:FightCommandoChick()
                    self.lastCommandoChickTime = os.clock()
                    self:SaveCooldowns()
                    self.pausedForTimedAction = false
                end
            end
            
            task.wait(10)
        end
        
        self.timedActionsThread = nil
    end)
end

