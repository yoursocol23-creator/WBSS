function UI:StartAutoQuest()
    if self.autoQuestRunning then
        print("DEBUG QUEST: Auto Quest already running!")
        return
    end
    
    if not self.autoFarmEnabled then
        print("DEBUG QUEST: Auto Farm is not enabled!")
        self.autoQuest = false
        self.needsRedraw = true
        return
    end
    
    self.autoQuestRunning = true
    print("DEBUG QUEST: âœ“ Auto Quest thread starting...")
    
    -- Run in separate thread
    self.autoQuestThread = task.spawn(function()
        print("DEBUG QUEST: === AUTO QUEST STARTED ===")
        
        while self.autoQuest and self.autoQuestRunning do
            print("DEBUG QUEST: ========== NEW QUEST CHECK LOOP ==========")
            
            if not self.autoFarmEnabled then
                print("DEBUG QUEST: âŒ Auto Farm disabled - stopping Auto Quest")
                break
            end
            
            local success, err = pcall(function()
                local player = game.Players.LocalPlayer
                
                local playerGui = player:FindFirstChild("PlayerGui")
                if not playerGui then return end
                
                local screenGui = playerGui:FindFirstChild("ScreenGui")
                if not screenGui then return end
                
                local menus = screenGui:FindFirstChild("Menus")
                if not menus then return end
                
                local children = menus:FindFirstChild("Children")
                if not children then return end
                
                local quests = children:FindFirstChild("Quests")
                if not quests then return end
                
                local content = quests:FindFirstChild("Content")
                if not content then return end
                
                local frame = content:FindFirstChild("Frame")
                if not frame then return end
                
                -- Collect all quests and their requirements
                local allQuestRequirements = {}
                
                for _, questBox in pairs(frame:GetChildren()) do
                    if questBox.Name == "QuestBox" then
                        local titleBarBG = questBox:FindFirstChild("TitleBarBG")
                        if not titleBarBG then continue end
                        
                        local titleBar = titleBarBG:FindFirstChild("TitleBar")
                        if not titleBar then continue end
                        
                        local questName = titleBar.Text
                        print("DEBUG QUEST: ðŸ“‹ Found quest: \"" .. questName .. "\"")
                        
                        local shouldProcess = false
                        local isBrownBear = string.find(questName, "Brown Bear:")
                        local isPolarBear = string.find(questName, "Polar Bear:")

                        if self.autoDoAll then
                            shouldProcess = true
                            print("DEBUG QUEST: Do All is ON - processing quest")
                        elseif isBrownBear and self.autoBrowBear then
                            shouldProcess = true
                            print("DEBUG QUEST: Brown Bear quest and toggle is ON - processing quest")
                        elseif isPolarBear and self.autoPolarBear then
                            shouldProcess = true
                            print("DEBUG QUEST: Polar Bear quest and toggle is ON - processing quest")
                        end
                        
                        if not shouldProcess then
                            print("DEBUG QUEST: Skipping quest (toggles are OFF)")
                            continue
                        end
                        
                        -- DEBUG: Count TaskBars
                        local taskBarCount = 0
                        for _, child in pairs(questBox:GetChildren()) do
                            if child.Name == "TaskBar" then
                                taskBarCount = taskBarCount + 1
                            end
                        end
                        print("DEBUG QUEST: Found " .. taskBarCount .. " TaskBars in this quest")
                        
                        local allComplete = true
                        local tasks = {}
                        
                        -- Collect all tasks
                        for _, taskBar in pairs(questBox:GetChildren()) do
                            if taskBar.Name == "TaskBar" and taskBar:IsA("Frame") then
                                local description = taskBar:FindFirstChild("Description")
                                
                                if description and description:IsA("TextLabel") then
                                    local taskText = description.Text
                                    
                                    if taskText and #taskText > 3 then
                                        taskText = taskText:gsub("[\n\r]+", " "):gsub("%s+", " ")
                                        
                                        local isComplete = string.find(string.lower(taskText), "complete") ~= nil
                                        local hasTalkTo = string.find(taskText, "Talk to ") ~= nil
                                        
                                        print("DEBUG QUEST:     Task: " .. taskText .. " | Complete: " .. tostring(isComplete))

                                        if not isComplete and not hasTalkTo then
                                            allComplete = false
                                            
                                            -- Parse requirement
                                            local requirement = self:ParseQuestRequirement(taskText)
                                            if requirement then
                                                -- Check if kill_mob requirement has a configured spawner
                                                if requirement.type == "kill_mob" then
                                                    local spawnerInfo = self:GetMobSpawnerCooldown(requirement.mob)
                                                    
                                                    if not spawnerInfo then
                                                        print("DEBUG QUEST: âš ï¸ Skipping kill_mob requirement (spawner not configured): " .. requirement.mob)
                                                        continue
                                                    end
                                                    
                                                    if self.questKillMobs then
                                                        table.insert(allQuestRequirements, {
                                                            questName = questName,
                                                            questBox = questBox,
                                                            requirement = requirement,
                                                            tasks = tasks
                                                        })
                                                        print("DEBUG QUEST: âœ“ Added kill mob requirement: " .. requirement.mob .. " (" .. requirement.amount .. ")")
                                                    end
                                                elseif requirement.type == "pollen" and self.questCollectPollen then
                                                    table.insert(allQuestRequirements, {
                                                        questName = questName,
                                                        questBox = questBox,
                                                        requirement = requirement,
                                                        tasks = tasks
                                                    })
                                                    print("DEBUG QUEST: âœ“ Added pollen requirement: " .. requirement.field .. " (" .. requirement.amount .. ")")
                                                end
                                            end
                                        end
                                        
                                        table.insert(tasks, {text = taskText, complete = isComplete, hasTalkTo = hasTalkTo})
                                    else
                                        print("DEBUG QUEST:     Task text too short or empty: '" .. tostring(taskText) .. "'")
                                    end
                                else
                                    print("DEBUG QUEST:     TaskBar missing Description or not TextLabel")
                                end
                            end
                        end
                        
                        -- If all tasks complete, add to list for claiming
                        if allComplete then
                            print("DEBUG QUEST: âœ“âœ“âœ“ ALL TASKS COMPLETE FOR: " .. questName)
                            
                            -- Find the "Talk to" task
                            local talkToTask = nil
                            for _, task in ipairs(tasks) do
                                if task.hasTalkTo then
                                    talkToTask = task
                                    break
                                end
                            end
                            
                            if talkToTask then
                                print("DEBUG QUEST: Found Talk To task, adding to claim list")
                                table.insert(allQuestRequirements, {
                                    questName = questName,
                                    questBox = questBox,
                                    requirement = nil,
                                    tasks = tasks,
                                    readyToClaim = true,
                                    talkToTask = talkToTask
                                })
                            else
                                print("DEBUG QUEST: No Talk To task found for completed quest")
                            end
                        end
                    end
                end
                
                print("DEBUG QUEST: Total quest requirements collected: " .. #allQuestRequirements)
                
                -- Sort by pollen amount (lowest first)
                table.sort(allQuestRequirements, function(a, b)
                    -- Prioritize ready-to-claim quests
                    if a.readyToClaim and not b.readyToClaim then return true end
                    if not a.readyToClaim and b.readyToClaim then return false end
                    
                    -- Then sort by amount (pollen or mob kills)
                    if a.requirement and b.requirement then
                        return a.requirement.amount < b.requirement.amount
                    end
                    return false
                end)
                
                -- Process the first quest in the sorted list
                if #allQuestRequirements > 0 then
                    local currentQuest = allQuestRequirements[1]
                    
                    -- If ready to claim
                    if currentQuest.readyToClaim then
                        if self.claimQuest then
                            local npcName = string.match(currentQuest.talkToTask.text, "Talk to ([^%.]+)")
                            
                            if npcName then
                                print("DEBUG QUEST: === CLAIMING QUEST FROM: " .. npcName .. " ===")
                                
                                local wasAutoFarming = self.autoFarmEnabled
                                local previousStatus = self.status
                                self.pausedForTimedAction = true
                                
                                StopWalking()
                                self:ClearTweenQueue()
                                task.wait(0.5)
                                
                                -- Get initial quest count
                                local initialQuestCount = #frame:GetChildren()
                                for _, child in pairs(frame:GetChildren()) do
                                    if child.Name ~= "QuestBox" then
                                        initialQuestCount = initialQuestCount - 1
                                    end
                                end
                                print("DEBUG QUEST: Initial quest count:", initialQuestCount)
                                
                                -- Find NPC position
                                local npcPos = nil
                                local npcs = game.Workspace:FindFirstChild("NPCs")
                                if npcs then
                                    local npc = npcs:FindFirstChild(npcName)
                                    if npc then
                                        local platform = npc:FindFirstChild("Platform")
                                        if platform and platform:IsA("BasePart") then
