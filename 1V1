function UI:RenderCombatTab()
    local contentX = self.panel.sidebarWidth + 30
    local contentY = 80
    
    self:CreateText("Combat & Mobs", contentX, contentY, Color3.fromRGB(255, 255, 255), 20)
    
    contentY = contentY + 40
    
    local combatToggles = {
        {label = "Kill Coconut Crab", key = "killCoconutCrab"},
        {label = "Train Snail", key = "trainSnail"},
        {label = "Kill King Beetle (a)", key = "killKingBeetle"},
        {label = "Kill Vicious Bee (a)", key = "killViciousBee"},
        {label = "Kill Commando Chick (a)", key = "killCommandoChick"},
        {label = "Kill Windy (a)(Buggy)", key = "killWindy"},
        {label = "Kill Tunnel Bear (a)", key = "killTunnelBear"},
        {label = "Kill Mondo", key = "killMondo"},
        {label = "Avoid Mobs", key = "avoidMobs"},
    }

    -- Calculate extra height for Mondo sub-options
    local extraHeightBeforeAvoidMobs = 0
    if self.killMondo then
        extraHeightBeforeAvoidMobs = 28 + 10  -- Loot Mondo button + spacing
        
        if not self.lootMondo then
            -- Loot Mondo is OFF, so we show Time To Kill button
            extraHeightBeforeAvoidMobs = extraHeightBeforeAvoidMobs + 28 + 10  -- Time To Kill + spacing
            
            if self.timeToKillEnabled then
                -- Time To Kill is ON, show slider too
                extraHeightBeforeAvoidMobs = extraHeightBeforeAvoidMobs + 35 + 10  -- Slider + spacing
            end
        else
            -- Loot Mondo is ON, add extra spacing to match
            extraHeightBeforeAvoidMobs = extraHeightBeforeAvoidMobs + 10
        end
    end

    for i, toggle in ipairs(combatToggles) do
        -- Add extra spacing after "Kill Mondo" and before "Avoid Mobs"
        local toggleY = contentY + ((i - 1) * 28)
        if i == 9 then  -- "Avoid Mobs" is index 9
            toggleY = toggleY + extraHeightBeforeAvoidMobs
        end
        
        local value = self[toggle.key] or false
        
        -- Background box (rounded)
        self:CreateRect(contentX, toggleY, 196, 22, Color3.fromRGB(30, 35, 45), 1, 4, true)
        self:CreateText(toggle.label, contentX + 30, toggleY + 6, Color3.fromRGB(200, 210, 220), 12)
        
        -- Checkbox square (rounded)
        local checkboxX = contentX + 8
        local checkboxColor = value and Color3.fromRGB(16, 185, 129) or Color3.fromRGB(60, 70, 85)
        self:CreateRect(checkboxX, toggleY + 5, 14, 14, checkboxColor, 1, 3, true)
        
        -- Checkmark (if enabled)
        if value then
            local checkX = checkboxX + 3
            local checkY = toggleY + 12
            
            self:CreateLine(checkX, checkY, checkX + 3, checkY + 3, Color3.fromRGB(255, 255, 255), 2)
            self:CreateLine(checkX + 3, checkY + 3, checkX + 8, checkY - 4, Color3.fromRGB(255, 255, 255), 2)
        end
        
        self:RegisterButton(contentX, toggleY, 196, 22, function()
            if toggle.key == "killCoconutCrab" then
                if not value and self.autoFarmEnabled then
                    notify("Windy - Coconut Crab", "Turn off Auto Farm first", 8)
                    return
                end
                
                self.killCoconutCrab = not self.killCoconutCrab
                self.needsRedraw = true
                
                if self.killCoconutCrab then
                    self:StartCoconutCrab()
                else
                    self:StopCoconutCrab()
                end
            elseif toggle.key == "trainSnail" then
                if not value and self.autoFarmEnabled then
                    notify("Windy - Train Snail", "Turn off Auto Farm first", "8")
                    return
                end
                
                self.trainSnail = not self.trainSnail
                self.needsRedraw = true
                
                if self.trainSnail then
                    self:StartTrainSnail()
                else
                    self:StopTrainSnail()
                end
            elseif toggle.key == "avoidMobs" then
                self.avoidMobs = not self.avoidMobs
                self.needsRedraw = true
            elseif toggle.key == "killKingBeetle" then
                self.killKingBeetle = not self.killKingBeetle
                self.needsRedraw = true
            elseif toggle.key == "killViciousBee" then
                self.killViciousBee = not self.killViciousBee
                self.needsRedraw = true
            elseif toggle.key == "killCommandoChick" then
                self.killCommandoChick = not self.killCommandoChick
                self.needsRedraw = true
            elseif toggle.key == "killTunnelBear" then
                self.killTunnelBear = not self.killTunnelBear
                self.needsRedraw = true
            elseif toggle.key == "killWindy" then
                self.killWindy = not self.killWindy
                self.needsRedraw = true
            elseif toggle.key == "killMondo" then
                self.killMondo = not self.killMondo
                self.needsRedraw = true
            else
                self[toggle.key] = not self[toggle.key]
                self.needsRedraw = true
            end
        end)
        
        -- Render Mondo sub-options immediately after "Kill Mondo" button
        if toggle.key == "killMondo" and self.killMondo then
            local mondoSubY = toggleY + 28 + 5
            
            -- ALWAYS show Loot Mondo
            -- Draw dash OUTSIDE the button
            self:CreateText("-", contentX + 5, mondoSubY + 6, Color3.fromRGB(150, 160, 175), 12)
            
            -- Sub-toggle 1: Loot Mondo
            local lootValue = self.lootMondo or false
            self:CreateRect(contentX + 20, mondoSubY, 176, 22, Color3.fromRGB(35, 40, 50), 1, 4, true)
            self:CreateText("Loot Mondo", contentX + 20 + 30, mondoSubY + 6, Color3.fromRGB(200, 210, 220), 12)
            
            local lootCheckboxX = contentX + 20 + 8
            local lootCheckboxColor = lootValue and Color3.fromRGB(16, 185, 129) or Color3.fromRGB(60, 70, 85)
            self:CreateRect(lootCheckboxX, mondoSubY + 5, 14, 14, lootCheckboxColor, 1, 3, true)
            
            if lootValue then
                local checkX = lootCheckboxX + 3
                local checkY = mondoSubY + 12
                self:CreateLine(checkX, checkY, checkX + 3, checkY + 3, Color3.fromRGB(255, 255, 255), 2)
                self:CreateLine(checkX + 3, checkY + 3, checkX + 8, checkY - 4, Color3.fromRGB(255, 255, 255), 2)
            end
            
            self:RegisterButton(contentX + 20, mondoSubY, 176, 22, function()
                self.lootMondo = not self.lootMondo
                self.needsRedraw = true
            end)
            
            -- Only show Time To Kill if Loot Mondo is OFF
            if not self.lootMondo then
                mondoSubY = mondoSubY + 28
                
                -- Draw dash OUTSIDE the button
                self:CreateText("-", contentX + 5, mondoSubY + 6, Color3.fromRGB(150, 160, 175), 12)
                
                -- Sub-toggle 2: Time To Kill (WITH CHECKBOX)
                local timeValue = self.timeToKillEnabled or false
                self:CreateRect(contentX + 20, mondoSubY, 176, 22, Color3.fromRGB(35, 40, 50), 1, 4, true)
                self:CreateText("Time To Kill", contentX + 20 + 30, mondoSubY + 6, Color3.fromRGB(200, 210, 220), 12)
                
                local timeCheckboxX = contentX + 20 + 8
                local timeCheckboxColor = timeValue and Color3.fromRGB(16, 185, 129) or Color3.fromRGB(60, 70, 85)
                self:CreateRect(timeCheckboxX, mondoSubY + 5, 14, 14, timeCheckboxColor, 1, 3, true)
                
                if timeValue then
                    local checkX = timeCheckboxX + 3
                    local checkY = mondoSubY + 12
                    self:CreateLine(checkX, checkY, checkX + 3, checkY + 3, Color3.fromRGB(255, 255, 255), 2)
                    self:CreateLine(checkX + 3, checkY + 3, checkX + 8, checkY - 4, Color3.fromRGB(255, 255, 255), 2)
                end
                
                self:RegisterButton(contentX + 20, mondoSubY, 176, 22, function()
                    self.timeToKillEnabled = not self.timeToKillEnabled
                    self.needsRedraw = true
                end)
                
                -- Only show slider if Time To Kill is enabled
                if self.timeToKillEnabled then
                    mondoSubY = mondoSubY + 28
                    
                    -- Time slider (indented further as sub-sub option)
                    local sliderX = contentX + 60
                    local sliderY = mondoSubY
                    local sliderWidth = 130
                    
                    -- Show current value at front (like "120s")
                    self:CreateText(tostring(self.mondoTimeToKill) .. "s", contentX + 25, sliderY + 8, Color3.fromRGB(255, 255, 255), 12)
                    
                    -- Slider track
                    self:CreateRect(sliderX, sliderY + 8, sliderWidth, 6, Color3.fromRGB(40, 45, 55), 1, 0, true)
                    
                    -- Slider fill (30-240 range)
                    local normalizedValue = (self.mondoTimeToKill - 30) / (240 - 30)
                    local sliderPos = normalizedValue * sliderWidth
                    
                    self:CreateRect(sliderX, sliderY + 8, sliderPos, 6, Color3.fromRGB(16, 185, 129), 1, 0, true)
                    
                    -- Slider handle
                    self:CreateRect(sliderX + sliderPos - 4, sliderY + 2, 8, 18, Color3.fromRGB(16, 185, 129), 1, 0, true)
                    
                    -- Min/max labels
                    self:CreateText("30s", sliderX, sliderY + 20, Color3.fromRGB(120, 130, 145), 10)
                    self:CreateText("240s", sliderX + sliderWidth - 20, sliderY + 20, Color3.fromRGB(120, 130, 145), 10)
                    
                    self:RegisterButton(sliderX, sliderY + 2, sliderWidth, 18, function()
                        self.draggingMondoSlider = true
                    end)
                end
            end
        end
    end
    
    local dropdownX = contentX + 220
    local dropdownY = contentY
    
    self:CreateText("Target Selection", dropdownX, dropdownY - 25, Color3.fromRGB(200, 210, 220), 14)
    
    self:CreateText("Last selected: " .. (self.selectedCombatTarget or "Any Mob"), dropdownX, dropdownY - 12, Color3.fromRGB(120, 130, 145), 10)
    
    self:CreateRect(dropdownX, dropdownY, 150, 26, Color3.fromRGB(30, 35, 45), 1, 6, true)
    self:CreateText(self.selectedCombatTarget or "Any Mob", dropdownX + 8, dropdownY + 7, Color3.fromRGB(200, 210, 220), 12)
    self:CreateText("v", dropdownX + 135, dropdownY + 6, Color3.fromRGB(150, 160, 175), 12)
    
    self:RegisterButton(dropdownX, dropdownY, 150, 26, function()
        if not self.lastMousePressed then
            self.combatDropdownOpen = not self.combatDropdownOpen
            self.needsRedraw = true
        end
    end)
    
    -- RENDER DROPDOWN LAST WITH PROPER ROUNDING
    if self.combatDropdownOpen then
        local options = {
            "Any Mob",
            "Ladybugs",
            "Rhino Beetles",
            "Mantis",
            "Scorpions",
            "Werewolf",
            "Cave Monsters",
            "King Beetle",
            "Tunnel Bear"
        }
        
        local menuY = dropdownY + 28
        
        -- Single rounded container background
        self:CreateRect(dropdownX, menuY, 150, #options * 24, Color3.fromRGB(25, 28, 35), 1, 8, true)
        
        for i, option in ipairs(options) do
            local optionY = menuY + ((i - 1) * 24)
            
            -- Flat option background (no corner radius)
            self:CreateRect(dropdownX + 1, optionY + 1, 148, 22, Color3.fromRGB(40, 45, 55), 1, 0, true)
            self:CreateText(option, dropdownX + 8, optionY + 6, Color3.fromRGB(200, 210, 220), 11)
            
            self:RegisterButton(dropdownX, optionY, 150, 24, function()
                if not self.lastMousePressed then
                    self.selectedCombatTarget = option
                    self.combatDropdownOpen = false
                    self.needsRedraw = true
                end
            end)
        end
    end
end

function UI:RenderQuestTab()
