function FaceBalloons:FindClosestBalloon()
    local player = game.Players.LocalPlayer
    local character = player.Character
    if not character then return nil, nil end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil, nil end
    
    local balloons = game.Workspace:FindFirstChild("Balloons")
    if not balloons then return nil, nil end
    
    local fieldBalloons = balloons:FindFirstChild("FieldBalloons")
    if not fieldBalloons then return nil, nil end
    
    local closestBalloon = nil
    local closestDistance = math.huge
    local playerPos = hrp.Position
    
    for _, balloon in pairs(fieldBalloons:GetChildren()) do
        local balloonBody = balloon:FindFirstChild("BalloonBody")
        if balloonBody and balloonBody:IsA("BasePart") then
            local success, balloonPos = pcall(function()
                return balloonBody.Position
            end)
            
            if success and balloonPos then
                local dx = balloonPos.X - playerPos.X
                local dy = balloonPos.Y - playerPos.Y
                local dz = balloonPos.Z - playerPos.Z
                local distance = math.sqrt(dx*dx + dy*dy + dz*dz)
                
                if distance < closestDistance then
                    closestDistance = distance
                    closestBalloon = balloonBody
                end
            end
        end
    end
    
    return closestBalloon, closestDistance
end

local function getPrimitive(part)
    local success, result = pcall(function()
        return memory_read("uintptr_t", part.Address + primitive)
    end)
    return success and result or nil
end

local function writeRotationMemory(part, angle)
    if not part or not part.Address then return false end
    
    local prim = getPrimitive(part)
    if not prim or prim == 0 then return false end
    
    local rad = math.rad(-angle)
    local cosY, sinY = math.cos(rad), math.sin(rad)
    
    local success = pcall(function()
        memory_write("float", prim + cframepath + 0x00, cosY)
        memory_write("float", prim + cframepath + 0x04, 0)
        memory_write("float", prim + cframepath + 0x08, sinY)
        memory_write("float", prim + cframepath + 0x0C, 0)
        memory_write("float", prim + cframepath + 0x10, 1)
        memory_write("float", prim + cframepath + 0x14, 0)
        memory_write("float", prim + cframepath + 0x18, -sinY)
        memory_write("float", prim + cframepath + 0x1C, 0)
        memory_write("float", prim + cframepath + 0x20, cosY)
    end)
    
    return success
end

local function setAutoRotate(humanoid, enabled)
    if not humanoid or not humanoid.Address then return false end
    local success = pcall(function()
        memory_write("byte", humanoid.Address + autoRotateOffset, enabled and 1 or 0)
    end)
    return success
end

local PRIMITIVE_OFFSET = 0x148
local CFRAME_OFFSET    = 0xC0

local function getPrimitive(part)
    local success, result = pcall(function()
        return memory_read("uintptr_t", part.Address + PRIMITIVE_OFFSET)
    end)
    return success and result or nil
end

local function writeCFrame(part, targetPos)
    local prim = getPrimitive(part)
    if not prim or prim == 0 then return false end
    local success = pcall(function()
        -- Preserve existing rotation, only write position (X/Y/Z at +0x24/0x28/0x2C)
        memory_write("float", prim + CFRAME_OFFSET + 0x24, targetPos.X)
        memory_write("float", prim + CFRAME_OFFSET + 0x28, targetPos.Y)
        memory_write("float", prim + CFRAME_OFFSET + 0x2C, targetPos.Z)
    end)
    return success
end

local function getAutoRotate(humanoid)
    if not humanoid or not humanoid.Address then return nil end
    local success, value = pcall(function()
        return memory_read("byte", humanoid.Address + autoRotateOffset)
    end)
    return success and (value == 1) or nil
end

local function lerpAngle(from, to, alpha)
    local delta = to - from
    while delta > 180 do delta = delta - 360 end
    while delta < -180 do delta = delta + 360 end
    return from + delta * alpha
end

