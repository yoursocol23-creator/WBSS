function UI:IsHiveOwnedByPlayer(hive, player)
    if not hive or not player then
        return false
    end

    local owner = hive:FindFirstChild("Owner")
    if not owner then
        return false
    end

    local okValue, ownerValue = pcall(function()
        return owner.Value
    end)

    if okValue and ownerValue == player then
        return true
    end

    local okName, ownerName = pcall(function()
        return owner.Value and owner.Value.Name
    end)
    if okName and ownerName == player.Name then
        return true
    end

    local ownerText = tostring(okValue and ownerValue or "")
    if ownerText ~= "" and string.find(ownerText, tostring(player.Name), 1, true) then
        return true
    end

    if player.UserId and string.find(ownerText, tostring(player.UserId), 1, true) then
        return true
    end

    return false
end

function UI:IsHiveUnclaimed(hive)
