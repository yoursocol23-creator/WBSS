local ObsidianRefreshHomeStats = UI.RefreshHomeStats
function UI:RefreshHomeStats(force)
    ObsidianRefreshHomeStats(self, force)
    if not force and not self.liveHomeStats then
        return
    end

    if not force and (tick() - (self.lastBSSHomeStatRefresh or 0)) < 1 then
        return
    end

    self.lastBSSHomeStatRefresh = tick()

    local honey = 0
    pcall(function()
        honey = AliveCheck:GetPlayerHoney()
    end)

    self:SetStatValue("honey_stat", tostring(math.floor(tonumber(honey) or 0)))
    self:SetStatValue("bss_status_stat", tostring(self.status or "Ready"))
    self:SetStatValue("home_field_stat", tostring(self.selectedOption or "None"))
    self:SetStatValue("home_tween_stat", tostring(self.tweenMethod or "Velocity"))
    self:SetStatValue("home_combat_stat", tostring(self.selectedCombatTarget or "Any Mob"))
end

function UI:StopBSSAutomation()
    self.autoFarmEnabled = false
    self.autoFarmRunning = false
    self.hiveClaimRunning = false
    self.autoDigEnabled = false
    self.autoDigRunning = false
    self.autoQuest = false
    self.autoQuestRunning = false
    self.killCoconutCrab = false
    self.coconutCrabRunning = false
    self.trainSnail = false
    self.trainSnailRunning = false
    self.farmTargetPractice = false
    self.targetPracticeActive = false
    self.farmPuppyBall = false
    self.farmPuppyBallRunning = false
    self.catchCoconuts = false
    self.catchCoconutsRunning = false
    self.catchStars = false
    self.catchStarsRunning = false

    pcall(function() FaceBalloons:Stop() end)
    pcall(function() AliveCheck:Stop() end)
    pcall(function() self:StopPathNodeESP() end)
    pcall(function() self:StopCoconutESP() end)
    pcall(function() self:StopTimedActionsHandler() end)
    pcall(function() self:ClearTweenQueue() end)
    pcall(function() StopWalking() end)

    for _, threadKey in ipairs({
        "autoQuestThread",
        "statusUpdaterThread",
        "autoFarmThread",
        "autoDigThread",
        "coconutCrabThread",
        "tweenQueueThread",
        "timedActionsThread",
        "farmPuppyBallThread",
        "catchCoconutsThread",
        "catchStarsThread",
    }) do
        local thread = self[threadKey]
        if thread and task and type(task.cancel) == "function" then
            pcall(task.cancel, thread)
        end
        self[threadKey] = nil
    end
end

