function UI:StopAutoQuest()
    print("Stopping Auto Quest...")
    self.autoQuest = false
    self.autoQuestRunning = false
    
    -- Return to original field if one was saved
    if self.questOriginalField and self.questOriginalField ~= "Select Field..." then
        print("DEBUG QUEST: Returning to original field before stopping:", self.questOriginalField)
        self.selectedOption = self.questOriginalField
        self.sprinklersPlaced = false
        self.needsRedraw = true
        
        -- Tween back to original field
        local player = game.Players.LocalPlayer
        local character = player.Character
        if character then
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local flowerZones = GetFlowerZonesFolder()
                if flowerZones then
                    local targetZone = GetFlowerZone(self.questOriginalField)
                    if targetZone then
                        local fieldPos = Vector3.new(targetZone.Position.X, targetZone.Position.Y + 10, targetZone.Position.Z)
                        self:QueueTween(hrp, fieldPos, true)
                    end
                end
            end
        end
    end
    
    -- Clear saved field
    self.questOriginalField = nil
    
    if self.autoQuestThread then
        self.autoQuestThread = nil
    end
end



function UI:StartAutoFarm()
    if self.selectedOption == "Select Field..." or self.selectedOption == "" then
        notify("Windy Auto Farm", "Select A field", "8")
        self.autoFarmEnabled = false
        self.needsRedraw = true
        return
    end
    
    self.gatherStartTime = os.clock()

    if not self.originalAutoFarmField or self.lastFieldChangeSource == "autofarm" then
        self.originalAutoFarmField = self.selectedOption
        self.lastFieldChangeSource = "autofarm"
    end

    if self.killCoconutCrab then
        notify("Turn Off Kill Coconut Crab First", "Windy - CONTROL", 8)
        self.autoFarmEnabled = false
        self.needsRedraw = true
