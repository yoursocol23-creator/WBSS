local ObsidianGetControlOptions = UI.GetControlOptions
function UI:GetControlOptions(control)
    local options = control and (control.options or control.Values or control.values)
    if type(options) == "function" then
        local ok, result = pcall(options, self, control)
        if ok and type(result) == "table" then
            return result
        end
    end

    return ObsidianGetControlOptions(self, control)
end

function UI:MarkDirty(layout, animation)
    if layout then
        self:MarkShellDirty()
    else
        self:MarkCurrentTabDirty()
    end

    if animation then
        self.animationsActive = true
    end
end

local ObsidianRender = UI.Render
function UI:Render()
    if self.needsRedraw and not self.isBooting then
        self.tabDirty[self.selectedTab or 1] = true
    end

    return ObsidianRender(self)
end

local function BSSNotify(title, message, duration)
    if type(notify) == "function" then
        pcall(notify, title, message, duration or 4)
    else
        UI:NotifyPlayer(tostring(message or title or ""), tostring(title or "Windy"), tonumber(duration) or 4)
    end
end

function UI:SetBSSControl(controlId, value, skipAction)
    self:SetControlValue(controlId, value, skipAction == true)
end

function UI:SyncBSSStateFromControls()
    for _, tabControls in ipairs(self.controls or {}) do
        for _, control in ipairs(tabControls) do
            local key = control.bssKey
            if key then
                local controlType = self:GetControlType(control)
                if controlType == "dropdown_multi" then
                    self[key] = control.selected or control.Selected or {}
                elseif controlType == "slider" then
                    local minValue = control.min or control.Min or 0
                    local maxValue = control.max or control.Max or minValue
                    local value = self:GetControlRawValue(control, self[key])
                    if type(value) == "table" then
                        value = value.value or value.Value or value.default or value.Default
                    end
                    value = tonumber(value) or tonumber(self[key]) or tonumber(control.default or control.Default) or minValue
                    value = math.clamp(value, minValue, maxValue)
                    self:SetControlRawValue(control, value)
                    self[key] = value
                elseif controlType == "toggle" or controlType == "checkbox" then
                    self[key] = self:GetControlRawValue(control, false) == true
                else
                    self[key] = self:GetControlRawValue(control, self[key])
                end
            end
        end
    end

    if TweenService then
        TweenService.currentMethod = self.tweenMethod or "Velocity"
    end
end

local function BSSAction(key, after)
    return function(control, value)
        UI[key] = value
        if type(after) == "function" then
            after(value, control)
        end
        UI:MarkCurrentTabDirty()
    end
end

local function BSSToggle(id, key, after)
    UI:AddAction(id, BSSAction(key, after))
end

local function BSSValue(id, key, after)
    UI:AddAction(id, BSSAction(key, after))
end



local function BSSButton(id, callback)
    UI:AddAction(id, function()
        if type(callback) == "function" then
            callback()
        end
        UI:MarkCurrentTabDirty()
    end)
end

function UI:GetBSSConfigOptions()
    pcall(function()
        self:RefreshSavedConfigs()
    end)

    local options = {}
    for _, config in ipairs(self.savedConfigs or {}) do
        table.insert(options, config.name)
    end

    if #options == 0 then
        table.insert(options, "None")
    end

    return options
end

