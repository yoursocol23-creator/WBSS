    end

    flowerZonesCache = game.Workspace:FindFirstChild("FlowerZones")
    flowerZonesCacheTime = os.clock()
    return flowerZonesCache
end

local function GetFlowerZone(zoneName)
    local flowerZones = GetFlowerZonesFolder()
    return flowerZones and flowerZones:FindFirstChild(zoneName) or nil
end

local function GetFlowerZones()
    local zones = {}
    local flowerZones = GetFlowerZonesFolder()
    
    if flowerZones then
        for _, zone in pairs(flowerZones:GetChildren()) do
            if not string.find(string.lower(zone.Name), "brick") then
                table.insert(zones, zone.Name)
            end
        end
    end
    
    table.sort(zones)
    
    return zones
end


