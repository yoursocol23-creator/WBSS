function UI:HandleInput()
    if not self.uiVisible then
        return
    end
    local mouse = game.Players.LocalPlayer:GetMouse()
    local mX, mY = mouse.X, mouse.Y
    local pressed = ismouse1pressed()
    
    if pressed and not self.lastMousePressed then
        local relX, relY = mX - self.panel.x, mY - self.panel.y
        
        if self.activeTab == 6 then
            local sliderX = self.panel.sidebarWidth + 30 + 220
            local textboxY = 80 + 40 + 60 + 60 + 60 + 34
            local textboxWidth = 150
            
            local clickedTextbox = (relX >= sliderX and relX <= sliderX + textboxWidth and
                                    relY >= textboxY and relY <= textboxY + 24)
            
            if clickedTextbox and not self.savedConfigDropdownOpen then
                if not self.configNameInputActive then
                    self:StartConfigNameInput()
                end
                self.lastMousePressed = pressed
                return
            end
            
            if self.configNameInputActive and (not clickedTextbox or self.savedConfigDropdownOpen) then
                self.configNameInputActive = false
                self.needsRedraw = true
            end
        end
        
        local clickingInsideDropdownArea = false
        
        if self.dropdownOpen then
            local dropdown1X = self.panel.sidebarWidth + 30 + 220
            local dropdownY = 80 + 40
            local menuY = dropdownY + 28
            local options = GetFlowerZones()
            
            if relX >= dropdown1X and relX <= dropdown1X + 150 and
               relY >= menuY and relY <= menuY + (#options * 24) then
                clickingInsideDropdownArea = true
            end
        end
        
        if self.secondDropdownOpen then
            local dropdown2X = self.panel.sidebarWidth + 30 + 220 + 170
            local dropdownY = 80 + 40
            local menuY = dropdownY + 28
            
            if relX >= dropdown2X and relX <= dropdown2X + 150 and
               relY >= menuY and relY <= menuY + (6 * 24) then
                clickingInsideDropdownArea = true
            end
        end
        
        if self.combatDropdownOpen then
            local dropdownX = self.panel.sidebarWidth + 30 + 220
            local dropdownY = 80 + 40
            local menuY = dropdownY + 28
            
            if relX >= dropdownX and relX <= dropdownX + 150 and
               relY >= menuY and relY <= menuY + (9 * 24) then
                clickingInsideDropdownArea = true
            end
        end
        
        if self.tweenMethodDropdownOpen then
            local sliderX = self.panel.sidebarWidth + 30 + 220
            local tweenMethodY = 80 + 40 + 60 + 60
            local menuY = tweenMethodY + 28
            
            if relX >= sliderX and relX <= sliderX + 150 and
               relY >= menuY and relY <= menuY + (2 * 24) then
                clickingInsideDropdownArea = true
            end
        end
        
        if self.savedConfigDropdownOpen then
            local sliderX = self.panel.sidebarWidth + 30 + 220
            local configY = 80 + 40 + 60 + 60 + 60
            local menuY = configY + 28
            local optionCount = #self.savedConfigs
            if optionCount == 0 then optionCount = 1 end
            
            if relX >= sliderX and relX <= sliderX + 150 and
               relY >= menuY and relY <= menuY + (optionCount * 24) then
                clickingInsideDropdownArea = true
            end
        end
        
        for _, btn in ipairs(self.buttons) do
            if relX >= btn.x and relX <= btn.x + btn.width and
               relY >= btn.y and relY <= btn.y + btn.height then
                
                if clickingInsideDropdownArea then
                    local isDropdownButton = false
                    
                    if self.dropdownOpen or self.secondDropdownOpen or self.combatDropdownOpen or self.tweenMethodDropdownOpen or self.savedConfigDropdownOpen then
                        local dropdownY = 80 + 40
                        local menuY = dropdownY + 28
                        
                        if btn.y >= menuY and btn.height == 24 then
                            isDropdownButton = true
                        end
                    end
                    
                    if isDropdownButton and btn.callback then
                        btn.callback()
                        self.lastMousePressed = pressed
                        return
                    end
                else
                    if btn.callback then
                        btn.callback()
                    end
                    self.lastMousePressed = pressed
                    return
                end
            end
        end
        
        if relX >= 0 and relX <= self.panel.width and relY >= 0 and relY <= 50 then
            self.dragging = {x = relX, y = relY}
        end
    end
    
    if pressed then
        if self.dragging then
            self.panel.x = mX - self.dragging.x
            self.panel.y = mY - self.dragging.y
            for _, d in pairs(self.drawings) do
                if d.isLine then
                    d.instance.From = Vector2.new(self.panel.x + d.relX, self.panel.y + d.relY)
                    d.instance.To = Vector2.new(self.panel.x + d.relX2, self.panel.y + d.relY2)
                else
                    d.instance.Position = Vector2.new(self.panel.x + d.relX, self.panel.y + d.relY)
                end
            end
        end
        
        if self.draggingSlider then
            self:HandleSliderDrag(mX, mY)
        end
        if self.draggingWalkSlider then
            self:HandleWalkSliderDrag(mX, mY)
        end
        if self.draggingGatherSlider then
            self:HandleGatherSliderDrag(mX, mY)
        end
        if self.draggingMondoSlider then
            self:HandleMondoSliderDrag(mX, mY)
        end
    else
        self.dragging = nil
        self.draggingSlider = false
        self.draggingWalkSlider = false
        self.draggingGatherSlider = false
        self.draggingMondoSlider = false
    end
    
    self.lastMousePressed = pressed
end

function UI:HandleSliderDrag(mX, mY)
    local sliderX = self.panel.x + self.panel.sidebarWidth + 30 + 220
    local sliderY = self.panel.y + 80 + 40 + 8
    local sliderWidth = 150
    
    -- Calculate position relative to slider
    local relX = mX - sliderX
    relX = math.max(0, math.min(relX, sliderWidth))
    
    -- Map to speed range (20-120)
    local normalizedValue = relX / sliderWidth
    self.tweenSpeed = 20 + (normalizedValue * 100)
    self.tweenSpeed = math.floor(self.tweenSpeed)
    
    self.needsRedraw = true
end

function UI:HandleGatherSliderDrag(mX, mY)
    local sliderX = self.panel.x + self.panel.sidebarWidth + 30 + 220
    local sliderY = self.panel.y + 80 + 40 + 8 + 60
    local sliderWidth = 150
    
    -- Calculate position relative to slider
    local relX = mX - sliderX
    relX = math.max(0, math.min(relX, sliderWidth))
    
    -- Map to time range (1-30 minutes)
    local normalizedValue = relX / sliderWidth
    self.gatherTime = 1 + (normalizedValue * 29)
    self.gatherTime = math.floor(self.gatherTime)
    
    self.needsRedraw = true
end

function UI:HandleMondoSliderDrag(mX, mY)
    local sliderX = self.panel.x + self.panel.sidebarWidth + 30 + 60  -- Changed from 40 to 60
    local mondoSubY = self.panel.y + 80 + 40 + (8 * 28) + 5 + 28 + 28 + 28  -- Kill Mondo + Loot Mondo + Time To Kill + Slider
    
    local sliderY = mondoSubY + 8
    local sliderWidth = 130  -- Changed from 150 to 130
    
    -- Calculate position relative to slider
    local relX = mX - sliderX
    relX = math.max(0, math.min(relX, sliderWidth))
    
    -- Map to time range (30-240 seconds)
    local normalizedValue = relX / sliderWidth
    self.mondoTimeToKill = 30 + (normalizedValue * 210)
    self.mondoTimeToKill = math.floor(self.mondoTimeToKill)
    
    self.needsRedraw = true
end

function UI:HandleWalkSliderDrag(mX, mY)
    local walkSliderX = self.panel.x + self.panel.sidebarWidth + 30 + 220 + 180
    local walkSliderWidth = 150
    
    local relX = mX - walkSliderX
    relX = math.max(0, math.min(relX, walkSliderWidth))
    
    local normalizedValue = relX / walkSliderWidth
    self.walkSpeed = math.floor(normalizedValue * 100)
    
    local player = game.Players.LocalPlayer
    local character = player.Character
    if character then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid and humanoid.Address then
            pcall(function()
                memory_write("float", humanoid.Address + (OFFSETS.WalkSpeed or 0x1D4), self.walkSpeed)
                memory_write("float", humanoid.Address + (OFFSETS.WalkSpeedCheck or 0x3C0), self.walkSpeed)
            end)
        end
    end
    
    self.needsRedraw = true
end

