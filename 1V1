function UI:QueueTweenAsync(hrp, targetPos, priority, onDone)
    -- Fields that require intermediate waypoint
    local highAltitudeFields = {
        ["Pine Tree Forest"] = true,
        ["Cactus Field"] = true,
        ["Pumpkin Patch"] = true,
        ["Pineapple Patch"] = true,
        ["Stump Field"] = true
    }
    
    local intermediateWaypoint = Vector3.new(17, 190, -210)
    
    -- Check if current field needs intermediate waypoint
    local needsWaypoint = self.selectedOption and highAltitudeFields[self.selectedOption]
    local addedWaypoint = false
    
    if needsWaypoint then
        local currentPos = hrp.Position
        
        -- Check distance from CURRENT position to waypoint
        local dxCurrent = currentPos.X - intermediateWaypoint.X
        local dyCurrent = currentPos.Y - intermediateWaypoint.Y
        local dzCurrent = currentPos.Z - intermediateWaypoint.Z
        local distFromCurrentToWaypoint = Vector3.new(dxCurrent, dyCurrent, dzCurrent).Magnitude
        
        -- Check distance from TARGET to waypoint
        local dxTarget = targetPos.X - intermediateWaypoint.X
        local dyTarget = targetPos.Y - intermediateWaypoint.Y
        local dzTarget = targetPos.Z - intermediateWaypoint.Z
        local distFromTargetToWaypoint = Vector3.new(dxTarget, dyTarget, dzTarget).Magnitude
        
        if distFromCurrentToWaypoint > 100 or distFromTargetToWaypoint > 100 then
            if priority then
                self:ClearTweenQueue()
            end
            
            local waypointData = {hrp = hrp, targetPos = intermediateWaypoint, priority = false}
            table.insert(self.tweenQueue, waypointData)
            addedWaypoint = true
        else
            print("Skipping waypoint (already near it)")
        end
    end
    
    -- Add main tween
    local tweenData = {hrp = hrp, targetPos = targetPos, priority = priority or false, onDone = onDone}
    
    -- Only clear queue if we didn't already add a waypoint
    if priority and not addedWaypoint then
        self:ClearTweenQueue()
    end
    
    table.insert(self.tweenQueue, tweenData)
    
    if not self.processingTween and not self.tweenQueueThread then
        self.tweenQueueThread = task.spawn(function()
             self:ProcessTweenQueue()
         end)
    end
end

function UI:QueueTween(hrp, targetPos, priority, onDone)
    return self:QueueTweenAsync(hrp, targetPos, priority, onDone)
end

function UI:ProcessTweenQueue()
    if self.processingTween then 
        warn("Multiple Tweens Not Allowed")
        return 
    end
    
    local queueToken = (self.tweenCancelToken or 0)
    while #self.tweenQueue > 0 do
        if queueToken ~= (self.tweenCancelToken or 0) then
            break
        end

        self.processingTween = true
            
        local tweenData = table.remove(self.tweenQueue, 1)
        local hrp = tweenData.hrp
        local targetPos = tweenData.targetPos
        local onDone = tweenData.onDone
        self.currentTweenTarget = targetPos
            
            -- Validate hrp
            if not hrp or not hrp.Parent then
                print("ERROR: Invalid HRP in tween queue, skipping")
                self.processingTween = false
                if type(onDone) == "function" then
                    pcall(onDone, false, "invalid_hrp")
                end
                continue
            end
            
            local startPos = hrp.Position
            local dx = targetPos.X - startPos.X
            local dy = targetPos.Y - startPos.Y
            local dz = targetPos.Z - startPos.Z
            local distance = Vector3.new(dx, dy, dz).Magnitude
            
            
            if distance < 3 then
                self.processingTween = false
                if type(onDone) == "function" then
                    pcall(onDone, true, "already_there")
                end
                continue
            end
            
            local tweenTime = distance / self.tweenSpeed
            
            -- USE SELECTED TWEEN METHOD:
            local tweenInfo = TweenInfo.new(tweenTime, "Linear", "None")
            self.currentTween = TweenService:Create(hrp, tweenInfo, {Position = targetPos})
            
            if not self.currentTween then
                print("ERROR: Failed to create tween!")
                self.processingTween = false
                if type(onDone) == "function" then
                    pcall(onDone, false, "create_failed")
                end
                continue
            end
            
            
            -- Play tween
            local playSuccess = pcall(function()
                self.currentTween:Play()
            end)
            
            if not playSuccess then
                print("ERROR: Failed to play tween!")
                self.currentTween = nil
                self.processingTween = false
                if type(onDone) == "function" then
                    pcall(onDone, false, "play_failed")
                end
                continue
            end
            
            
            -- Wait for tween completion with timeout and progress monitoring
            local startTime = os.clock()
            local maxWaitTime = math.max(tweenTime + 5, 15) -- At least 15s, or tweenTime + 5s buffer
            local lastProgressTime = startTime
            local lastProgressPos = hrp.Position
            local stuckCount = 0
            
            while self.currentTween and self.currentTween.IsPlaying and (self.autoFarmEnabled or self.killCoconutCrab or self.trainSnail) do
                if queueToken ~= (self.tweenCancelToken or 0) then
                    if self.currentTween then
                        pcall(function() self.currentTween:Cancel() end)
                    end
                    break
                end

                local elapsed = os.clock() - startTime
                
                -- Hard timeout
                if elapsed > maxWaitTime then
                    print("ERROR: Tween timeout after " .. string.format("%.1f", elapsed) .. "s")
                    if self.currentTween then
                        pcall(function() self.currentTween:Cancel() end)
                    end
                    break
                end
                
                -- Progress check every 2 seconds
                if os.clock() - lastProgressTime >= 2 then
                    hrp = tweenData.hrp
                    if hrp and hrp.Parent then
                        local currentPos = hrp.Position
                        local pdx = currentPos.X - lastProgressPos.X
                        local pdy = currentPos.Y - lastProgressPos.Y
                        local pdz = currentPos.Z - lastProgressPos.Z
                        local progressDist = Vector3.new(pdx, pdy, pdz).Magnitude
                        
                        
                        if progressDist < 2 then
                            stuckCount = stuckCount + 1
                            print("WARNING: Tween appears stuck (count: " .. stuckCount .. ")")
                            
                            if stuckCount >= 3 then
                                print("ERROR: Tween stuck for 6s, force canceling")
                                if self.currentTween then
                                    pcall(function() self.currentTween:Cancel() end)
                                end
                                break
                            end
                        else
                            stuckCount = 0 -- Reset if making progress
                        end
                        
                        lastProgressPos = currentPos
                    else
                        print("ERROR: Lost HRP during tween")
                        if self.currentTween then
                            pcall(function() self.currentTween:Cancel() end)
                        end
                        break
                    end
                    
                    lastProgressTime = os.clock()
                end
                
                task.wait(0.1)
            end
            
            -- Cleanup
            if self.currentTween then
                pcall(function()
                    if self.currentTween.IsPlaying then
                        self.currentTween:Cancel()
                    end
                end)
            end
            self.currentTween = nil
            self.currentTweenTarget = nil
            
            
            -- Verify final position
            hrp = tweenData.hrp
            if hrp and hrp.Parent then
                local finalPos = hrp.Position
                local fdx = finalPos.X - targetPos.X
                local fdy = finalPos.Y - targetPos.Y
                local fdz = finalPos.Z - targetPos.Z
                local finalDistance = Vector3.new(fdx, fdy, fdz).Magnitude
            end
            
            task.wait(0.2)
            self.processingTween = false
            if type(onDone) == "function" then
                pcall(onDone, true, "done")
            end
    end
    
    if queueToken == (self.tweenCancelToken or 0) then
        self.processingTween = false
        self.currentTweenTarget = nil
        self.tweenQueue = {}
        self.tweenQueueThread = nil
    end
end

function UI:ClearTweenQueue()
    self.tweenCancelToken = (self.tweenCancelToken or 0) + 1
    self.tweenQueue = {}
    if self.currentTween then
        pcall(function()
            if self.currentTween.Cancel then
                self.currentTween:Cancel()
            else
                self.currentTween:Stop()
            end
        end)
        self.currentTween = nil
    end
    self.currentTweenTarget = nil
    self.processingTween = false
    self.tweenQueueThread = nil
end

function UI:WaitForTween(timeoutSeconds, shouldContinue, onTick)
    local startedAt = os.clock()
    local timeout = tonumber(timeoutSeconds) or 60

    while self.processingTween do
        if type(shouldContinue) == "function" and not shouldContinue() then
            return false, "cancelled"
        end

        if timeout > 0 and os.clock() - startedAt > timeout then
            self:ClearTweenQueue()
            return false, "timeout"
        end

        if type(onTick) == "function" then
            local ok, result = pcall(onTick)
            if not ok or result == false then
                return false, "tick_cancelled"
            end
        end

        pcall(function()
            self:UpdateRobloxInputCapture()
            self:HandleHotkeys()
            self:PollFrameInputChanged()
            self:RefreshHomeStats(false)
            self:UpdateAIRequestTimeout()
            self:UpdateAIPolling()

            if self.searchFocused or self.activeTextInput or self.activeDropdownSearch then
                self:PollSearchKeys()
            end

            if self.activeKeybind then
                self:PollKeybindCapture()
            end

            if self.uiVisible and not self.isBooting then
                self:UpdateAnimations(1 / 60)
                self:HandleInput()
                self:HandleTransientEffects()

                if self.needsRedraw or self.animationsActive then
                    self:Render()
                end
            end
        end)

        task.wait(0.03)
    end

    return true, "done"
end

function UI:UseSprinkler()
