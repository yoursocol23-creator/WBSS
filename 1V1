function UI:RenderSidebar()
    local p = self.panel
    local sw = p.sidebarWidth
    self:CreateRect(0, 50, sw, p.height - 50, Color3.fromRGB(20, 23, 30), 1, 0, true)
    self:CreateRect(sw, 50, 1, p.height - 50, Color3.fromRGB(40, 45, 55), 1, 0, true)
    
    local tabHeight = 45
    local startY = 70
    
    for i, tab in ipairs(self.tabs) do
        local tabY = startY + ((i - 1) * tabHeight)
        local isActive = (i == self.activeTab)
        
        -- init lerp
        if not self.tabLerpProgress[i] then
            self.tabLerpProgress[i] = isActive and 1 or 0
        end
        
        -- lerp toward target
        local targetVal = isActive and 1 or 0
        local current = self.tabLerpProgress[i]
        self.tabLerpProgress[i] = current + (targetVal - current) * 0.25
        local t = self.tabLerpProgress[i]
        
        -- interpolate background color
        local bgR = math.floor(20 + (16 - 20) * t)
        local bgG = math.floor(23 + (185 - 23) * t)
        local bgB = math.floor(30 + (129 - 30) * t)
        self:CreateRect(0, tabY, sw, tabHeight, Color3.fromRGB(bgR, bgG, bgB))
        
        -- left accent bar
        local barW = math.floor(4 * t)
        if barW > 0 then
            self:CreateRect(0, tabY, barW, tabHeight, Color3.fromRGB(6, 150, 100))
        end
        
        -- icon and text colors lerped too
        local iconR = math.floor(120 + (255 - 120) * t)
        local iconG = math.floor(130 + (255 - 130) * t)
        local iconB = math.floor(145 + (255 - 145) * t)
        self:CreateText(tab.icon, 25, tabY + 8, Color3.fromRGB(iconR, iconG, iconB), 16)
        
        local textR = math.floor(150 + (255 - 150) * t)
        local textG = math.floor(160 + (255 - 160) * t)
        local textB = math.floor(175 + (255 - 175) * t)
        self:CreateText(tab.name, 50, tabY + 15, Color3.fromRGB(textR, textG, textB), 13)
        
        self:RegisterButton(0, tabY, sw, tabHeight, function()
            self.activeTab = i
        end)
        
        if i < #self.tabs then
            local sepR = math.floor(30 + (6 - 30) * t)
            local sepG = math.floor(35 + (150 - 35) * t)
            local sepB = math.floor(45 + (100 - 45) * t)
            self:CreateRect(15, tabY + tabHeight - 1, sw - 30, 1, Color3.fromRGB(sepR, sepG, sepB))
        end
    end
end

