local TweenService = {}
local EasingFunctions = {
    Linear = function(t) return t end,
    Sine = {
        In = function(t) return 1 - math.cos((t * math.pi) / 2) end,
        Out = function(t) return math.sin((t * math.pi) / 2) end,
        InOut = function(t) return -(math.cos(math.pi * t) - 1) / 2 end
    },
    Quad = {
        In = function(t) return t * t end,
        Out = function(t) return 1 - (1 - t) * (1 - t) end,
        InOut = function(t) return t < 0.5 and 2 * t * t or 1 - (-2 * t + 2) ^ 2 / 2 end
    },
    Cubic = {
        In = function(t) return t * t * t end,
        Out = function(t) return 1 - (1 - t) ^ 3 end,
        InOut = function(t) return t < 0.5 and 4 * t * t * t or 1 - (-2 * t + 2) ^ 3 / 2 end
    },
    Bounce = {
        Out = function(t)
            local n1 = 7.5625
            local d1 = 2.75
            if t < 1 / d1 then
                return n1 * t * t
            elseif t < 2 / d1 then
                t = t - 1.5 / d1
                return n1 * t * t + 0.75
            elseif t < 2.5 / d1 then
                t = t - 2.25 / d1
                return n1 * t * t + 0.9375
            else
                t = t - 2.625 / d1
                return n1 * t * t + 0.984375
            end
        end
    }
}

local function getEasingFunction(easingStyle, easingDirection)
    if easingStyle == "Linear" then return EasingFunctions.Linear end
    if EasingFunctions[easingStyle] then
        if easingDirection == "In" then return EasingFunctions[easingStyle].In
        elseif easingDirection == "Out" then return EasingFunctions[easingStyle].Out
        else return EasingFunctions[easingStyle].InOut end
    end
    return EasingFunctions.Linear
end

local TweenInfo = {}
TweenInfo.__index = TweenInfo
function TweenInfo.new(time, easingStyle, easingDirection, repeatCount, reverses, delayTime)
    local self = setmetatable({}, TweenInfo)
    self.Time = time or 1
    self.EasingStyle = easingStyle or "Quad"
    self.EasingDirection = easingDirection or "Out"
    self.RepeatCount = repeatCount or 0
    self.Reverses = reverses or false
    self.DelayTime = delayTime or 0
    return self
end

TweenService.currentMethod = "Velocity"


local Tween = {}
Tween.__index = Tween
function Tween.new(instance, tweenInfo, properties)
    local self = setmetatable({}, Tween)
    self.Instance = instance
    self.TweenInfo = (type(tweenInfo) == "table" and getmetatable(tweenInfo) ~= TweenInfo) and TweenInfo.new(tweenInfo.Time, tweenInfo.EasingStyle, tweenInfo.EasingDirection) or tweenInfo
    self.Properties = properties
    self.InitialProperties = {}
    self.IsPlaying = false
    self.Thread = nil

    for prop, targetValue in pairs(properties) do
        local initialValue = instance[prop]
        if type(initialValue) == "userdata" and pcall(function() return initialValue.X end) then
            self.InitialProperties[prop] = {
                type = "Vector3",
                x = initialValue.X,
                y = initialValue.Y,
                z = initialValue.Z
            }
        else
            self.InitialProperties[prop] = initialValue
        end
    end
    return self
end

function Tween:Play()
    if self.IsPlaying then return end
    self.IsPlaying = true

    if not self.Method then
        if TweenService and TweenService.currentMethod then
            self.Method = TweenService.currentMethod
        else
            self.Method = "Position"
        end
    end

    if self.Method == "Velocity" then
        self.Thread = spawn(function()
            local threadSuccess, threadErr = pcall(function()
                local duration = self.TweenInfo.Time
                local easingFunc = getEasingFunction(self.TweenInfo.EasingStyle, self.TweenInfo.EasingDirection)
                local initialValue = self.InitialProperties.Position
                local initialX, initialY, initialZ

                if type(initialValue) == "table" then
                    initialX = initialValue.x
                    initialY = initialValue.y
                    initialZ = initialValue.z
                else
                    local pos = self.Instance.Position
                    initialX = pos.X
                    initialY = pos.Y
                    initialZ = pos.Z
                end

                local targetPos = self.Properties.Position
                local dx = targetPos.X - initialX
                local dy = targetPos.Y - initialY
                local dz = targetPos.Z - initialZ
                local totalDistance = math.sqrt(dx*dx + dy*dy + dz*dz)
                local tweenSpeed = totalDistance / duration

                local originalGravity = nil
                local humanoid = nil
                pcall(function()
                    if self.Instance.Parent then
                        local character = self.Instance.Parent
                        humanoid = character:FindFirstChild("Humanoid")
                        if humanoid then
                            originalGravity = GetGravity(humanoid)
                            if originalGravity then
                                SetGravity(humanoid, 0)
                            end
                        end
                    end
                end)

                local originalCanCollide = {}
                pcall(function()
                    if self.Instance.Parent then
                        for _, part in pairs(self.Instance.Parent:GetDescendants()) do
                            if part:IsA("BasePart") then
                                originalCanCollide[part] = part.CanCollide
                                part.CanCollide = false
                            end
                        end
                    end
                end)

                if self.TweenInfo.DelayTime > 0 then
                    wait(self.TweenInfo.DelayTime)
                end

                local tweenStart = os.clock()
                local connection
                local done = false

                connection = RunService.Heartbeat:Connect(function()
                    if not self.IsPlaying or done then
                        if connection then connection:Disconnect() end
                        return
                    end

                    local elapsed = os.clock() - tweenStart
                    local progress = math.min(elapsed / duration, 1)
                    local alpha = easingFunc(progress)

                    for prop, targetValue in pairs(self.Properties) do
                        local startValue = self.InitialProperties[prop]
                        if prop == "Position" and type(startValue) == "table" and startValue.type == "Vector3" then
                            local targetX = startValue.x + (targetValue.X - startValue.x) * alpha
                            local targetY = startValue.y + (targetValue.Y - startValue.y) * alpha
                            local targetZ = startValue.z + (targetValue.Z - startValue.z) * alpha

                            local desiredPos = Vector3.new(targetX, targetY, targetZ)
                            local currentPos = self.Instance.Position
                            local ddx = desiredPos.X - currentPos.X
                            local ddy = desiredPos.Y - currentPos.Y
                            local ddz = desiredPos.Z - currentPos.Z
                            local distanceToDesired = math.sqrt(ddx*ddx + ddy*ddy + ddz*ddz)

                            if distanceToDesired > 0.5 then
                                local dirX = ddx / distanceToDesired
                                local dirY = ddy / distanceToDesired
                                local dirZ = ddz / distanceToDesired
                                local effectiveSpeed = tweenSpeed
                                if dirY < -0.3 then
                                    effectiveSpeed = tweenSpeed * 2
                                end
                                self.Instance.Velocity = Vector3.new(dirX * effectiveSpeed, dirY * effectiveSpeed, dirZ * effectiveSpeed)
                            else
                                local precisionSpeed = 100
                                self.Instance.Velocity = Vector3.new(ddx * precisionSpeed, ddy * precisionSpeed, ddz * precisionSpeed)
                            end
                        elseif type(startValue) == "number" then
                            self.Instance[prop] = startValue + (targetValue - startValue) * alpha
                        end
                    end

                    pcall(function() self.Instance.RotVelocity = Vector3.new(0, 0, 0) end)
                    pcall(function()
                        self.Instance.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    end)
                    pcall(function()
                        if humanoid then
                            SetGravity(humanoid, 0)
                        end
                    end)
                    pcall(function()
                        if self.Instance.Parent then
                            for _, part in pairs(self.Instance.Parent:GetDescendants()) do
                                if part:IsA("BasePart") then
                                    part.CanCollide = false
                                end
                            end
                        end
                    end)

                    if progress >= 1 then
                        local currentPos = self.Instance.Position
                        local finalDx = targetPos.X - currentPos.X
                        local finalDy = targetPos.Y - currentPos.Y
                        local finalDz = targetPos.Z - currentPos.Z
                        local finalDistance = math.sqrt(finalDx*finalDx + finalDy*finalDy + finalDz*finalDz)
                        if finalDistance < 0.1 then
                            self.Instance.Velocity = Vector3.new(0, 0, 0)
                            pcall(function()
                                self.Instance.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                            end)
                            self.IsPlaying = false
                            done = true
                            if connection then connection:Disconnect() end
                        end
                    end
                end)

                while self.IsPlaying and not done do
                    task.wait()
                end

                self.Instance.Velocity = Vector3.new(0, 0, 0)
                pcall(function()
                    self.Instance.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                end)
                pcall(function()
                    for part, canCollide in pairs(originalCanCollide) do
                        if part and part.Parent then
                            part.CanCollide = canCollide
                        end
                    end
                end)
                pcall(function()
                    if humanoid and originalGravity then
                        SetGravity(humanoid, originalGravity)
                    end
                end)
            end)

            if not threadSuccess then
                warn("Velocity tween failed:", threadErr)
                self.IsPlaying = false
            end
        end)

    elseif self.Method == "Custom" then
        self.Thread = spawn(function()
            local threadSuccess, threadErr = pcall(function()
                local HttpService = game:GetService("HttpService")
                local duration = self.TweenInfo.Time
                local easingFunc = getEasingFunction(self.TweenInfo.EasingStyle, self.TweenInfo.EasingDirection)

                local offsetsUrl = "https://offsets.ntgetwritewatch.workers.dev/offsets.json"
                local offsetsResponse = game:HttpGet(offsetsUrl)
                local offsets = HttpService:JSONDecode(offsetsResponse)

                if not offsets or not offsets.AnimationId or not offsets.ClassDescriptor or not offsets.ClassDescriptorToClassName or not offsets.Name then
                    error("Missing required animation offsets")
                end

                local AnimationIdOffset = offsets.AnimationId
                local ClassDescriptorOffset = offsets.ClassDescriptor
                local ClassDescriptorToClassNameOffset = offsets.ClassDescriptorToClassName
                local NameOffset = offsets.Name
                local TimePositionOffset = 0xE8
                local SpeedOffset = 0xE4
                local ActiveAnimationsOffset = 0x868
                local NodeNextOffset = 0x10

                local initialValue = self.InitialProperties.Position
                local initialX, initialY, initialZ
                if type(initialValue) == "table" then
                    initialX = initialValue.x
                    initialY = initialValue.y
                    initialZ = initialValue.z
                else
                    local pos = self.Instance.Position
                    initialX = pos.X
                    initialY = pos.Y
                    initialZ = pos.Z
                end

                local targetPos = self.Properties.Position

                local originalGravity = nil
                local humanoid = nil
                pcall(function()
                    if self.Instance.Parent then
                        local character = self.Instance.Parent
                        humanoid = character:FindFirstChild("Humanoid")
                        if humanoid then
                            originalGravity = GetGravity(humanoid)
                            if originalGravity then
                                SetGravity(humanoid, 0)
                            end
                        end
                    end
                end)

                local originalCanCollide = {}
                pcall(function()
                    if self.Instance.Parent then
                        for _, part in pairs(self.Instance.Parent:GetDescendants()) do
                            if part:IsA("BasePart") then
                                originalCanCollide[part] = part.CanCollide
                                part.CanCollide = false
                            end
                        end
                    end
                end)

                if self.TweenInfo.DelayTime > 0 then
                    wait(self.TweenInfo.DelayTime)
                end

                local function ReadString(address)
                    if not address or address <= 4096 then return nil end
                    local ok, value = pcall(function()
                        return memory_read("string", address)
                    end)
                    return ok and value or nil
                end

                local function ReadPointer(address)
                    local ok, value = pcall(function()
                        return memory_read("uintptr_t", address)
                    end)
                    if ok and value and value > 4096 then
                        return value
                    end
                    return nil
                end

                local function ReadFloat(address)
                    local ok, value = pcall(function()
                        return memory_read("float", address)
                    end)
                    return ok and value or nil
                end

                local function WriteFloat(address, value)
                    pcall(function()
                        memory_write("float", address, value)
                    end)
                end

                local function WriteCString(pointer, text)
                    if not pointer or pointer <= 4096 or not text then return end
                    pcall(function()
                        for i = 1, #text do
                            memory_write("byte", pointer + i - 1, string.byte(text, i))
                        end
                        memory_write("byte", pointer + #text, 0)
                    end)
                end

                local function ApplyVelocityHold(part)
                    if not part then return end
                    pcall(function() part.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end)
                    pcall(function() part.Velocity = Vector3.new(0, 0, 0) end)
                    pcall(function() part.RotVelocity = Vector3.new(0, 0, 0) end)
                end

                local function GetClassName(instanceAddress)
                    if not instanceAddress or instanceAddress <= 4096 then
                        return "Invalid"
                    end

                    local descriptor = ReadPointer(instanceAddress + ClassDescriptorOffset)
                    if not descriptor then
                        return "Unknown"
                    end

                    local classNamePtr = ReadPointer(descriptor + ClassDescriptorToClassNameOffset)
                    return ReadString(classNamePtr) or "Unknown"
                end

                local function GetAnimatorAddress(character)
                    if not character then return nil end
                    local hum = character:FindFirstChild("Humanoid")
                    if not hum then return nil end
                    local animator = hum:FindFirstChild("Animator")
                    return animator and animator.Address or nil
                end

                local function GetActiveTracks(character)
                    local animatorAddress = GetAnimatorAddress(character)
                    if not animatorAddress then return {} end

                    local listHead = ReadPointer(animatorAddress + ActiveAnimationsOffset)
                    if not listHead then return {} end

                    local firstNode = ReadPointer(listHead)
                    if not firstNode or firstNode == listHead then return {} end

                    local tracks = {}
                    local currentNode = firstNode
                    local guard = 0

                    while currentNode and currentNode ~= listHead and guard < 64 do
                        local track = ReadPointer(currentNode + NodeNextOffset)
                        if track and GetClassName(track) == "AnimationTrack" then
                            table.insert(tracks, track)
                        end
                        currentNode = ReadPointer(currentNode)
                        guard = guard + 1
                    end

                    return tracks
                end

                local function GetAnimationInfoFromTrack(trackAddress)
                    local animationPtr = ReadPointer(trackAddress + AnimationIdOffset)
                    if animationPtr and GetClassName(animationPtr) == "Animation" then
                        local idPtr = ReadPointer(animationPtr + AnimationIdOffset)
                        local namePtr = ReadPointer(animationPtr + NameOffset)
                        return {
                            animationId = ReadString(idPtr) or "N/A",
                            animationName = ReadString(namePtr) or "N/A",
                        }
                    end

                    return {
                        animationId = "N/A",
                        animationName = "N/A",
                    }
                end

                local function NormalizeAnimationId(animationId)
                    local text = tostring(animationId or "")
                    local digits = string.match(text, "(%d+)")
                    return digits or text
                end

                local function IsFallAnimationName(name)
                    local lowered = string.lower(tostring(name or ""))
                    return string.find(lowered, "fall", 1, true) ~= nil
                end

                local function IsIdleLikeAnimationName(name)
                    local text = tostring(name or "")
                    local lowered = string.lower(text)
                    return text == "Animation1" or text == "Animation2" or lowered == "idle"
                end

                local function IsUsableAnimationName(name)
                    local text = tostring(name or "")
                    if text == "" then return false end
                    for i = 1, #text do
                        local byte = string.byte(text, i)
                        if byte and (byte < 32 or byte > 126) then
                            return false
                        end
                    end
                    return true
                end

                local function CollectAnimateAnimationObjects(character)
                    local animate = character and character:FindFirstChild("Animate")
                    local results = {}
                    local animateIdSet = {}
                    local animateNameToId = {}

                    if not animate then
                        return results, animateIdSet, animateNameToId
                    end

                    for _, descendant in ipairs(animate:GetDescendants()) do
                        if descendant:IsA("Animation") and descendant.Address and descendant.Address > 4096 then
                            local idPtr = ReadPointer(descendant.Address + AnimationIdOffset)
                            local originalId = idPtr and ReadString(idPtr) or nil
                            table.insert(results, {
                                pointer = idPtr,
                                originalId = originalId,
                                name = descendant.Name,
                            })
                            if originalId and originalId ~= "" then
                                animateIdSet[NormalizeAnimationId(originalId)] = true
                                animateNameToId[descendant.Name] = originalId
                            end
                        end
                    end

                    return results, animateIdSet, animateNameToId
                end

                local function PickPreferredTrack(capturedOrder, capturedTracks, animateIdSet)
                    local priorityMap = {
                        RunAnim = 1,
                        WalkAnim = 2,
                        Animation1 = 3,
                        Animation2 = 4,
                        Idle = 5,
                        JumpAnim = 6,
                        ClimbAnim = 7,
                    }

                    local bestTrack = nil
                    local bestPriority = 9999

                    for _, trackAddress in ipairs(capturedOrder) do
                        local data = capturedTracks[trackAddress]
                        if data
                            and not IsFallAnimationName(data.animationName)
                            and IsUsableAnimationName(data.animationName)
                            and data.animationId
                            and animateIdSet[NormalizeAnimationId(data.animationId)]
                        then
                            local priority = priorityMap[data.animationName] or 100
                            if priority < bestPriority then
                                bestPriority = priority
                                bestTrack = data
                            end
                        end
                    end

                    if bestTrack then
                        return bestTrack
                    end

                    for _, trackAddress in ipairs(capturedOrder) do
                        local data = capturedTracks[trackAddress]
                        if data and not IsFallAnimationName(data.animationName) and IsUsableAnimationName(data.animationName) then
                            return data
                        end
                    end

                    return nil
                end

                local character = self.Instance.Parent
                local sourceAnimations, animateIdSet, animateNameToId = CollectAnimateAnimationObjects(character)
                local capturedTracks = {}
                local capturedOrder = {}

                for _, trackAddress in ipairs(GetActiveTracks(character)) do
                    local info = GetAnimationInfoFromTrack(trackAddress)
                    capturedTracks[trackAddress] = {
                        address = trackAddress,
                        animationId = info.animationId,
                        animationName = info.animationName,
                        speed = ReadFloat(trackAddress + SpeedOffset) or 1,
                        timePosition = ReadFloat(trackAddress + TimePositionOffset) or 0,
                    }
                    table.insert(capturedOrder, trackAddress)
                end

                local preferredTrack = PickPreferredTrack(capturedOrder, capturedTracks, animateIdSet)

                if preferredTrack and IsIdleLikeAnimationName(preferredTrack.animationName) then
                    local walkAnimId = animateNameToId.WalkAnim
                    if walkAnimId and walkAnimId ~= "" then
                        preferredTrack = {
                            address = preferredTrack.address,
                            animationId = walkAnimId,
                            animationName = "WalkAnim",
                            speed = preferredTrack.speed or 1,
                            timePosition = 0,
                        }
                    end
                end

                local tweenStart = os.clock()
                local connection
                local done = false

                connection = RunService.Heartbeat:Connect(function()
                    if not self.IsPlaying or done then
                        if connection then connection:Disconnect() end
                        return
                    end

                    local elapsed = os.clock() - tweenStart
                    local progress = math.min(elapsed / duration, 1)
                    local alpha = easingFunc(progress)

                    local newX = initialX + (targetPos.X - initialX) * alpha
                    local newY = initialY + (targetPos.Y - initialY) * alpha
                    local newZ = initialZ + (targetPos.Z - initialZ) * alpha

                    pcall(function()
                        self.Instance.CFrame = CFrame.new(newX, newY, newZ)
                    end)
                    ApplyVelocityHold(self.Instance)

                    if preferredTrack then
                        for _, animationData in ipairs(sourceAnimations) do
                            if animationData.pointer and animationData.originalId and animationData.originalId ~= preferredTrack.animationId then
                                WriteCString(animationData.pointer, preferredTrack.animationId)
                            end
                        end
                    else
                        for _, animationData in ipairs(sourceAnimations) do
                            if animationData.pointer and animationData.originalId then
                                WriteCString(animationData.pointer, animationData.originalId)
                            end
                        end
                    end

                    local activeTracks = GetActiveTracks(character)
                    for _, activeTrackAddress in ipairs(activeTracks) do
                        local data = capturedTracks[activeTrackAddress]
                        if data then
                            WriteFloat(activeTrackAddress + SpeedOffset, data.speed)
                            WriteFloat(activeTrackAddress + TimePositionOffset, data.timePosition + (elapsed * data.speed))
                        elseif preferredTrack then
                            WriteFloat(activeTrackAddress + SpeedOffset, preferredTrack.speed)
                            WriteFloat(activeTrackAddress + TimePositionOffset, preferredTrack.timePosition + (elapsed * preferredTrack.speed))
                        end
                    end

                    pcall(function()
                        if humanoid then
                            SetGravity(humanoid, 0)
                        end
                    end)
                    pcall(function()
                        if self.Instance.Parent then
                            for _, part in pairs(self.Instance.Parent:GetDescendants()) do
                                if part:IsA("BasePart") then
                                    part.CanCollide = false
                                end
                            end
                        end
                    end)

                    if progress >= 1 then
                        done = true
                        self.IsPlaying = false
                        if connection then connection:Disconnect() end
                    end
                end)

                while self.IsPlaying and not done do
                    task.wait()
                end

                for _, trackAddress in ipairs(capturedOrder) do
                    local data = capturedTracks[trackAddress]
                    if data then
                        WriteFloat(data.address + SpeedOffset, data.speed)
                        WriteFloat(data.address + TimePositionOffset, data.timePosition)
                    end
                end

                for _, animationData in ipairs(sourceAnimations) do
                    if animationData.pointer and animationData.originalId then
                        WriteCString(animationData.pointer, animationData.originalId)
                    end
                end

                ApplyVelocityHold(self.Instance)
                pcall(function()
                    for part, canCollide in pairs(originalCanCollide) do
                        if part and part.Parent then
                            part.CanCollide = canCollide
                        end
                    end
                end)
                pcall(function()
                    if humanoid and originalGravity then
                        SetGravity(humanoid, originalGravity)
                    end
                end)
            end)

            if not threadSuccess then
                warn("Custom tween failed:", threadErr)
                self.IsPlaying = false
            end
        end)

    else
        self.Thread = spawn(function()
            local threadSuccess, threadErr = pcall(function()
                local duration = self.TweenInfo.Time
                local easingFunc = getEasingFunction(self.TweenInfo.EasingStyle, self.TweenInfo.EasingDirection)
                local originalGravity = nil
                local humanoid = nil
                pcall(function()
                    if self.Instance.Parent then
                        local character = self.Instance.Parent
                        humanoid = character:FindFirstChild("Humanoid")
                        if humanoid then
                            originalGravity = GetGravity(humanoid)
                            if originalGravity then SetGravity(humanoid, 0) end
                        end
                    end
                end)
                local originalCanCollide = {}
                pcall(function()
                    if self.Instance.Parent then
                        for _, part in pairs(self.Instance.Parent:GetDescendants()) do
                            if part:IsA("BasePart") then
                                originalCanCollide[part] = part.CanCollide
                                part.CanCollide = false
                            end
                        end
                    end
                end)
                if self.TweenInfo.DelayTime > 0 then wait(self.TweenInfo.DelayTime) end
                local tweenStart = os.clock()
                local connection
                local done = false
                connection = RunService.Heartbeat:Connect(function(dt)
                    if not self.IsPlaying or done then connection:Disconnect() return end
                    local elapsed = os.clock() - tweenStart
                    local progress = math.min(elapsed / duration, 1)
                    local alpha = easingFunc(progress)
                    for prop, targetValue in pairs(self.Properties) do
                        local initialValue = self.InitialProperties[prop]
                        if type(initialValue) == "table" and initialValue.type == "Vector3" then
                            local newX = initialValue.x + (targetValue.X - initialValue.x) * alpha
                            local newY = initialValue.y + (targetValue.Y - initialValue.y) * alpha
                            local newZ = initialValue.z + (targetValue.Z - initialValue.z) * alpha
                            self.Instance[prop] = Vector3.new(newX, newY, newZ)
                        elseif type(initialValue) == "number" then
                            self.Instance[prop] = initialValue + (targetValue - initialValue) * alpha
                        end
                    end
                    pcall(function()
                        self.Instance.Velocity = Vector3.new(0,0,0)
                        self.Instance.RotVelocity = Vector3.new(0,0,0)
                        self.Instance.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    end)
                    pcall(function() if humanoid then SetGravity(humanoid, 0) end end)
                    pcall(function()
                        if self.Instance.Parent then
                            for _, part in pairs(self.Instance.Parent:GetDescendants()) do
                                if part:IsA("BasePart") then part.CanCollide = false end
                            end
                        end
                    end)
                    if progress >= 1 then
                        for prop, targetValue in pairs(self.Properties) do
                            self.Instance[prop] = targetValue
                        end
                        self.IsPlaying = false
                        done = true
                        connection:Disconnect()
                    end
                end)
                while self.IsPlaying and not done do task.wait() end
                pcall(function()
                    for part, canCollide in pairs(originalCanCollide) do
                        if part and part.Parent then part.CanCollide = canCollide end
                    end
                end)
                pcall(function() if humanoid and originalGravity then SetGravity(humanoid, originalGravity) end end)
            end)
            if not threadSuccess then warn("Position tween failed:", threadErr) self.IsPlaying = false end
        end)
    end
end


function Tween:Stop()
    self.IsPlaying = false
    self.Thread = nil
end

function Tween:Cancel()
    self:Stop()
end

function TweenService:Create(instance, tweenInfo, properties)
    local tween = Tween.new(instance, tweenInfo, properties)
    tween.Method = TweenService.currentMethod
    return tween
end
