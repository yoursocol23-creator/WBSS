    if not self.aiDebug then
        return
    end

    print("MatchaMind", tostring(event), ...)
end

function UI:DebugAIVerbose(event, ...)
    if not self.aiDebug or not self.aiDebugVerbose then
        return
    end

    print("MatchaMind", tostring(event), ...)
end

function UI:SetAIStage(stage)
    self.aiLastStage = tostring(stage or "idle")
end

function UI:FormatAIError(message)
    local text = self:TrimText(tostring(message or "unknown error"))
    if text == "" then
        text = "unknown error"
    end

    if #text > 420 then
        text = text:sub(1, 420) .. "..."
    end

    if text:sub(1, 15) == "Request failed:" then
        return text
    end

    return "Request failed: " .. text
end

function UI:GetAIResponseCommand(response)
    if type(response) == "string" then
        local trimmed = self:TrimText(response)
        local first = trimmed:sub(1, 1)
        if first == "{" or first == "[" then
            local ok, decoded = pcall(function()
                return HttpService:JSONDecode(trimmed)
            end)
            if ok then
                response = decoded
            else
                return nil
            end
        else
            return nil
        end
    end

    if type(response) ~= "table" then
        return nil
    end

    if #response > 0 then
        return response
    end

    if response.commands ~= nil then
        return response.commands
    end

    if response.actions ~= nil then
        return response.actions
    end

    if response.command ~= nil then
        if type(response.command) == "table" then
            return response.command
        end
        if response.id ~= nil or response.controlId ~= nil or response.control_id ~= nil or response.value ~= nil or response.params ~= nil then
            return response
        end
        return response.command
    end

    if response.action ~= nil then
        if type(response.action) == "table" then
            return response.action
        end
        return response
    end

    local actionType = response.type or response.name
    if actionType == "set_control" or actionType == "run_action" then
        return response
    end

    return nil
end

function UI:ExecuteAICommand(command)
    local function normalizeValue(value)
        if type(value) == "string" then
            local lowered = value:lower()
            if lowered == "true" or lowered == "on" or lowered == "enabled" then
                return true
            elseif lowered == "false" or lowered == "off" or lowered == "disabled" then
                return false
            end
        end

        return value
    end

    local function executeOne(item)
        if type(item) == "string" then
            item = {
                action = item,
            }
        end

        if type(item) ~= "table" then
            return "invalid command"
        end

        if #item > 0 and not item.action and not item.type and not item.command and not item.name then
            local results = {}
            for _, nested in ipairs(item) do
                table.insert(results, executeOne(nested))
            end
            return table.concat(results, "; ")
        end

        local params = type(item.params) == "table" and item.params
            or type(item.arguments) == "table" and item.arguments
            or {}
        local action = tostring(item.action or item.type or item.command or item.name or "")
        local id = item.id or item.controlId or item.control_id or params.id or params.controlId or params.control_id
        local value = normalizeValue(item.value)
        if value == nil then
            value = normalizeValue(params.value)
        end

        if action == "set_control" or action == "run_action" then
            if not id or tostring(id) == "" then
                return "command missing control id"
            end

            local control = self:GetControlById(tostring(id))
            if not control then
                return "could not find control: " .. tostring(id)
            end

            local previousValue = self:GetControlRawValue(control, nil)
            local ok = self:SetControlValue(tostring(id), value, false)
            if ok and action == "run_action" and previousValue == value then
                self:RunAction(control, value)
            elseif not ok and action == "run_action" then
                self:RunAction(control, value)
                ok = true
            end

            return ok and ("done, " .. tostring(id) .. " set to " .. tostring(value))
                or ("could not set " .. tostring(id))
        end

        return "unsupported command: " .. tostring(action)
    end

    return executeOne(command)
end

function UI:CompleteAIRequest(requestSerial, reply)
    if self.aiRequestSerial ~= requestSerial then
        self:DebugAI("late response ignored", tostring(requestSerial), "current", tostring(self.aiRequestSerial))
        return false
    end

    self.aiIsSending = false
    self.aiRequestStartedAt = nil
    self.aiActiveJobId = nil
    self.aiPollingStartedAt = nil
    self.aiLastPollAt = 0
    self.aiPollInFlight = false
    self.aiNextPollAt = 0

    local command = self:GetAIResponseCommand(reply)
    if command then
        local ok, result = pcall(function()
            return self:ExecuteAICommand(command)
        end)
        reply = ok and result or self:FormatAIError(result)
    elseif type(reply) == "table" then
        reply = reply.reply or reply.text or reply.message or ""
    end

    self:DebugAI("complete", "serial", tostring(requestSerial), "chars", tostring(#tostring(reply or "")))
    self:AddAIMessage("assistant", reply or "")
    self:SetAIStage("idle")
    self:MarkCurrentTabDirty()
    return true
end

function UI:FailAIRequest(requestSerial, message)
    self:DebugAI("error", tostring(message or "unknown error"))
    return self:CompleteAIRequest(requestSerial, self:FormatAIError(message))
end

function UI:UpdateAIRequestTimeout()
    if not self.aiIsSending then
        return
    end

    local startedAt = self.aiRequestStartedAt
    if not startedAt then
        return
    end

    local timeout = self.aiUsePolling and (tonumber(self.aiPollTimeout) or 45) or (tonumber(self.aiRequestTimeout) or 30)
    if (tick() - startedAt) < timeout then
        return
    end

    local lastStage = self.aiLastStage or "unknown"
    local jobId = self.aiActiveJobId or "none"
    self.aiIsSending = false
    self.aiRequestStartedAt = nil
    self.aiActiveJobId = nil
    self.aiPollingStartedAt = nil
    self.aiLastPollAt = 0
    self.aiPollInFlight = false
    self.aiNextPollAt = 0
    self.aiRequestSerial = (self.aiRequestSerial or 0) + 1
    self:DebugAI("timeout", "after", tostring(timeout), "seconds", "stage", tostring(lastStage), "job", tostring(jobId))
    self:AddAIMessage("assistant", self:FormatAIError("backend did not respond after " .. tostring(timeout) .. "s. Last stage: " .. tostring(lastStage) .. ". Job: " .. tostring(jobId)))
    self:SetAIStage("idle")
    self:MarkCurrentTabDirty()
end

function UI:SpawnAIThread(callback)
    if type(callback) ~= "function" then
        return false
    end

    if task and type(task.spawn) == "function" then
        self:DebugAI("scheduler", "task.spawn")
        local ok = pcall(function()
            task.spawn(callback)
        end)
        if ok then
            return true
        end
        self:DebugAI("scheduler error", "task.spawn")
    end

    if type(spawn) == "function" then
        self:DebugAI("scheduler", "spawn")
        local ok = pcall(function()
            spawn(callback)
        end)
        if ok then
            return true
        end
        self:DebugAI("scheduler error", "spawn")
    end

    if type(delay) == "function" then
        self:DebugAI("scheduler", "delay")
        local ok = pcall(function()
            delay(0, callback)
        end)
        if ok then
            return true
        end
        self:DebugAI("scheduler error", "delay")
    end

    if task and type(task.defer) == "function" then
        self:DebugAI("scheduler", "task.defer")
        local ok = pcall(function()
            task.defer(callback)
        end)
        if ok then
            return true
        end
        self:DebugAI("scheduler error", "task.defer")
    end

    return false
end

function UI:WaitAI(seconds)
    if task and type(task.wait) == "function" then
        task.wait(seconds or 0)
    elseif type(wait) == "function" then
        wait(seconds or 0)
    end
end

