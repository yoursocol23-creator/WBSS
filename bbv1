function UI:BuildShell()
    self.shellRebuilds = (self.shellRebuilds or 0) + 1

    local bucket = self.shellBucket
    self:BeginBucket(bucket)
    self.renderAlpha = self.uiAlpha

    local wx, wyBase = self:GetRenderWindowPosition()
    local wy = wyBase + self:GetAnimatedWindowYOffset()
    local ww = self.window.width
    local wh = self.window.height
    local sidebarW = self.window.sidebarWidth

    -- Main shell stays square-based for performance; rounded loading keeps the heavier circles.
    self:CreateSquare(bucket, wx - 1, wy - 1, ww + 2, wh + 2, Theme.dark, 0.65, true)
    self:CreateSquare(bucket, wx, wy, ww, wh, Theme.accent, 1, false, 1)
    self:CreateSquare(bucket, wx + 1, wy + 1, ww - 2, wh - 2, Theme.border, 1, false, 1)
    self:CreateSquare(bucket, wx + 2, wy + 2, ww - 4, wh - 4, Theme.bg, 1, true)
    self:CreateSquare(bucket, wx + 1, wy + 1, sidebarW - 1, wh - 2, Theme.sidebar, 1, true)

    -- Obsidian-style header/logo/search
    self:DrawObsidianHeader(bucket, wx, wy, ww, wh, sidebarW)
    self:RegisterSearchHitbox()

    -- Tabs
    local tabY = wy + 58
    local tabStep = 40
    local buttonX = wx + 1
    local buttonW = sidebarW - 2
    local buttonH = 40

    local highlightY = wy + math.floor((self.activeTabHighlightY or 58) + 0.5)

    -- Active tab row
    self:CreateSquare(bucket, buttonX, highlightY, buttonW, buttonH, Theme.panel, 1, true)
    self:CreateSquare(bucket, buttonX, highlightY, 2, buttonH, Theme.accent, 1, true)

    for tabIndex, tab in ipairs(self.tabs) do
        local selectedAmount = self.animationState.tabActive[tabIndex] or (self.selectedTab == tabIndex and 1 or 0)
        local hoverAmount = self.animationState.tabHover[tabIndex] or 0

        local buttonY = tabY + ((tabIndex - 1) * tabStep)
        local isSelected = selectedAmount > 0.99
        local showImages = not self:AreUIImagesDisabled()

        if not isSelected then
            self:CreateSquare(
                bucket,
                buttonX,
                buttonY,
                buttonW,
                buttonH,
                LerpColor(Theme.sidebar, Theme.panel, hoverAmount),
                0.35 * hoverAmount,
                true
            )
        end

        if hoverAmount > 0.01 and not isSelected then
            self:CreateSquare(
                bucket,
                buttonX + 1,
                buttonY + 1,
                buttonW - 2,
                buttonH - 2,
                Theme.topHighlight,
                0.04 * hoverAmount,
                true
            )
        end

        -- Tab icon/logo
        local tabTextX = showImages and (wx + 22) or (wx + 18)
        local iconAlpha = isSelected and 1 or (hoverAmount > 0.01 and 0.75 or 0.5)

        if showImages then
            local iconData = self:GetTabIconData(tab)
            if iconData then
                local iconObj = self:CreateImage(bucket, iconData, wx + 14, buttonY + 12, 16, 16, iconAlpha)

                if iconObj then
                    tabTextX = wx + 40
                end
            else
                -- fallback dot if image fails
                self:CreateCircle(
                    bucket,
                    wx + 22,
                    buttonY + 20,
                    3,
                    LerpColor(Theme.textDim, Theme.accent, selectedAmount),
                    iconAlpha,
                    true
                )

                tabTextX = wx + 40
            end
        end

        self:CreateText(
            bucket,
            tab.name,
            tabTextX,
            buttonY + 13,
            LerpColor(
                LerpColor(Theme.textDim, Theme.text, hoverAmount),
                Theme.text,
                selectedAmount
            ),
            13,
            false
        )

        self:RegisterHitbox("tab_" .. tostring(tabIndex), buttonX, buttonY, buttonW, buttonH, function()
            if self.selectedTab ~= tabIndex then
                self.selectedTab = tabIndex
                self.searchFocused = false
                self.activeTextInput = nil
                self.activeDropdownSearch = nil
                self.activeKeybind = nil
                self:ZeroSearchKeys()
                self:UpdateRobloxInputCapture()
                if tabIndex == 1 then
                    self:RefreshHomeStats(true)
                end
                self.expandedDropdown = nil
                self.scroll.offset = 0
                self:ResetContentAnimation()
                self:UpdateScrollLimit()
                self:MarkShellDirty()
                self:MarkCurrentTabDirty()
            end
        end, 1)
    end

    -- Footer
    self:CreateLine(bucket, wx + 4, wy + wh - 24, wx + ww - 4, wy + wh - 24, Theme.border, 1, 1)
    self:CreateText(bucket, self.footerText or "No Footer", wx + math.floor(ww / 2), wy + wh - 17, Theme.textMuted, 12, true)
    self:CreateLine(bucket, wx + ww - 18, wy + wh - 5, wx + ww - 5, wy + wh - 18, Theme.textMuted, 0.5, 1)
    self:CreateLine(bucket, wx + ww - 12, wy + wh - 5, wx + ww - 5, wy + wh - 12, Theme.textMuted, 0.5, 1)

    -- Drag hitbox
    self:RegisterHitbox("window_drag", wx, wy, ww, 18, function()
        self.draggingWindow = true
        local mousePos = self:GetMouseLocation()
        self.dragOffsetX = mousePos.X - wx
        self.dragOffsetY = mousePos.Y - wy
    end, 1)

    self:RegisterHitbox("window_resize", wx + ww - 22, wy + wh - 22, 22, 22, function()
        self.draggingResize = true
        local mousePos = self:GetMouseLocation()
        self.resizeOffsetX = (self.window.x + self.window.width) - mousePos.X
        self.resizeOffsetY = (self.window.y + self.window.height) - mousePos.Y
    end, 4)

    self:EndBucket(bucket)
    self.renderAlpha = 1
end

function UI:DrawCheapObsidianSpinner(bucket, centerX, centerY)
    local step = math.floor((tick() * 8) % 4)
    local radius = 23

    for i = 0, 3 do
        local angle = ((i + step) / 4) * math.pi * 2
        local alpha = i == 0 and 1 or (i == 1 and 0.65 or 0.35)

        local x1 = centerX + math.cos(angle) * 10
        local y1 = centerY + math.sin(angle) * 10
        local x2 = centerX + math.cos(angle) * radius
        local y2 = centerY + math.sin(angle) * radius

        self:CreateLine(bucket, x1, y1, x2, y2, Theme.accent, alpha, 3)
    end
end

function UI:GetLoadingSpinnerRotation()
    local tweenTime = tonumber(self.loadingIconTweenTime) or 1

    if tweenTime <= 0 then
        return 0
    end

    return ((tick() / tweenTime) * 360) % 360
end

function UI:UpdateLoadingAnimation(dt)
    local elapsed = tick() - (self.bootStartedAt or tick())
    local duration = math.max(0.01, self.bootDuration or 5)

    local progress = math.clamp(elapsed / duration, 0, 1)

    self.bootVisualProgress = progress
    self.loadingAnimatedProgress = progress
    self.loadingSpinnerRotation = self:GetLoadingSpinnerRotation()
end

function UI:DrawLoadingSidebar(bucket, loadX, loadY, loadH, contentW, sidebarW, currentStep, totalSteps)
    if self.loadingShowSidebar ~= true then
        return
    end

    local sidebarX = loadX + contentW
    local sidebarY = loadY
    local sidebarH = loadH

    self:CreateSquare(bucket, sidebarX, sidebarY + 1, sidebarW - 1, sidebarH - 2, Theme.panel, 1, true)
    self:CreateLine(bucket, sidebarX, sidebarY + 1, sidebarX, sidebarY + sidebarH - 2, Theme.border, 1, 1)

    self:CreateText(bucket, self.loadingSidebarTitle or "LOADING", sidebarX + 16, sidebarY + 18, Theme.textDim, 13, false)

    local items = self.loadingSidebarItems or {}
    local itemCount = math.max(#items, 1)
    local progress = math.clamp((currentStep or 0) / math.max(totalSteps or 10, 1), 0, 1)
    local activeIndex = math.clamp(math.floor(progress * itemCount) + 1, 1, itemCount)

    local startY = sidebarY + 54

    for i, text in ipairs(items) do
        local rowY = startY + ((i - 1) * 32)
        local active = i == activeIndex
        local done = i < activeIndex

        if rowY + 26 <= sidebarY + sidebarH - 12 then
            if active then
                self:CreateSquare(bucket, sidebarX + 12, rowY, sidebarW - 24, 26, Theme.bg, 1, true)
                self:CreateSquare(bucket, sidebarX + 12, rowY, 2, 26, Theme.accent, 1, true)
            end

            local dotColor = done and Theme.accent or (active and Theme.text or Theme.textMuted)
            self:CreateCircle(bucket, sidebarX + 24, rowY + 13, 3, dotColor, 1, true)

            self:CreateText(
                bucket,
                tostring(text),
                sidebarX + 36,
                rowY + 6,
                active and Theme.text or Theme.textDim,
                13,
                false
            )
        end
    end
end

function UI:BuildLoadingScreen()
    local bucket = self.loadingBucket
    self:BeginBucket(bucket)
    self.renderAlpha = 1
    self.renderScale = 1

    local loadX, loadY, loadW, loadH, contentW, sidebarW = self:GetLoadingBounds()
    local contentX = loadX
    local contentY = loadY

    self:DrawRoundedWindow(bucket, loadX, loadY, loadW, loadH)

    local topBarH = 48

    local progress = math.clamp(self.loadingAnimatedProgress or self.bootVisualProgress or 0, 0, 1)
    local totalSteps = 10
    local currentStep = math.clamp(math.floor(progress * totalSteps), 0, totalSteps)

    -- Optional right sidebar, Obsidian-style layout
    self:DrawLoadingSidebar(bucket, loadX, loadY, loadH, contentW, sidebarW, currentStep, totalSteps)

    -- Title icon 30x30 inside the content container
    local iconSize = 30
    local iconX = contentX + 12
    local iconY = contentY + 9

    local loadingLogoData = self:GetLoadingLogoImageData()
    local drewLoadingLogo = false

    if loadingLogoData then
        local logoObj = self:CreateImage(bucket, loadingLogoData, iconX, iconY, iconSize, iconSize, 1)
        drewLoadingLogo = logoObj ~= nil
    end

    if not drewLoadingLogo then
        self:CreateRoundedBox(bucket, iconX, iconY, iconSize, iconSize, 4, Theme.panel)
        self:CreateRoundedBox(bucket, iconX, iconY, iconSize, iconSize, 4, Theme.border)
        self:CreateText(bucket, "m", iconX + 15, iconY + 6, Theme.text, 16, true)
    end

    self:CreateText(bucket, self.title or "obsidian base", contentX + 48, contentY + 14, Theme.text, 20, false)

    -- Divider only across the content container, like Obsidian's Container line
    self:CreateLine(bucket, contentX + 1, contentY + topBarH, contentX + contentW - 1, contentY + topBarH, Theme.border, 1, 1)

    local contentTop = contentY + topBarH
    local centerX = contentX + math.floor(contentW / 2)

    -- Spinner 64x64 area
    local spinnerCenterY = contentTop + 62
    local spinnerData = self:GetLoadingSpinnerImageData()
    local spinnerObj = nil

    if spinnerData then
        spinnerObj = self:CreateImage(bucket, spinnerData, centerX - 32, spinnerCenterY - 32, 64, 64, 1)

        if spinnerObj then
            pcall(function()
                spinnerObj.Rotation = self.loadingSpinnerRotation or 0
            end)
        end
    end

    if not spinnerObj then
        self:DrawCheapObsidianSpinner(bucket, centerX, spinnerCenterY)
    end

    local msg = self.bootReady and "Ready" or "Loading"
    local desc = self.bootReady and "Finished" or "Please wait..."

    self:CreateText(bucket, msg, centerX, spinnerCenterY + 42, Theme.text, 18, true)
    self:CreateText(bucket, desc, centerX, spinnerCenterY + 66, Theme.textDim, 14, true)

    local barW = math.floor(contentW * 0.7)
    local barH = 15
    local barX = contentX + math.floor((contentW - barW) / 2)
    local barY = spinnerCenterY + 98

    self:DrawRoundedBar(bucket, barX, barY, barW, barH, progress)

    self:CreateText(
        bucket,
        tostring(currentStep) .. "/" .. tostring(totalSteps),
        barX + math.floor(barW / 2),
        barY + 3,
        Theme.text,
        14,
        true
    )

    self:EndBucket(bucket)
    self.renderAlpha = 1
    self.renderScale = 1
end

function UI:BuildActiveTab()
    self.tabRebuilds = (self.tabRebuilds or 0) + 1

    local bucket = self.tabBuckets[self.selectedTab]
    self:BeginBucket(bucket)
    self.renderAlpha = self.uiAlpha * self.contentAlpha

    local x, y, width, height = self:GetContentBounds()
    self:DrawObsidianActiveTab(bucket)

    if self.selectedTab == self.aiTabIndex then
        self:EndBucket(bucket)
        self.renderAlpha = 1
        return
    end

    local scrollbarX, scrollbarY, scrollbarW, scrollbarH, thumbY, thumbH = self:GetScrollbarMetrics()
    self:CreateSquare(bucket, scrollbarX, scrollbarY, scrollbarW, scrollbarH, Theme.panel, 1, true)
    self:CreateSquare(bucket, scrollbarX, scrollbarY, scrollbarW, scrollbarH, Theme.borderSoft, 1, false, 1)


    if self.scroll.max <= 0 then
        self:CreateSquare(bucket, scrollbarX + 1, scrollbarY + 1, scrollbarW - 2, scrollbarH - 2, Theme.panelAlt, 0.55, true)
    else
        local animatedThumbY = math.floor((self.animatedScrollThumbY or thumbY) + 0.5)
        self:CreateSquare(bucket, scrollbarX + 1, animatedThumbY, scrollbarW - 2, thumbH, Theme.accent, 1, true)
        self:CreateLine(bucket, scrollbarX + 1, animatedThumbY, scrollbarX + scrollbarW - 2, animatedThumbY, Theme.success, 0.18, 1)
        self:RegisterHitbox("scrollbar_thumb", scrollbarX - 10, animatedThumbY - 2, scrollbarW + 20, thumbH + 4, function()
            self.draggingScroll = true
            self.scrollDragOffset = self:GetMouseLocation().Y - animatedThumbY
        end, 3)
    end

    self:EndBucket(bucket)
    self.renderAlpha = 1
end

function UI:Render()
    self.redrawCount = (self.redrawCount or 0) + 1
    self.hitboxes = {}

    if self.isBooting then
        self:HideBucket(self.shellBucket)
        for _, bucket in ipairs(self.tabBuckets) do
            self:HideBucket(bucket)
        end
        self:BuildLoadingScreen()
        self.needsRedraw = false
        return
    end

    if not self.loadingClearedAfterBoot then
        self:ClearBucket(self.loadingBucket)
        self.loadingClearedAfterBoot = true
    else
        self:HideBucket(self.loadingBucket)
    end

    if (not self.uiVisible) and (self.uiAlpha or 0) <= 0.01 then
        self:ClearAllBuckets()
        self.hiddenCleared = true
        self.needsRedraw = false
        return
    end

    self:UpdateScrollLimit()

    for tabIndex, bucket in ipairs(self.tabBuckets) do
        if tabIndex ~= self.selectedTab then
            self:HideBucket(bucket)
        end
    end

    local shellRebuiltThisFrame = false

    if self.shellDirty or not self.shellBucket.built then
        self:BuildShell()
        self.shellDirty = false
        shellRebuiltThisFrame = true
    else
        self:ShowBucket(self.shellBucket)
        self:RegisterShellHitboxes()
    end

    if shellRebuiltThisFrame or self.tabDirty[self.selectedTab] or not self.tabBuckets[self.selectedTab].built then
        self:BuildActiveTab()
        self.tabDirty[self.selectedTab] = false
    else
        self:ShowBucket(self.tabBuckets[self.selectedTab])
        self:RegisterActiveTabHitboxes()
    end

    self.needsRedraw = false
end

function UI:DebugPerfReport(force)
    if not self.debugPerf then
        return
    end

    local now = tick()
    if not force and (now - (self.lastPerfDebugTick or 0)) < 10 then
        return
    end

    self.lastPerfDebugTick = now

    local tabCounts = {}
    for index, bucket in ipairs(self.tabBuckets or {}) do
        tabCounts[index] = tostring(#(bucket.objects or {}))
    end

    print(
        "[ObsidianPerf]",
        "shell=" .. tostring(#(self.shellBucket.objects or {})),
        "loading=" .. tostring(#(self.loadingBucket.objects or {})),
        "tabs=" .. table.concat(tabCounts, ","),
        "redraws=" .. tostring(self.redrawCount or 0),
        "shellRebuilds=" .. tostring(self.shellRebuilds or 0),
        "tabRebuilds=" .. tostring(self.tabRebuilds or 0),
        "needsRedraw=" .. tostring(self.needsRedraw)
    )
end

