function UI:DestroyPathDebugDrawings()
    if not self.pathDebugDrawings then
        return
    end

    local drawings = self.pathDebugDrawings
    local lists = {
        {drawings.currentLine, drawings.currentCircle, drawings.currentLabel},
        drawings.nodeLines or {},
        drawings.nodeCircles or {},
        drawings.nodeLabels or {},
    }

    for _, list in ipairs(lists) do
        for _, obj in ipairs(list) do
            if obj then
                pcall(function()
                    obj.Visible = false
                end)
                pcall(function()
                    obj:Remove()
                end)
            end
        end
    end

    self.pathDebugDrawings = nil
end

function UI:DestroyEspObjects()
    for key, entry in pairs(self.espObjects or {}) do
        if entry then
            for _, obj in pairs(entry) do
                if obj then
                    pcall(function()
                        obj.Visible = false
                    end)
                    pcall(function()
                        obj:Remove()
                    end)
                end
            end
        end
        self.espObjects[key] = nil
    end
end

function UI:Destroy()
    self.isRunning = false
    pcall(function()
        self:StopWalking()
    end)
    pcall(function()
        self:CancelTweenToPositions("destroy")
    end)

    if self.heartbeatConnection then
        pcall(function()
            self.heartbeatConnection:Disconnect()
        end)
        pcall(function()
            self.heartbeatConnection:disconnect()
        end)
        self.heartbeatConnection = nil
    end

    pcall(function()
        self:DestroyPathDebugDrawings()
    end)
    pcall(function()
        self:DestroyEspObjects()
    end)

    if self.overlayBucket then
        pcall(function()
            self:DestroyBucket(self.overlayBucket)
        end)
    end

    BaseDestroy(self)
end

function UI:HandleTransientEffects()
    BaseHandleTransientEffects(self)

    local now = tick()
    if (self.cuteGirlOverlayUntil or 0) > 0 and now >= (self.cuteGirlOverlayUntil or 0) then
        self.cuteGirlOverlayUntil = 0
        self:MarkShellDirty()
    end
end

function UI:BuildOverlay()
    if not self.overlayBucket then
        return
    end

    local bucket = self.overlayBucket
    self:BeginBucket(bucket)
    self.renderAlpha = 1

    if (self.cuteGirlOverlayUntil or 0) <= tick() then
        self:EndBucket(bucket)
        self:HideBucket(bucket)
        self.renderAlpha = 1
        return
    end

    local wx, wyBase = self:GetRenderWindowPosition()
    local wy = wyBase + self:GetAnimatedWindowYOffset()
    local ww = self.window.width
    local wh = self.window.height
    local overlaySize = 41 * 12
    local overlayX = wx + math.floor((ww - overlaySize) * 0.5)
    local overlayY = wy + math.floor((wh - overlaySize) * 0.5)
    local cuteGirlImageData = self:GetCuteGirlImageData()

    if cuteGirlImageData then
        self:CreateImage(bucket, cuteGirlImageData, overlayX, overlayY, overlaySize, overlaySize, 1)
    else
        self:DrawFastBox(bucket, overlayX, overlayY, overlaySize, overlaySize, Theme.panelAlt, Theme.accent, 1)
        self:CreateText(bucket, "cute girl", overlayX + math.floor(overlaySize * 0.5), overlayY + math.floor(overlaySize * 0.5) - 6, Theme.text, 44, true)
    end

    self:EndBucket(bucket)
    self.renderAlpha = 1
end

function UI:Render()
    pcall(function()
        self:RefreshPlayerTeleportOptions()
    end)

    BaseRender(self)

    if self.isBooting or not self.overlayBucket then
        return
    end

    if (not self.uiVisible) and (self.uiAlpha or 0) <= 0.01 then
        self:HideBucket(self.overlayBucket)
        return
    end

    if (self.cuteGirlOverlayUntil or 0) > tick() then
        self:BuildOverlay()
    else
        self:HideBucket(self.overlayBucket)
    end
end

