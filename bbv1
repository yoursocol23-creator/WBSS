function UI:ParseMarkdownSegments(text)
    local ok, parsed = pcall(function()
        local source = tostring(text or ""):gsub("\r\n", "\n"):gsub("\r", "\n")
        local lines = {}

        if source == "" then
            return {
                {
                    segments = {
                        {text = "", bold = false, code = false},
                    },
                    heading = false,
                    bullet = false,
                },
            }
        end

        local function parseInline(content)
            local segments = {}
            local index = 1

            local function addSegment(value, bold, code)
                if value and value ~= "" then
                    table.insert(segments, {
                        text = value,
                        bold = bold == true,
                        code = code == true,
                    })
                end
            end

            while index <= #content do
                local boldStart = content:find("%*%*", index)
                local codeStart = content:find("`", index, true)
                local markerStart = nil
                local markerType = nil

                if boldStart and (not codeStart or boldStart < codeStart) then
                    markerStart = boldStart
                    markerType = "bold"
                elseif codeStart then
                    markerStart = codeStart
                    markerType = "code"
                end

                if not markerStart then
                    addSegment(content:sub(index), false, false)
                    break
                end

                if markerStart > index then
                    addSegment(content:sub(index, markerStart - 1), false, false)
                end

                if markerType == "bold" then
                    local closeStart, closeEnd = content:find("%*%*", markerStart + 2)
                    if closeStart then
                        addSegment(content:sub(markerStart + 2, closeStart - 1), true, false)
                        index = closeEnd + 1
                    else
                        addSegment(content:sub(markerStart), false, false)
                        break
                    end
                else
                    local closeStart = content:find("`", markerStart + 1, true)
                    if closeStart then
                        addSegment(content:sub(markerStart + 1, closeStart - 1), false, true)
                        index = closeStart + 1
                    else
                        addSegment(content:sub(markerStart), false, false)
                        break
                    end
                end
            end

            if #segments == 0 then
                table.insert(segments, {text = "", bold = false, code = false})
            end

            return segments
        end

        for rawLine in (source .. "\n"):gmatch("([^\n]*)\n") do
            local line = rawLine
            local heading = false
            local bullet = false

            if line:sub(1, 2) == "# " then
                heading = true
                line = line:sub(3)
            elseif line:sub(1, 2) == "- " then
                bullet = true
                line = line:sub(3)
            end

            table.insert(lines, {
                segments = parseInline(line),
                heading = heading,
                bullet = bullet,
            })
        end

        return lines
    end)

    if ok and type(parsed) == "table" then
        return parsed
    end

    return {
        {
            segments = {
                {text = tostring(text or ""), bold = false, code = false},
            },
            heading = false,
            bullet = false,
        },
    }
end

function UI:BuildMarkdownRenderLines(text, maxWidth, maxLines)
    local parsed = self:ParseMarkdownSegments(text)
    local renderLines = {}
    local widest = 0
    maxWidth = math.max(40, tonumber(maxWidth) or 160)
    maxLines = tonumber(maxLines) or 24

    local function segmentWidth(segment, size)
        local text = tostring(segment and segment.text or "")
        local width = self:EstimateAITextWidth(text, size)
        if segment and segment.code then
            width = width + 8
        end
        return width
    end

    local function pushLine(line)
        if #renderLines >= maxLines then
            return false
        end

        line.width = line.width or 0
        line.size = line.size or 13
        line.lineH = line.lineH or (line.heading and 20 or 15)
        widest = math.max(widest, line.width + (line.indent or 0))
        table.insert(renderLines, line)
        return true
    end

    for _, sourceLine in ipairs(parsed) do
        local size = sourceLine.heading and 16 or 13
        local lineH = sourceLine.heading and 20 or 15
        local indent = sourceLine.bullet and 14 or 0
        local lineMaxWidth = math.max(40, maxWidth - indent)

        local current = {
            segments = {},
            heading = sourceLine.heading == true,
            bullet = sourceLine.bullet == true,
            bulletFirst = sourceLine.bullet == true,
            indent = indent,
            size = size,
            lineH = lineH,
            width = 0,
        }

        local hadWords = false
        for _, segment in ipairs(sourceLine.segments or {}) do
            local text = tostring(segment.text or "")
            for word in text:gmatch("%S+") do
                hadWords = true
                local wordSegment = {
                    text = word,
                    bold = segment.bold == true or sourceLine.heading == true,
                    code = segment.code == true,
                }
                local spacerWidth = current.width > 0 and self:EstimateAITextWidth(" ", size) or 0
                local wordWidth = segmentWidth(wordSegment, size)

                if current.width > 0 and (current.width + spacerWidth + wordWidth) > lineMaxWidth then
                    if not pushLine(current) then
                        renderLines[#renderLines].segments = {
                            {text = "...", bold = false, code = false},
                        }
                        return renderLines, widest
                    end
                    current = {
                        segments = {},
                        heading = sourceLine.heading == true,
                        bullet = false,
                        bulletFirst = false,
                        indent = indent,
                        size = size,
                        lineH = lineH,
                        width = 0,
                    }
                    spacerWidth = 0
                end

                if spacerWidth > 0 then
                    table.insert(current.segments, {text = " ", bold = false, code = false, spacer = true})
                    current.width = current.width + spacerWidth
                end

                table.insert(current.segments, wordSegment)
                current.width = current.width + wordWidth
            end
        end

        if hadWords then
            if not pushLine(current) then
                renderLines[#renderLines].segments = {
                    {text = "...", bold = false, code = false},
                }
                return renderLines, widest
            end
        else
            pushLine({
                segments = {
                    {text = "", bold = false, code = false},
                },
                heading = sourceLine.heading == true,
                bullet = sourceLine.bullet == true,
                bulletFirst = sourceLine.bullet == true,
                indent = indent,
                size = size,
                lineH = math.max(9, lineH - 4),
                width = 0,
            })
        end
    end

    if #renderLines == 0 then
        pushLine({
            segments = {
                {text = "", bold = false, code = false},
            },
            size = 13,
            lineH = 15,
            width = 0,
        })
    end

    return renderLines, widest
end

function UI:GetMarkdownLinesHeight(lines)
    local height = 0
    for _, line in ipairs(lines or {}) do
        height = height + (line.lineH or 15)
    end
    return height
end

function UI:DrawMarkdownLines(bucket, lines, x, y, maxWidth, defaultColor, viewTop, viewBottom)
    if not bucket then
        return
    end

    local function estimateAITextWidth(text, size)
        return math.floor(#tostring(text or "") * ((size or 14) * 0.42))
    end

    local function cleanSpaces(text)
        return tostring(text or ""):gsub("%s+", " ")
    end

    local cursorY = y

    for _, line in ipairs(lines or {}) do
        local lineH = line.lineH or 15
        local size = line.size or 13

        if cursorY >= viewTop and (cursorY + lineH) <= viewBottom then
            local segmentX = x + (line.indent or 0)

            if line.bulletFirst then
                self:CreateText(bucket, "â€¢", x + 1, cursorY, Theme.accent, size, false)
            end

            local pendingText = ""

            local function flushPending()
                pendingText = cleanSpaces(pendingText)

                if pendingText ~= "" then
                    local color = line.heading and Theme.text or defaultColor
                    self:CreateText(bucket, pendingText, segmentX, cursorY, color, size, false)
                    segmentX = segmentX + estimateAITextWidth(pendingText, size)
                    pendingText = ""
                end
            end

            for _, segment in ipairs(line.segments or {}) do
                local segmentText = tostring(segment.text or "")

                if segment.code then
                    flushPending()

                    segmentText = cleanSpaces(segmentText)
                    local segmentW = estimateAITextWidth(segmentText, size)
                    local codeW = segmentW + 8

                    local codeBg = self:CreateSquare(bucket, segmentX - 3, cursorY - 1, codeW, lineH - 1, Theme.bg, 0.95, true)
                    local codeBorder = self:CreateSquare(bucket, segmentX - 3, cursorY - 1, codeW, lineH - 1, Theme.border, 0.95, false, 1)

                    self:SetDrawingZIndex(codeBg, 60000, bucket)
                    self:SetDrawingZIndex(codeBorder, 65000, bucket)
                    self:CreateText(bucket, segmentText, segmentX + 1, cursorY, Theme.accentSoft or Theme.accent, size, false)

                    segmentX = segmentX + codeW

                elseif segment.bold then
                    flushPending()

                    segmentText = cleanSpaces(segmentText)
                    local color = Theme.text
                    local segmentW = estimateAITextWidth(segmentText, size)

                    self:CreateText(bucket, segmentText, segmentX, cursorY, color, size, false)
                    self:CreateText(bucket, segmentText, segmentX + 1, cursorY, color, size, false)

                    segmentX = segmentX + segmentW

                elseif segment.spacer then
                    if pendingText ~= "" and pendingText:sub(-1) ~= " " then
                        pendingText = pendingText .. " "
                    end

                else
                    if pendingText ~= "" and pendingText:sub(-1) ~= " " then
                        pendingText = pendingText .. " "
                    end
                    pendingText = pendingText .. segmentText
                end
            end

            flushPending()
        end

        cursorY = cursorY + lineH
    end
end

function UI:DrawAIChatTab(bucket)
    local x, y, width = self:GetContentBounds()
    self.scroll.max = 0
    self.scroll.offset = 0

    local pad = 10
    local headerY = y + 6
    local headerH = 24
    local newChatW = 76
    local testW = 52
    local buttonGap = 6
    local newChatX = x + width - pad - newChatW
    local testX = newChatX - buttonGap - testW

    if bucket then
        self:CreateText(bucket, "MatchaMind", x + pad, headerY + 3, Theme.text, 17, false)
        self:DrawFastBox(bucket, testX, headerY, testW, headerH, self.hoveredId == "ai_test_backend" and Theme.panelAlt or Theme.panel, Theme.border, 1)
        self:CreateText(bucket, "Test", testX + math.floor(testW * 0.5), headerY + 11, Theme.textDim, 13, true)
        self:DrawFastBox(bucket, newChatX, headerY, newChatW, headerH, self.hoveredId == "ai_new_chat" and Theme.panelAlt or Theme.panel, Theme.border, 1)
        self:CreateText(bucket, "New Chat", newChatX + math.floor(newChatW * 0.5), headerY + 11, Theme.textDim, 13, true)
    end


    self:RegisterHitbox("ai_new_chat", newChatX, headerY, newChatW, headerH, function()
        self:ClearAIChat()
    end, 3)

    local chatX, chatY, chatW, chatH = self:GetAIChatBounds()
    local composerX, composerY, composerW, composerH, inputX, inputW, sendX, sendW = self:GetAIComposerBounds()
    local inputControl = self:GetAIInputControl()
    local inputValue = tostring(self:GetControlRawValue(inputControl, ""))
    local trimmedInput = self:TrimText(inputValue)
    local inputActive = self.activeTextInput == "ai_prompt_input"
    local inputShown = inputValue

    if inputActive and self.searchCursor then
        inputShown = inputShown .. "|"
    end

    if inputShown == "" and not inputActive then
        inputShown = tostring(inputControl and (inputControl.placeholder or inputControl.Placeholder) or "Message MatchaMind...")
    end

    if bucket then
        self:DrawFastBox(bucket, chatX, chatY, chatW, chatH, Theme.bg, Theme.border, 1)
    end

    local messages = {}
    local hasUserMessage = false
    for _, message in ipairs(self.aiMessages or {}) do
        if message and message.role == "user" then
            hasUserMessage = true
        end
        table.insert(messages, message)
    end

    if self.aiIsSending then
        table.insert(messages, {
            role = "assistant",
            text = self.aiActiveJobId and "Waiting for reply..." or "MatchaMind is thinking...",
            pending = true,
        })
    end

    local layouts = {}
    local totalH = 0
    local gap = 9
    local maxBubbleW = math.max(150, math.floor(chatW * 0.72))

    for index, message in ipairs(messages) do
        local role = tostring((message and message.role) or "assistant")
        local text = tostring((message and message.text) or "")
        local widest = self:EstimateTextWidth(role == "user" and "You" or "MatchaMind", 12)
        local lines = nil
        local markdownLines = nil
        local bodyH = 0

        if role == "user" then
            lines = self:WrapText(text, maxBubbleW - 18, 13)
            if #lines > 12 then
                while #lines > 12 do
                    table.remove(lines)
                end
                lines[#lines] = self:TruncateText(tostring(lines[#lines] or "") .. " ...", maxBubbleW - 18, 13)
            end

            for _, line in ipairs(lines) do
                widest = math.max(widest, self:EstimateTextWidth(line, 13))
            end
            bodyH = #lines * 15
        else
            markdownLines, widest = self:BuildMarkdownRenderLines(text, maxBubbleW - 18, 24)
            widest = math.max(widest, self:EstimateTextWidth("MatchaMind", 12))
            bodyH = self:GetMarkdownLinesHeight(markdownLines)
        end

        local bubbleW = math.min(maxBubbleW, math.max(132, widest + 20))
        local bubbleH = 27 + bodyH
        layouts[index] = {
            role = role,
            lines = lines,
            markdownLines = markdownLines,
            w = bubbleW,
            h = bubbleH,
            pending = message and message.pending == true,
        }

        if index > 1 then
            totalH = totalH + gap
        end
        totalH = totalH + bubbleH
    end

    local viewTop = chatY + 8
    local viewBottom = chatY + chatH - 8
    local viewportH = math.max(1, viewBottom - viewTop)
    self.aiChatContentHeight = totalH
    self.aiChatViewportHeight = viewportH
    self.aiChatScrollMax = math.max(0, totalH - viewportH)

    if self.aiScrollToLatest then
        self.aiChatScroll = self.aiChatScrollMax
    else
        self.aiChatScroll = math.clamp(self.aiChatScroll or 0, 0, self.aiChatScrollMax)
    end

    if bucket and #layouts == 0 and not hasUserMessage and not self.aiIsSending then
        local centerX = chatX + math.floor(chatW * 0.5)
        local centerY = chatY + math.floor(chatH * 0.5) - 16
        self:CreateText(bucket, "What can I help with?", centerX, centerY, Theme.text, 18, true)
        self:CreateText(bucket, "Ask MatchaMind anything.", centerX, centerY + 24, Theme.textMuted, 13, true)
    end

    local cursorY = viewTop - (self.aiChatScroll or 0)
    for _, layout in ipairs(layouts) do
        local bubbleY = cursorY
        local bubbleBottom = bubbleY + layout.h
        local intersects = bubbleBottom >= viewTop and bubbleY <= viewBottom

        if bucket and intersects then
            local isUser = layout.role == "user"
            local bubbleX = isUser and (chatX + chatW - layout.w - 12) or (chatX + 12)
            local fill = isUser and Theme.panelAlt or Theme.panel
            local border = isUser and Theme.accent or Theme.border
            local textColor = layout.pending and Theme.textMuted or Theme.text
            local boxY = math.max(bubbleY, viewTop)
            local boxBottom = math.min(bubbleBottom, viewBottom)
            local boxH = math.max(0, boxBottom - boxY)

            if boxH > 0 then
                self:DrawFastBox(bucket, bubbleX, boxY, layout.w, boxH, fill, border, 1)
            end

            local headerText = isUser and "You" or "MatchaMind"
            local headerY = bubbleY + 6
            if headerY >= viewTop and (headerY + 12) <= viewBottom then
                self:CreateText(bucket, headerText, bubbleX + 9, headerY, isUser and Theme.accent or Theme.textDim, 12, false)
            end

            if isUser then
                for lineIndex, line in ipairs(layout.lines or {}) do
                    local lineY = bubbleY + 21 + ((lineIndex - 1) * 15)
                    if lineY >= viewTop and (lineY + 14) <= viewBottom then
                        self:CreateText(bucket, line, bubbleX + 9, lineY, textColor, 13, false)
                    end
                end
            else
                self:DrawMarkdownLines(bucket, layout.markdownLines, bubbleX + 9, bubbleY + 21, layout.w - 18, textColor, viewTop, viewBottom)
            end
        end

        cursorY = bubbleY + layout.h + gap
    end

    if self.aiChatScrollMax > 0 then
        local trackX = chatX + chatW - 5
        local trackH = math.max(1, viewBottom - viewTop)
        local thumbH = math.max(24, math.floor(trackH * (viewportH / math.max(viewportH, totalH))))
        local available = math.max(1, trackH - thumbH)
        local thumbY = viewTop + math.floor(available * ((self.aiChatScroll or 0) / math.max(1, self.aiChatScrollMax)))
        if bucket then
            self:CreateSquare(bucket, trackX, viewTop, 2, trackH, Theme.panel, 0.85, true)
            self:CreateSquare(bucket, trackX, thumbY, 2, thumbH, Theme.accent, 1, true)
        end
        self:RegisterHitbox("ai_chat_scrollbar", trackX - 8, thumbY - 4, 18, thumbH + 8, function()
            self.draggingAIChatScroll = true
            self.aiScrollToLatest = false
            self.aiScrollDragOffset = self:GetMouseLocation().Y - thumbY
        end, 4)
    end

    local showJump = self.aiChatScrollMax > 0 and (self.aiChatScroll or 0) < (self.aiChatScrollMax - 8)
    if showJump then
        local jumpW = 110
        local jumpH = 24
        local jumpX = chatX + chatW - jumpW - 12
        local jumpY = chatY + chatH - jumpH - 10

        if bucket then
            self:DrawFastBox(bucket, jumpX, jumpY, jumpW, jumpH, self.hoveredId == "ai_jump_latest" and Theme.panelAlt or Theme.panel, Theme.accent, 1)
            self:CreateText(bucket, "Jump To Latest", jumpX + math.floor(jumpW * 0.5), jumpY + 5, Theme.text, 13, true)
        end

        self:RegisterHitbox("ai_jump_latest", jumpX, jumpY, jumpW, jumpH, function()
            self.aiScrollToLatest = true
            self.aiChatScroll = self.aiChatScrollMax or 0
            self:MarkCurrentTabDirty()
        end, 5)
    end

    local canSend = trimmedInput ~= "" and not self.aiIsSending
    local sendFill = canSend and Theme.panelAlt or Theme.bg
    local sendTextColor = canSend and Theme.text or Theme.textMuted

    if bucket then
        self:DrawFastBox(bucket, composerX, composerY, composerW, composerH, Theme.panel, Theme.border, 1)
        self:DrawFastBox(bucket, inputX + 6, composerY + 7, inputW - 6, composerH - 14, Theme.bg, inputActive and Theme.accent or Theme.border, 1)
        self:CreateText(bucket, self:TruncateText(inputShown, inputW - 24, 14), inputX + 15, composerY + 18, inputValue == "" and not inputActive and Theme.textMuted or Theme.text, 14, false)
        self:DrawFastBox(bucket, sendX, composerY + 7, sendW, composerH - 14, sendFill, canSend and Theme.accent or Theme.border, canSend and 1 or 0.75)
        self:CreateText(bucket, self.aiIsSending and "Thinking" or "Send", sendX + math.floor(sendW * 0.5), composerY + 21, sendTextColor, 14, true)
    end

    self:RegisterHitbox("ai_prompt_input_box", inputX + 6, composerY + 7, inputW - 6, composerH - 14, function()
        self:FocusTextControl("ai_prompt_input")
    end, 4)

    self:RegisterHitbox("ai_send_button", sendX, composerY + 7, sendW, composerH - 14, function()
        self:SendAIMessage()
    end, 4)
end

function UI:DrawObsidianActiveTab(bucket)
    if self.selectedTab == self.aiTabIndex then
        return self:DrawAIChatTab(bucket)
    end

    local x, y, width, height = self:GetContentBounds()
    local columns = self:BuildObsidianGroups()
    local gap = 6
    local usableWidth = math.max(1, width - self:GetScrollbarGutter())
    local colW = math.max(1, math.floor((usableWidth - gap - 4) * 0.5))
    local colX = {
        x + 2,
        x + 2 + colW + gap,
    }
    local contentTop = y + 2 + math.floor((self.contentOffset or 0) + 0.5) - self.scroll.offset
    local contentBottom = y + height - 2

    for side = 1, 2 do
        local cursorY = contentTop
        for _, group in ipairs(columns[side]) do
            local innerX = colX[side] + 7
            local innerW = math.max(1, colW - 14)
            local groupH = self:GetGroupHeight(group, innerW)
            local visible = cursorY + groupH >= y and cursorY <= contentBottom

            if visible then
                self:DrawObsidianGroupFrame(bucket, group, colX[side], cursorY, colW, groupH)
                local controlY = cursorY + 42
                for index, control in ipairs(group.controls) do
                    if index > 1 then
                        controlY = controlY + 8
                    end
                    local controlH = self:GetControlHeight(control, innerW)
                    if controlY + controlH >= y and controlY <= contentBottom then
                        self:DrawObsidianControl(bucket, control, innerX, controlY, innerW, contentBottom)
                    end
                    controlY = controlY + controlH
                end
            end

            cursorY = cursorY + groupH + 6
        end
    end
end

function UI:RegisterActiveTabHitboxes()
    if self.selectedTab == self.aiTabIndex then
        self:DrawAIChatTab(nil)
        return
    end

    self:DrawObsidianActiveTab(nil)

    local scrollbarX, scrollbarY, scrollbarW, scrollbarH, thumbY, thumbH = self:GetScrollbarMetrics()
    if self.scroll.max > 0 then
        local animatedThumbY = math.floor((self.animatedScrollThumbY or thumbY) + 0.5)
        self:RegisterHitbox("scrollbar_thumb", scrollbarX - 10, animatedThumbY - 2, scrollbarW + 20, thumbH + 4, function()
            self.draggingScroll = true
            self.scrollDragOffset = self:GetMouseLocation().Y - animatedThumbY
        end, 3)
    end
end

