function UI:GetCustomerTargetPosition()
    local mouseIgnore = workspace:FindFirstChild("MouseIgnore")
    local guidingArrow = mouseIgnore and mouseIgnore:FindFirstChild("GuidingArrow_PizzaDelivery_Customer")
    local gameFolder = workspace:FindFirstChild("_game")
    local spawnedCharacters = gameFolder and gameFolder:FindFirstChild("SpawnedCharacters")
    local rootPart = self:GetLocalRootPart()
    local cachedPosition = self.farmState.lastPizzaCustomerPosition
    local cachedName = tostring(self.farmState.lastPizzaCustomerName or "unknown")
    local cachedDot = tonumber(self.farmState.lastPizzaCustomerDot)
    if not guidingArrow or not guidingArrow:IsA("BasePart") then
        FarmDebug("Customer lookup: guiding arrow missing")
        if rootPart and typeof(cachedPosition) == "Vector3" and (rootPart.Position - cachedPosition).Magnitude <= 20 then
            FarmDebug(string.format(
                "Customer lookup fallback: using cached target name=%s dot=%s distance=%.2f target=(%.2f, %.2f, %.2f)",
                cachedName,
                cachedDot and string.format("%.4f", cachedDot) or "nil",
                (rootPart.Position - cachedPosition).Magnitude,
                cachedPosition.X,
                cachedPosition.Y,
                cachedPosition.Z
            ))
            return cachedPosition
        end
        return nil
    end

    if not spawnedCharacters then
        FarmDebug("Customer lookup: _game/SpawnedCharacters missing")
        return nil
    end

    local arrowPosition = guidingArrow.Position
    local arrowLook = guidingArrow.CFrame.LookVector
    local bestModel = nil
    local bestPosition = nil
    local bestDot = -1
    local bestDistance = math.huge
    local bestDeliveryModel = nil
    local bestDeliveryPosition = nil
    local bestDeliveryDot = -1
    local bestDeliveryDistance = math.huge

    FarmDebug(string.format(
        "Customer lookup arrow: pos=(%.2f, %.2f, %.2f) look=(%.3f, %.3f, %.3f)",
        arrowPosition.X,
        arrowPosition.Y,
        arrowPosition.Z,
        arrowLook.X,
        arrowLook.Y,
        arrowLook.Z
    ))

    for _, customer in ipairs(spawnedCharacters:GetChildren()) do
        local customerName = tostring(customer and customer.Name or "")
        local loweredName = string.lower(customerName)
        if customer:IsA("Model")
            and string.find(loweredName, "pizza", 1, true)
            and string.find(loweredName, "customer", 1, true)
        then
            local isDeliveryCustomer = string.find(loweredName, "delivery", 1, true) ~= nil
            local candidatePart = customer:FindFirstChild("HumanoidRootPart")
            if not (candidatePart and candidatePart:IsA("BasePart")) then
                candidatePart = customer:FindFirstChild("Head")
            end
            if not (candidatePart and candidatePart:IsA("BasePart")) then
                candidatePart = customer.PrimaryPart
            end
            if not (candidatePart and candidatePart:IsA("BasePart")) then
                for _, descendant in ipairs(customer:GetDescendants()) do
                    if descendant:IsA("BasePart") then
                        candidatePart = descendant
                        break
                    end
                end
            end

            if candidatePart and candidatePart:IsA("BasePart") then
                local candidatePosition = candidatePart.Position
                local offset = candidatePosition - arrowPosition
                local distance = offset.Magnitude

                if distance > 2 then
                    local direction = offset.Unit
                    local dot = (arrowLook.X * direction.X) + (arrowLook.Y * direction.Y) + (arrowLook.Z * direction.Z)

                    FarmDebug(string.format(
                        "Customer lookup candidate: name=%s delivery=%s dot=%.4f distance=%.2f pos=(%.2f, %.2f, %.2f)",
                        customerName,
                        tostring(isDeliveryCustomer),
                        dot,
                        distance,
                        candidatePosition.X,
                        candidatePosition.Y,
                        candidatePosition.Z
                    ))

                    if dot > 0.85 then
                        if isDeliveryCustomer then
                            if distance < bestDeliveryDistance or (math.abs(distance - bestDeliveryDistance) <= 0.01 and dot > bestDeliveryDot) then
                                bestDeliveryModel = customer
                                bestDeliveryPosition = candidatePosition
                                bestDeliveryDot = dot
                                bestDeliveryDistance = distance
                            end
                        end
                        if distance < bestDistance or (math.abs(distance - bestDistance) <= 0.01 and dot > bestDot) then
                            bestModel = customer
                            bestPosition = candidatePosition
                            bestDot = dot
                            bestDistance = distance
                        end
                    elseif dot > bestDot then
                        bestDot = dot
                    end
                end
            else
                FarmDebug(string.format("Customer lookup candidate skipped: name=%s invalid_part", customerName))
            end
        end
    end

    if bestDeliveryModel and bestDeliveryPosition then
        bestModel = bestDeliveryModel
        bestPosition = bestDeliveryPosition
        bestDot = bestDeliveryDot
        bestDistance = bestDeliveryDistance
    end

    if bestModel and bestPosition then
        self.farmState.lastPizzaCustomerPosition = bestPosition
        self.farmState.lastPizzaCustomerName = tostring(bestModel.Name)
        self.farmState.lastPizzaCustomerDot = bestDot
        FarmDebug(string.format(
            "Customer lookup result: name=%s dot=%.4f distance=%.2f target=(%.2f, %.2f, %.2f)",
            tostring(bestModel.Name),
            bestDot,
            bestDistance,
            bestPosition.X,
            bestPosition.Y,
            bestPosition.Z
        ))
        return bestPosition
    end

    if rootPart and typeof(cachedPosition) == "Vector3" and (rootPart.Position - cachedPosition).Magnitude <= 20 then
        FarmDebug(string.format(
            "Customer lookup fallback: using cached target name=%s dot=%s distance=%.2f target=(%.2f, %.2f, %.2f)",
            cachedName,
            cachedDot and string.format("%.4f", cachedDot) or "nil",
            (rootPart.Position - cachedPosition).Magnitude,
            cachedPosition.X,
            cachedPosition.Y,
            cachedPosition.Z
        ))
        return cachedPosition
    end

    FarmDebug(string.format(
        "Customer lookup result: no valid customer bestDot=%s",
        bestDot >= 0 and string.format("%.4f", bestDot) or "nil"
    ))
    return nil
end

function UI:GetCharacterTeleportPart(character)
