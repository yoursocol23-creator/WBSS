        if ok and formatted ~= nil then
            return tostring(formatted)
        end
    end

    return tostring(value)
end

function UI:GetFormattedDropdownValue(control)
    local controlType = self:GetControlType(control)

    if controlType == "dropdown_single" then
        local value = self:GetControlRawValue(control, nil)
        if value == nil or value == "" then
            return "---"
        end
        return self:FormatDropdownValue(control, value)
    end

    local active = {}
    local selected = control.selected or control.Selected or control.value or control.Value or {}
    for _, option in ipairs(self:GetControlOptions(control)) do
        if selected[option] then
            table.insert(active, self:FormatDropdownValue(control, option))
        end
    end

    if #active == 0 then
        return "---"
    end

    if #active <= 2 then
        return table.concat(active, ", ")
    end

    return active[1] .. ", " .. active[2] .. " +" .. tostring(#active - 2)
end

function UI:IsDropdownOptionDisabled(control, option)
    local disabledValues = control.disabledOptions or control.DisabledValues or control.disabledValues
    if type(disabledValues) ~= "table" then
        return false
    end

    if disabledValues[option] == true then
        return true
    end

    for _, value in ipairs(disabledValues) do
        if value == option then
            return true
        end
    end

    return false
end

